#################################################################
#  SECTION B1   Core Geological Hypothesis
#################################################################

psca:Atlantis_Identification_Claim
    a psca:SelfAssertedClaim ;
    dct:description "Identification of Plato's Atlantis with the Sardinian-Corsican geological block (Insula Magna)."@en ;
    psca:confidenceLevel "0.95"^^xsd:float ;
    prov:wasDerivedFrom psca:PSCA_Scientific_Abstract_2026 .

psca:MeltwaterPulse1B_Event
    a psca:SelfAssertedClaim ;
    dct:description "Meltwater Pulse 1B (~9600 BC) as the eustatic event responsible for submerging the continental shelf at -120m."@en ;
    psca:confidenceLevel "0.90"^^xsd:float .

psca:Evidence_WadatiBenioff_Sulcis
    a psca:EvidenceVector ;
    dct:description "Use of EMODnet bathymetry and Wadati-Benioff fault under Sulcis as physical anchors for the Atlantis narrative."@en .

#################################################################
#  SECTION B2   Geomythological Recalibration
#################################################################

psca:Geographic_Sparagmos
    a psca:SelfAssertedClaim ;
    dct:description "Hypothesis of geographic sparagm s: ancient names originally referring to Sardinia-Corsica were later reassigned to North Africa."@en .

psca:Herodotus_Libya_Reinterpretation
    a psca:SelfAssertedClaim ;
    dct:description "Interpretation of Herodotus' 'Libya' as Southern Sardinia (Sulcis/Campidano)."@en .

psca:Hesperides_Fruttidoro
    a psca:SelfAssertedClaim ;
    dct:description "Identification of the Garden of the Hesperides at Fruttidoro (Capoterra), interpreted as Caput Terrae."@en .

psca:Pillars_of_Hercules_Carloforte
    a psca:SelfAssertedClaim ;
    dct:description "Identification of the Pillars of Hercules with the Faraglione 'Antiche Colonne' in Carloforte."@en .

psca:Odyssey_Sardinian_Route
    a psca:SelfAssertedClaim ;
    dct:description "Mapping of Ulysses' route along the Sardinian coast (Porto Maga, Gallura, etc.)."@en .

#################################################################
#  SECTION B3   Biological and Genetic Evidence
#################################################################

psca:Sardinia_Frozen_Archive
    a psca:SelfAssertedClaim ;
    dct:description "Sardinia described as a 'Frozen Archive' of Neolithic and pre-Indo-European genetics (Marcus et al. 2020)."@en .

psca:PostCataclysmic_Gap
    a psca:SelfAssertedClaim ;
    dct:description "Formalization of a chronological gap (9600 6000 BC) explaining genetic discontinuity at Su Carroppu."@en .

psca:Gigantism_Hypothesis
    a psca:SelfAssertedClaim ;
    dct:description "Hypothesis linking Sardinian gigantism to the Giants' Graves."@en .

psca:Atlantean_Neoteny
    a psca:SelfAssertedClaim ;
    dct:description "Hypothesis of Atlantean neoteny as a biological marker."@en .

#################################################################
#  SECTION B4   Cultural and Linguistic Diaspora
#################################################################

psca:Global_Megalithism_Claim
    a psca:SelfAssertedClaim ;
    dct:description "Claim that global megalithic sites share a Sardinian-Corsican-Atlantean origin."@en .

psca:Atlantean_Language_Family
    a psca:SelfAssertedClaim ;
    dct:description "Definition of an 'Atlantean Language Family' linking Basque, Sumerian, Finnish, Quechua, etc."@en .

psca:Sitting_Burial_Marker
    a psca:SelfAssertedClaim ;
    dct:description "Cross-reference between Herodotus' Nasamones and sitting burials at Mont'e Prama."@en ;
    psca:confidenceLevel "0.95"^^xsd:float .

psca:Hypogeism_FalseDoor
    a psca:SelfAssertedClaim ;
    dct:description "Domus de Janas as the origin of the 'False Door' archetype in Etruscan and Lydian tombs."@en .

#################################################################
#  SECTION B5   Methodologies and Inventions
#################################################################

psca:Conceptometry_Method
    a psca:SelfAssertedClaim ;
    dct:description "Conceptometry: method for measuring conceptual density in ancient texts."@en .

psca:QS2C_Framework
    a psca:SelfAssertedClaim ;
    dct:description "QS C: Quantum and Contextual Semantic Compression framework."@en .

psca:Narrative_Tensors
    a psca:SelfAssertedClaim ;
    dct:description "Narrative Tensors: mathematical model for computational narratology."@en .

psca:Tastiera_Usai
    a psca:SelfAssertedClaim ;
    dct:description "Tastiera USAI: patented musical keyboard/accordion innovation."@en .

