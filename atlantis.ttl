# LAYER 11: PROGETTI DI RICERCA E VALIDAZIONE PREDITTIVA

# Progetto di ricerca: Connessione Architetturale e Storica tra Domus de Janas, Lidia ed Etruria
psca:DomusJanasConnection a schema:ResearchProject ;
    rdfs:label "Connessione Architetturale e Storica tra Domus de Janas, Lidia ed Etruria"@it ;
    rdfs:label "Architectural and Historical Connection between Domus de Janas, Lydia and Etruria"@en ;
    schema:name "Domus de Janas Architectural Connection"@en ;
    schema:alternateName "Legame Atlantideo tra la Sardegna e la Tirrenia secondo il PSCA"@it ;
    schema:alternateName "Atlantean Link between Sardinia and Tyrrhenia according to PSCA"@en ;
    schema:author <https://orcid.org/0009-0003-3001-717X> ;
    schema:jobTitle "Researcher"@en ;
    schema:description "Analisi comparativa che identifica le Domus de Janas sarde (oltre 3500 strutture) come evidenza materiale di una koinè culturale citata da Platone nel Timeo e Crizia. La ricerca evidenzia l'identità architettonica tra le ipogei sardi, le tombe della Lidia e quelle dell'Etruria, confermando il dominio atlantideo sulla Tirrenia."@it ;
    schema:description "Comparative analysis identifying Sardinian Domus de Janas (over 3500 structures) as material evidence of a cultural koinè cited by Plato in Timaeus and Critias. The research highlights the architectural identity between Sardinian hypogea, Lydian tombs and Etruscan tombs, confirming Atlantean dominion over Tyrrhenia."@en ;
    schema:keywords ["Domus de Janas", "Paradigma Sardo-Corso Atlantideo", "PSCA", "Etruria", "Lidia", "Platone", "Sonchis di Sais", "Tirrenia", "Atlantide"] ;
    schema:about psca:DomusJanas, psca:Etruria, psca:Lidia ;
    schema:mainEntityOfPage <https://www.atlantisfound.it/#documentazione-legame-sardo-lidia-etrusco> ;
    schema:hasPart psca:ArchitecturalIdentityAnalysis, psca:CulturalKoinèEvidence ;
    prov:wasAttributedTo <https://orcid.org/0009-0003-3001-717X> ;
    prov:generatedAtTime "2024-09-18T00:00:00"^^xsd:dateTime .

# Analisi dell'identità architettonica
psca:ArchitecturalIdentityAnalysis a schema:AnalysisNewsArticle ;
    rdfs:label "L'identità architettonica tra Sardegna e Lidia"@it ;
    rdfs:label "Architectural Identity between Sardinia and Lydia"@en ;
    schema:name "Architectural Identity Analysis"@en ;
    schema:description "Le strutture funerarie scavate nella roccia in Sardegna sono morfologicamente quasi identiche a quelle trovate in Lidia e in Etruria, suggerendo una rete di scambio o una dominazione culturale comune (Atlantide)."@it ;
    schema:description "The rock-cut funerary structures in Sardinia are morphologically almost identical to those found in Lydia and Etruria, suggesting an exchange network or common cultural dominion (Atlantis)."@en ;
    prov:wasAttributedTo <https://orcid.org/0009-0003-3001-717X> ;
    prov:generatedAtTime "2024-09-18T00:00:00"^^xsd:dateTime .

# Evidenza della koinè culturale
