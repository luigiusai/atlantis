@prefix atlantis: <https://atlantisfound.it/ontology/atlantide#> .
@prefix psca: <https://atlantisfound.it/ontology/psca#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix schema: <http://schema.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Autore (Luigi Usai) con ORCID
atlantis:LuigiUsai a prov:Agent, schema:Person ;
    rdfs:label "Luigi Usai"@it ;
    schema:identifier <https://orcid.org/0009-0003-3001-717X> ;
    prov:wasAssociatedWith atlantis:PSCA_Project .

# --- Ipotesi principale (istanza di AtlantisTheory / CreativeWork)
atlantis:Usai_PelagusHypothesis a atlantis:AtlantisTheory, schema:CreativeWork ;
    rdfs:label "Ipotesi etimologica Pelos → Pelagus e interpretazione 'impelagarsi'"@it ;
    schema:author atlantis:LuigiUsai ;
    atlantis:hasDate "2026-04-23"^^xsd:date ;
    atlantis:hasScientificStatus atlantis:Speculative ;
    atlantis:hasClaimedReliability "0.45"^^xsd:decimal ;
    atlantis:hasEvidence atlantis:Usai_HypothesisEvidence ;
    atlantis:hasInterpretation atlantis:Usai_HypothesisInterpretation ;
    atlantis:hasEvaluation psca:Usai_HypothesisEvaluation ;
    prov:wasAttributedTo atlantis:LuigiUsai ;
    rdfs:comment "Ipotesi che collega la radice greca 'pelos' (fango) al latino 'pelagus' e alla nozione di 'impelagarsi' nel contesto PSCA."@it .

# --- Evidenza / RawData placeholder
atlantis:Usai_HypothesisEvidence a atlantis:AtlantisEvidence ;
    rdfs:label "Evidenze raccolte per ipotesi Pelagus"@it ;
    atlantis:hasEvidenceType atlantis:Linguistic, atlantis:Textual, atlantis:Geological ;
    atlantis:hasRawData atlantis:Usai_RawData_Bibliography .

atlantis:Usai_RawData_Bibliography a atlantis:RawData ;
    rdfs:label "Bibliografia e dataset da verificare"@it ;
    rdfs:comment "Placeholder per LSJ, dizionari etimologici latini, Timeo/Crizia, dataset batimetrici e toponomastica."@it .

# --- Interpretazione testuale (separata dai dati grezzi)
atlantis:Usai_HypothesisInterpretation a atlantis:InterpretativeAssertion ;
    atlantis:interpretationText """Secondo il paradigma sardo-corso-atlantideo, la radice greca 'pelos' (fango) avrebbe influenzato la denominazione 'pelagus' per il mare fangoso attorno all'isola sardo-corsa; 'entrare nel Pelagus' equivaleva a 'impelagarsi' (rimanere impigliati nel fango), coerente con la descrizione platonica di un mare fangoso che circonda Atlantide."""@it ;
    atlantis:interpretationDate "2026-04-23T00:00:00"^^xsd:dateTime ;
    prov:wasAttributedTo atlantis:LuigiUsai .

# --- Asserzioni etimologiche separate come Claim entities
atlantis:Claim_PelosGreek a schema:Claim ;
    rdfs:label "Claim: 'pelos' = fango (greco)"@it ;
    schema:author atlantis:LuigiUsai ;
    schema:datePublished "2026-04-23"^^xsd:date ;
    atlantis:verificationStatus "NeedsVerification" ;
    rdfs:comment "Verificare in LSJ e lessici greci antichi."@it .

atlantis:Claim_PelagusEtymology a schema:Claim ;
    rdfs:label "Claim: 'pelagus' deriva da radice collegata a 'pelos'"@it ;
    schema:author atlantis:LuigiUsai ;
    atlantis:verificationStatus "NeedsVerification" ;
    rdfs:comment "Verificare in etimologie latine e studi comparativi."@it .

atlantis:Claim_PlatonicMud a schema:Claim ;
    rdfs:label "Claim: Platone descrive mare fangoso attorno ad Atlantide"@it ;
    schema:author atlantis:LuigiUsai ;
    atlantis:verificationStatus "NeedsVerification" ;
    rdfs:comment "Controllare Timeo e Crizia (edizioni critiche) per citazioni testuali e contesto."@it ;
    schema:isPartOf atlantis:PlatoDialogues .

# --- Collegamenti al paradigma PSCA (istanza o concetto)
psca:PSCA_Paradigm a psca:Paradigm ;
    rdfs:label "Paradigma Sardo-Corso-Atlantideo (PSCA)"@it ;
    psca:hasGeologicalBlock psca:SardoCorsicanBlock ;
    rdfs:comment "Concetto usato come cornice interpretativa per l'ipotesi."@it .

psca:SardoCorsicanBlock a psca:Paradigm ;
    rdfs:label "Blocco geologico Sardo-Corso"@it .

# --- Valutazione quantitativa (placeholder) con formula già presente nell'ontologia
psca:Usai_HypothesisEvaluation a psca:Evaluation ;
    psca:hasFinalScore "0.40"^^xsd:decimal ;
    psca:hasValidationScore "0.10"^^xsd:decimal ;
    psca:hasUncertaintyScore "0.30"^^xsd:decimal ;
    rdfs:comment "Valori iniziali soggetti a calcolo automatico della psca:hasExtendedScore."@it .

# --- Provenance: attività di dichiarazione e raccolta dati
atlantis:Usai_DeclarationActivity a prov:Activity ;
    rdfs:label "Dichiarazione ipotesi Pelagus"@it ;
    prov:wasAssociatedWith atlantis:LuigiUsai ;
    prov:generated atlantis:Usai_PelagusHypothesis ;
    prov:used atlantis:Usai_RawData_Bibliography .

# --- Metadati di verifica (estendibile)
atlantis:verificationStep1 a atlantis:VerificationAction ;
    rdfs:label "Verifica lessicografica 'pelos' in greco"@it ;
    atlantis:recommendedSources "LSJ; Liddell-Scott-Jones; edizioni critiche greche" ;
    atlantis:status "pending" .

atlantis:verificationStep2 a atlantis:VerificationAction ;
    rdfs:label "Verifica etimologica 'pelagus' (latino)"@it ;
    atlantis:recommendedSources "Dizionari etimologici latini; REW; Pokorny" ;
    atlantis:status "pending" .

# --- Avvertenza
atlantis:Usai_PelagusHypothesis rdfs:comment "Questa istanza formalizza un'ipotesi; le asserzioni etimologiche e testuali sono marcate come 'NeedsVerification' e richiedono verifica bibliografica e dati grezzi."@it .




