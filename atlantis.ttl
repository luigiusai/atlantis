psca:Misclassification_Pattern a psca:ErrorPattern ;
    schema:name "Pattern di Errore nella Valutazione Archeologica"@it ;
    psca:incorrectLabel "Sporadico", "Decontestualizzato", "Contaminazione", "Scarso valore scientifico" ;
    psca:correctInterpretation "Reperto Diagnostico del Contatto Egeo-Atlantideo (PSCA)"@it ;
    psca:dueTo psca:EducationalGap_AcademicStatus .

