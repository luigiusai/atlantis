#################################################################
# 16. ESPANSIONE V. 22.0 - VALIDAZIONE ARCHEOGENETICA E GAP POST-CATACLISMATICO
#################################################################

# --- 1. IL CONCETTO DI "GAP" (Latenza Post-Sommersione) ---

psca:PostCataclysmicGap a psca:Hypothesis, crm:E4_Period ;
    rdfs:label "Gap Plurimillenario Post-Atlantideo"@it ;
    schema:startDate "-9600" ;
    schema:endDate "-6000" ;
    schema:description "Periodo di spopolamento o latenza informativa del blocco sardo-corso conseguente alla sommersione del 9600 a.C. Risolve l'apparente assenza di continuità tra la civiltà atlantidea e il neolitico sardo."@it ;
    psca:validatedBy psca:Evidence_GeneticDiscontinuity .

# --- 2. IL SITO CHIAVE E IL RICERCATORE ---

psca:CarloLuglie a schema:Person ;
    schema:name "Carlo Lugliè" ;
    schema:affiliation "Università degli Studi di Cagliari" ;
    schema:jobTitle "Professore di Preistoria e Protostoria" ;
    rdfs:comment "Le sue ricerche sul sito di Su Carroppu hanno fornito la base empirica per la comprensione del popolamento mesolitico della Sardegna."@it .

psca:SuCarroppu_Sirri a psca:ArchaeologicalSite ;
    rdfs:label "Riparo sotto roccia di Su Carroppu (Sirri, Carbonia)"@it ;
    psca:geologicalContext "Sulcis" ;
    schema:description "Sito fondamentale che ospita i resti umani più antichi della Sardegna (circa 11.000 BP / 9.000 a.C.)."@it ;
    psca:hasArtifact "Resti scheletrici Mesolitici" ;
    prov:wasInvestigatedBy psca:CarloLuglie .

# --- 3. VETTORE DI EVIDENZA: DISCONTINUITÀ GENETICA ---

psca:Evidence_GeneticDiscontinuity a psca:EvidenceVector ;
    rdfs:label "Discontinuità Genomica Mesolitico-Neolitico"@it ;
    schema:description "L'analisi del DNA mitocondriale (aplogruppi J2b1 e I3) dei resti di Su Carroppu mostra una firma genetica distinta dalle popolazioni neolitiche successive. Questo conferma che il popolamento definitivo della Sardegna avvenne circa 3000 anni dopo i primi abitanti mesolitici."@it ;
    psca:supports psca:PostCataclysmicGap ;
    schema:citation "Marcus et al. (2020), 'Genetic history from the Middle Neolithic to present on the Mediterranean island of Sardinia'" ;
    psca:epistemologicalImplication "La discontinuità prova un evento di interruzione demografica totale coerente con il cataclisma platonico (PSCA)."@it .

# --- 4. IL SARDO COME "FROZEN ARCHIVE" (DNA PIÙ ANTICO D'EUROPA) ---

psca:SardinianDNA_Refugium a psca:BiologicalAnomalie ;
    rdfs:label "Sardegna come Refugium Genetico Europeo"@it ;
    schema:description "Il DNA sardo moderno è considerato un fossile biologico: è l'unico in Europa a conservare intatta la componente genetica degli agricoltori neolitici e dei cacciatori-raccoglitori pre-indoeuropei, senza l'apporto delle migrazioni delle steppe."@it ;
    psca:isInterpretedBy psca:ParadigmaSardoCorsoAtlantideo ;
    rdfs:comment "Questa stasi genetica conferma la natura isolata e 'continenta' del blocco sardo-corso (Atlantide)."@it .

# --- 5. LOGICA DI CONNESSIONE AL PSCA ---

usai:SardoCorsicanBlock 
    psca:hasBiologicalProof psca:SardinianDNA_Refugium ;
    psca:hasArchaeologicalProof psca:SuCarroppu_Sirri .

psca:ParadigmaSardoCorsoAtlantideo
    psca:resolvesAnomaly "Mancanza di reperti tra il 9000 e il 6000 a.C. in Sardegna" ;
    psca:inference "La popolazione atlantidea (Su Carroppu) perì o migrò a causa della sommersione costiera; l'isola rimase inaccessibile fino alla stabilizzazione eustatica neolitica."@it .

