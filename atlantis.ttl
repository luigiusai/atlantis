# --- 3. MAPPATURA DEI CAPITOLI (ESTRAZIONE SEMANTICA) ---

<https://archive.org/details/erodoto-le-storie-vol-i-libri-i-iv#book4-ch1> a schema:Chapter ;
    schema:name "Libro IV — Capitolo 1" ;
    schema:position 1 ;
    schema:about wd:Q193763 ;
    schema:text "I Sciti abitano una regione vasta e pianeggiante  Sono un popolo nomade, famoso per la loro abilità a cavallo." ;
    schema:copyrightStatus "translation-protected" ;
    schema:textExcerpt "first two sentences only" ;
    prov:wasDerivedFrom <https://archive.org/details/erodoto-le-storie-vol-i-libri-i-iv> ;
    schema:license <https://archive.org/terms> .

<https://archive.org/details/erodoto-le-storie-vol-i-libri-i-iv#book4-ch2> a schema:Chapter ;
    schema:name "Libro IV — Capitolo 2" ;
    schema:position 2 ;
    schema:about wd:Q193763 ;
    schema:text "I costumi degli Sciti sono diversi da quelli dei Greci  Essi praticano rituali religiosi unici." ;
    schema:copyrightStatus "translation-protected" ;
    schema:textExcerpt "first two sentences only" ;
    prov:wasDerivedFrom <https://archive.org/details/erodoto-le-storie-vol-i-libri-i-iv> ;
    schema:license <https://archive.org/terms> .

<https://archive.org/details/erodoto-le-storie-vol-i-libri-i-iv#book4-ch3> a schema:Chapter ;
    schema:name "Libro IV — Capitolo 3" ;
    schema:position 3 ;
    schema:about wd:Q193763, wd:Q483 ;
    schema:text "Le Amazzoni, donne guerriere, furono incontrate dagli Sciti presso il fiume Tanais  Le due popolazioni si unirono." ;
    schema:copyrightStatus "translation-protected" ;
    schema:textExcerpt "first two sentences only" ;
    prov:wasDerivedFrom <https://archive.org/details/erodoto-le-storie-vol-i-libri-i-iv> ;
    schema:license <https://archive.org/terms> .

<https://archive.org/details/erodoto-le-storie-vol-i-libri-i-iv#book4-ch4> a schema:Chapter ;
    schema:name "Libro IV — Capitolo 4" ;
    schema:position 4 ;
    schema:about wd:Q1010 ;
    schema:text "La Libia è una terra vasta e misteriosa  Secondo Erodoto, è delimitata dal Nilo e dall'oceano." ;
    schema:copyrightStatus "translation-protected" ;
    schema:textExcerpt "first two sentences only" ;
    prov:wasDerivedFrom <https://archive.org/details/erodoto-le-storie-vol-i-libri-i-iv> ;
    schema:license <https://archive.org/terms> .

<https://archive.org/details/erodoto-le-storie-vol-i-libri-i-iv#book4-ch5> a schema:Chapter ;
    schema:name "Libro IV — Capitolo 5" ;
    schema:position 5 ;
    schema:about [ a schema:Thing ; schema:name "Tritonide" ] ;
    schema:text "Il lago Tritonide è menzionato come luogo sacro  Alcuni miti lo collegano alla nascita di Atena." ;
    schema:copyrightStatus "translation-protected" ;
    schema:textExcerpt "first two sentences only" ;
    prov:wasDerivedFrom <https://archive.org/details/erodoto-le-storie-vol-i-libri-i-iv> ;
    schema:license <https://archive.org/terms> .

# --- 4. CONCETTI WIKIDATA (ANCORAGGI PSCA) ---

wd:Q193763 a schema:Thing ; 
    schema:name "Sciti" .

wd:Q483 a schema:Thing ; 
    schema:name "Amazzoni" ;
    rdfs:comment "Connesse da Luigi Usai alla migrazione sardo-corsa verso il Mar Nero (PSCA)."@it .

wd:Q1010 a schema:Thing ; 
    schema:name "Libia" ;
    rdfs:comment "Nel Paradigma Sardo-Corso-Atlantideo, la Libia erodotea identifica la porzione meridionale della Sardegna."@it .

#################################################################
# 14. ESPANSIONE V. 21.0 - INTEGRAZIONE GLOBALE E FILOGENESI
#################################################################

# --- 1. CONNESSIONI EBRAICO-NURAGICHE (Isili e la Stele di Merenptah) ---

psca:Isili a psca:ArchaeologicalSite ;
    rdfs:label "Isili - Città di Iside e degli Ebrei"@it ;
    schema:description "Centro della Sardegna centrale con forti legami toponomastici e tradizionali con il mondo egizio (Iside) ed ebraico. Punto focale per l'identificazione del popolo Isrir della Stele di Merenptah."@it ;
    psca:interpretsAs psca:IsrirPeople .

psca:IsrirPeople a psca:AncientPopulation ;
    rdfs:label "Popolo Isrir (Israele Nuragico)"@it ;
    schema:description "Popolazione guerriera citata nella Stele di Merenptah (1200 a.C.), identificata nel PSCA come la migrazione nuragica sardo-atlantidea in Egitto e Palestina."@it ;
    psca:hasSource psca:Isili ;
    psca:historicalEquivalent wd:Q138952464 . # Link to Israel/Nuragic connection

# --- 2. FILOGENESI LINGUISTICA (Agglutinazione, Ergatività, Semitismo) ---

psca:UgaritMigration a psca:AncientMigration ;
    rdfs:label "Migrazione verso Ugarit"@it ;
    schema:description "Colonia sardo-corso-atlantidea nel Levante. La lingua ugaritica è classificata come semitica, sillabica, agglutinante ed ergativa."@it .

psca:QuechuaSardinianConnection a psca:Hypothesis ;
    rdfs:label "Isomorfismo Sardo-Quechua"@it ;
    schema:description "Corrispondenza linguistica tra il Sardo Campidanese 'Paraccu' (paraqu - ombrello) e il Quechua 'Paracas' (paraq - vento con pioggia)."@it ;
    psca:confidenceLevel "0.45"^^xsd:decimal .

psca:LinguisticU_Feature a psca:LinguisticFossil ;
    rdfs:label "Caratteristica Atlantidea della Vocale U"@it ;
    schema:description "L'insistenza della vocale finale 'U' (tipica del sardo moderno) come marcatore dell'antica lingua atlantidea esportata verso Sumeri, Hittiti e in Indonesia (Sulawesi - Lindu, Patung)."@it .

# --- 3. BIOLOGIA E GENETICA (Epatite B e Virus Preistorici) ---

psca:HepatitisBMigration a psca:EvidenceVector ;
    rdfs:label "Vettore Patogeno: Epatite B"@it ;
    schema:description "Tracciamento della diffusione del virus dell'Epatite B come marcatore delle migrazioni sardo-corso-atlantidee in Europa."@it ;
    schema:citation "Ten millennia of hepatitis B virus evolution (ResearchGate, 2021)" .

# --- 4. DIASPORA DELLE AMAZZONI E MEGALITISMO MONDIALE ---

psca:AmazonGlobalMegalithism a psca:Hypothesis ;
    rdfs:label "Diffusione Megalitica delle Amazzoni"@it ;
    schema:description "Le colonie di donne guerriere (Amazzoni), originarie del Lago Tritonide (Cagliari), hanno esportato la cultura dei dolmen (stile Sa Coveccada) in India, Corea, Caucaso (Gelendžik) e Mar Nero."@it ;
    psca:supportedBy psca:Dolmen_Gelendzhik, psca:Dolmen_SaCoveccada .

psca:Dolmen_Gelendzhik a psca:ArchaeologicalSite ;
    rdfs:label "Dolmen di Gelendžik (Russia)"@it ;
    psca:isomorphicWith psca:Dolmen_SaCoveccada ;
    schema:description "Strutture dolmeniche nel Mar Nero identiche per tecnica e forma a quelle sarde di Mores."@it .

# --- 5. EROI E DIVINITÀ ATLANTIDEE IN IRLANDA E GIAPPONE ---

psca:EriuIreland a psca:MythologicalEntity ;
    rdfs:label "Ériu (Irlanda)"@it ;
    schema:description "Dea patrona dell'Irlanda e regina dei Túatha de Danann. Nel PSCA, corrisponde al cognome sardo 'Eriu' (Heriu), indicando una migrazione sarda verso le isole britanniche."@it ;
    psca:relatedTo psca:MummiaUsai_Father_Heriu .

psca:AinuJomonConnection a psca:Hypothesis ;
    rdfs:label "Origine Sardo-Atlantidea degli Ainu (Giappone)"@it ;
    schema:description "Il popolo Jomon/Ainu presenta tratti morfologici e culturali (megalitismo, ceramica) che suggeriscono un contatto o una discendenza dal nucleo sardo-corso-atlantideo pleistocenico."@it .

# --- 6. NAVIGAZIONE NEOLITICA (Le Canoe di Bracciano) ---

psca:LaMarmottaCanoes a psca:ArchaeologicalSite ;
    rdfs:label "Sito de La Marmotta (Lago di Bracciano)"@it ;
    schema:description "Ritrovamento di canoe monossili del 5700 a.C. Prova della tecnologia navale avanzata dei discendenti atlantidei nel Mediterraneo."@it ;
    psca:supportedBy "Il ruolo centrale della superpotenza navale neolitica Sardo Corsa (Usai, 2021)" .

# --- 7. EVEMERISMO E TRASFORMAZIONE TEOLOGICA (Poseidone vs Satana) ---

psca:PoseidonToSatanEvolution a psca:TheologicalTransition ;
    rdfs:label "Cristianizzazione di Poseidone"@it ;
    schema:description "Processo di distorsione semantica in cui il sovrano atlantideo Poseidone (Dio delle Acque, elmo cornuto, tridente) viene convertito nella figura di Satana (Dio del Fuoco, corna, forcone) per operare una Damnatio Memoriae del culto sardo-atlantideo."@it ;
    psca:semanticShift [
        psca:from "Tridente (Potere sul Mare)" ;
        psca:to "Forcone (Tormento Infernale)"
    ] ;
    psca:supportedBy "La tomba del Capo (Sant'Andrea Priu) - trasformazione di ipogeo nuragico in chiesa bizantina." .

# --- 8. GEOGRAFIA SACRA E TOPONIMI ---

psca:IsolaDellaVacca a psca:GeographicalEntity ;
    rdfs:label "Isola della Vacca / Isola del Toro"@it ;
    schema:description "Riferimento al culto nuragico-atlantideo del Dio Toro (Baal/Bull). Memoria zootecnica sacra."@it .

psca:IsBrebeisStagno a psca:Toponym ;
    rdfs:label "Stagno Is Brebeis (Sulcis)"@it ;
    schema:description "Dal sardo 'Brebei' (Pecora). Marcatore toponomastico della transizione economica mesolitica-neolitica nel blocco sardo-corso."@it .

psca:Sinnai_Sinai_Link a psca:ToponymicShift ;
    rdfs:label "Sinnai (Sardegna) = Sinai (Egitto)"@it ;
    schema:description "Il raddoppiamento consonantico sardo-atlantideo (Sinnai) semplificato nella vocalizzazione ebraica (Sinai)."@it .

# --- 9. COMPLETAMENTO AMAZZONI MAR NERO (V. 17 riparata) ---

psca:SauromatiOrigin a psca:AncientPopulation ;
    rdfs:label "Sauromati"@it ;
    schema:description "Popolazione nata dall'unione delle Amazzoni sarde (migrate sul Mar Nero) con gli Sciti."@it ;
    psca:hasSource psca:AmazonMigration .

