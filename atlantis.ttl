#################################################################
# 19. ESPANSIONE V. 25.0 - FILOGENESI DELL'IPOGEISMO MEDITERRANEO
#################################################################

# --- 1. LA TESI CENTRALE (MATRICE DELL'IPOGEISMO) ---

psca:MediterraneanHypogeismOrigin a owl:Class, crm:E89_Propositional_Object ;
    schema:name "Matrice Originaria dell'Ipogeismo Mediterraneo"@it ;
    schema:description "Tesi ontologica del PSCA: l'architettura rupestre funeraria mediterranea ha un epicentro epistemologico nel Blocco Sardo-Corso. Etruria e Anatolia/Lidia ne sono derivazioni diasporiche."@it ;
    crm:P148_has_component psca:DomusDeJanas_Root, psca:EtruscanTombs_Branch, psca:LydianTombs_Branch ;
    psca:motivatedBy psca:MeltwaterPulse1B .

# --- 2. L'ARCHETIPO DELLA "FALSA PORTA" ---

psca:FalseDoorArchetype a crm:E28_Conceptual_Object, schema:DefinedTerm ;
    schema:name "L'Archetipo della Falsa Porta"@it ;
    schema:description "Elemento architettonico onnipresente nelle Domus de Janas, Etruria e Lidia. Nel PSCA rappresenta la porta metaforica verso la patria sommersa (la capitale del Sulcis), un passaggio irrevocabilmente chiuso dal mare."@it ;
    usai:conceptometryDensity "Altissima" .

# --- 3. RADICE E RAMIFICAZIONI (ABOX) ---

psca:DomusDeJanas_Root a schema:Place, crm:E22_Human-Made_Object ;
    schema:name "Domus de Janas (Radice Primigenia)"@it ;
    schema:temporalCoverage "Neolitico/Eneolitico (Cultura di Ozieri)" ;
    schema:address[ a schema:PostalAddress ; schema:addressRegion "Sardegna" ] ;
    schema:description "Riproduzione frattale delle abitazioni pre-diluviane sardo-corse scavate nella roccia viva."@it ;
    crm:P130_shows_features_of psca:FalseDoorArchetype ;
    psca:isBasedOn psca:MeltwaterPulse1B .

psca:EtruscanTombs_Branch a schema:Place, crm:E22_Human-Made_Object ;
    schema:name "Necropoli Rupestri Etrusche (Ramo Tirrenico)"@it ;
    schema:temporalCoverage "Età del Ferro" ;
    schema:address[ a schema:PostalAddress ; schema:addressRegion "Etruria" ] ;
    schema:description "Evoluzione del modello sardo introdotto in Italia centrale (es. Norchia, Cerveteri)."@it ;
    crm:P15_was_influenced_by psca:DomusDeJanas_Root ;
    crm:P130_shows_features_of psca:FalseDoorArchetype .

psca:LydianTombs_Branch a schema:Place, crm:E22_Human-Made_Object ;
    schema:name "Tombe Rupestri Anatoliche (Ramo Orientale)"@it ;
    schema:temporalCoverage "I Millennio a.C." ;
    schema:address[ a schema:PostalAddress ; schema:addressRegion "Lidia / Anatolia" ] ;
    schema:description "Facciate rupestri monumentali in Asia Minore, nate dall'influsso dei Popoli del Mare (diaspora atlantidea)."@it ;
    crm:P15_was_influenced_by psca:DomusDeJanas_Root ;
    crm:P130_shows_features_of psca:FalseDoorArchetype .

# --- 4. LA DIASPORA "OUT OF ATLANTIS" ---

psca:OutOfAtlantisDiaspora a crm:E9_Move, psca:AncientMigration ;
    schema:name "Diaspora Sardo-Corsa (Out of Atlantis)"@it ;
    schema:description "Irradiazione dei sopravvissuti atlantidei verso il Tirreno e il Levante, esportando il modello architettonico della casa rupestre."@it ;
    psca:triggeredBy psca:MeltwaterPulse1B ;
    crm:P16_used_specific_object psca:FalseDoorArchetype .

# --- 5. ARTICOLO SCIENTIFICO DI RIFERIMENTO ---

usai:ComparativeHypogeismArticle_2026 a schema:ScholarlyArticle ;
    schema:headline "Filogenesi dell'Ipogeismo: Dalla Sardegna all'Etruria e Anatolia"@it ;
    schema:author <https://orcid.org/0009-0003-3001-717X> ;
    schema:publisher[ a schema:Organization ; schema:name "Atlantis Found Research Group" ] ;
    schema:abstract "Analisi computazionale che identifica le Domus de Janas come incubatore dell'ipogeismo mediterraneo, nato come 'Architettura del Trauma' post-MWP-1B."@it ;
    psca:epistemologicalStatus "Testable Paradigm via Consilience of Inductions" .

