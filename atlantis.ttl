# Classi aggiuntive per la matrice di comparazione
psca:MilosCriterion a rdfs:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Criterio Milos"@it ;
    rdfs:label "Milos Criterion"@en ;
    rdfs:comment "Criterio di valutazione dalla conferenza di Milos"@it .

