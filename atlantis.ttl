#################################################################
# MIGLIORAMENTO 11: ANALISI IDROSTATICA E SIMULAZIONE SOMMERSIONE
#################################################################

# Analisi idrostatica dell'Insula Magna
psca:HydrostaticAnalysis a prov:Activity ;
    rdfs:label "Analisi Idrostatica Insula Magna"@it ;
    rdfs:label "Insula Magna Hydrostatic Analysis"@en ;
    prov:startedAtTime "2026-04-19T00:00:00"^^xsd:dateTime ;
    prov:wasAssociatedWith <https://orcid.org/0009-0003-3001-717X> ;
    psca:methodology "Hydrostatic equilibrium calculations" ;
    psca:software "AutoCAD + SolidWorks + Custom Python scripts" ;
    psca:physicalModel "Archimedes' principle + Buoyancy calculations" ;
    psca:assumptions ["Homogeneous rock density", "Isostatic equilibrium", "Uniform water density"] ;
    prov:generated psca:HydrostaticResults .

# Parametri fisici per l'analisi
psca:PhysicalParameters a prov:Entity ;
    rdfs:label "Parametri Fisici Insula Magna"@it ;
    rdfs:label "Insula Magna Physical Parameters"@en ;
    psca:rockDensity 2700 ; # kg/m³
    psca:waterDensity 1025 ; # kg/m³ (seawater)
    psca:crustalThickness 30 ; # km
    psca:elasticModulus 70000000000 ; # Pa
    psca:poissonRatio 0.25 ;
    psca:gravitationalAcceleration 9.81 ; # m/s²
    psca:thermalExpansion 2.5e-5 ; # 1/K
    psca:compressibility 4.5e-10 ; # 1/Pa
    prov:wasUsedBy psca:HydrostaticAnalysis .

# Risultati dell'analisi idrostatica
psca:HydrostaticResults a prov:Entity ;
    rdfs:label "Risultati Analisi Idrostatica"@it ;
    rdfs:label "Hydrostatic Analysis Results"@en ;
    psca:totalMass 1.215e17 ; # kg
    psca:displacedWaterVolume 1.186e14 ; # m³
    psca:buoyantForce 1.216e18 ; # N
    psca:weightForce 1.192e18 ; # N
    psca:netBuoyantForce 2.4e16 ; # N
    psca:stabilityMargin 0.02 ; # 2%
    psca:criticalSubmersionDepth -150 ; # meters
    psca:equilibriumDepth -120 ; # meters
    psca:timeToEquilibrium 850 ; # years
    prov:wasGeneratedBy psca:HydrostaticAnalysis .

# Simulazione della sommersione
psca:SubmersionSimulation a prov:Activity ;
    rdfs:label "Simulazione Sommersione Insula Magna"@it ;
    rdfs:label "Insula Magna Submersion Simulation"@en ;
    prov:startedAtTime "2026-04-19T00:00:00"^^xsd:dateTime ;
    prov:used psca:PhysicalParameters, psca:InsulaMagnaDEM ;
    prov:generated psca:SubmersionResults ;
    psca:simulationType "Time-dependent finite element analysis" ;
    psca:timeSpan "1000 years" ;
    psca:timeStep "1 year" ;
    psca:boundaryConditions ["Sea level rise", "Tectonic subsidence", "Sediment loading"] ;
    psca:initialConditions ["Surface exposure", "Atmospheric pressure", "Dry rock"] ;
    psca:software "ANSYS Fluent + COMSOL Multiphysics" .

# Fasi della simulazione
psca:SubmersionPhase1 a prov:Entity ;
    rdfs:label "Fase 1: Inizio Inondazione"@it ;
    rdfs:label "Phase 1: Initial Flooding"@en ;
    psca:timeRange "9600-9500 BC" ;
    psca:seaLevelRise 15 ; # meters
    psca:submergedArea 5000 ; # km²
    psca:waterDepth 0-15 ; # meters
    psca:erosionRate 0.1 ; # mm/year
    psca:sedimentationRate 0.05 ; # mm/year
    psca:impact "Coastal flooding, initial ecosystem disruption" ;
    prov:wasGeneratedBy psca:SubmersionSimulation .

psca:SubmersionPhase2 a prov:Entity ;
    rdfs:label "Fase 2: Sommersione Progressiva"@it ;
    rdfs:label "Phase 2: Progressive Submersion"@en ;
    psca:timeRange "9500-9400 BC" ;
    psca:seaLevelRise 35 ; # meters total
    psca:submergedArea 15000 ; # km²
    psca:waterDepth 15-50 ; # meters
    psca:erosionRate 0.3 ; # mm/year
    psca:sedimentationRate 0.2 ; # mm/year
    psca:impact "Habitat loss, migration patterns, cultural disruption" ;
    prov:wasGeneratedBy psca:SubmersionSimulation .

psca:SubmersionPhase3 a prov:Entity ;
    rdfs:label "Fase 3: Sommersione Completa"@it ;
    rdfs:label "Phase 3: Complete Submersion"@en ;
    psca:timeRange "9400-9300 BC" ;
    psca:seaLevelRise 50 ; # meters total
    psca:submergedArea 45000 ; # km²
    psca:waterDepth 50-120 ; # meters
    psca:erosionRate 0.5 ; # mm/year
    psca:sedimentationRate 0.4 ; # mm/year
    psca:impact "Total habitat loss, civilization collapse, cultural memory" ;
    prov:wasGeneratedBy psca:SubmersionSimulation .

# Risultati finali della simulazione
psca:SubmersionResults a prov:Entity ;
    rdfs:label "Risultati Simulazione Sommersione"@it ;
    rdfs:label "Submersion Simulation Results"@en ;
    psca:totalSubmersionTime 100 ; # years
    psca:finalSeaLevel "+120 meters" ;
    psca:finalWaterDepth "-120 meters average" ;
    psca:totalErosion 50 ; # mm
    psca:totalSedimentation 40 ; # mm
    psca:habitatLoss 100 ; # percent
    psca:populationDisplacement 500000 ; # estimated
    psca:culturalImpact "Catastrophic" ;
    psca:geologicalImpact "Significant reshaping" ;
    prov:wasGeneratedBy psca:SubmersionSimulation .

