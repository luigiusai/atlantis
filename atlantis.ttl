#################################################################
# Liste di toponimi e pattern fonetici (dittonghi) - campione
#################################################################
psca:ToponymPattern_Dittongo_EI a schema:Thing ;
    schema:name "Toponimi con dittongo 'ei' (campione)" ;
    schema:description "Esempi: Orosei; Baunei; Bultei; Burcei; Furtei; Gergei; Urzulei; Lanusei; Lei; Musei; Pauli Arbarei; Costa Rei; Triei." .

psca:ToponymPattern_Dittongo_AI a schema:Thing ;
    schema:name "Toponimi con dittongo 'ai' (campione)" ;
    schema:description "Esempi: Allai; Ollollai; Illorai; Lotzorai; Masainas; Olzai; Onifai; Samatzai; Ulassai." .

psca:ToponymPattern_Dittongo_OI a schema:Thing ;
    schema:name "Toponimi con dittongo 'oi' (campione)" ;
    schema:description "Esempi: Gavoi; Mammoiada; Loiri Porto San Paolo." .

psca:ToponymPattern_Dittongo_AU a schema:Thing ;
    schema:name "Toponimi con dittongo 'au' (campione)" ;
    schema:description "Esempi: Ardauli; Bauladu; Baunei; Pauli; Narcau; Tempio Pausania." .

#################################################################
# Ipotesi di ricerca e raccomandazioni (sintesi)
#################################################################
psca:ResearchPlan_ToponymDatabase a schema:HowTo ;
    schema:name "Creazione database toponomastico" ;
    schema:description "Creare un database strutturato con campi: toponimo, coordinate, prima attestazione, fonte, note etimologiche; importare SardegnaGeoPortale; normalizzare voci." .

psca:ResearchPlan_Filology a schema:HowTo ;
    schema:name "Verifiche filologiche" ;
    schema:description "Coinvolgere linguisti storici per validare etimologie; ricercare prime attestazioni documentarie; pubblicare inventario critico delle fonti." .

psca:ResearchPlan_GeologyArchaeology a schema:HowTo ;
    schema:name "Indagini geologiche e archeologiche" ;
    schema:description "Pianificare prospezioni batimetriche e sonar; eseguire carotaggi stratigrafici; coordinare campagne di scavo e ricognizione nelle aree costiere e lagunari." .

psca:ResearchPlan_Archaeogenetics a schema:HowTo ;
    schema:name "Analisi archeogenetiche" ;
    schema:description "Raccogliere e analizzare campioni antichi dalla Sardegna meridionale; confrontare con dataset del Levante e Nord Africa." .

psca:ResearchPlan_StatisticalValidation a schema:HowTo ;
    schema:name "Validazione statistica delle corrispondenze onomastiche" ;
    schema:description "Applicare test statistici e modelli di permutazione spaziale per stimare la significatività delle concentrazioni toponomastiche." .

#################################################################
# Avvertenze epistemiche e disclaimer
#################################################################
psca:Disclaimer_TentativeResearch a schema:CreativeWork ;
    schema:name "Disclaimer sulla natura esplorativa della ricerca" ;
    schema:description "Le ipotesi sono esplorative e speculative; molte affermazioni richiedono verifica filologica, stratigrafica e statistica per evitare correlazioni spurie e bias di conferma." .

