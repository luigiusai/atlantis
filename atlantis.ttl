psca:Liangzhu_China a psca:ArchaeologicalSite ;
rdfs:label "Città di Liangzhu" ;
psca:structure "Cerchi concentrici (stile capitale di Atlantide)" .

# --- 5. LINGUISTICA E POPOLI DEL MARE ---

psca:AtlanteanLanguage a psca:LinguisticRoot ;
