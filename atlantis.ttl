<https://www.luigiusai.it/doc/toponomastica-capoterra-psca> a schema:CreativeWork ;
    dcterms:creator <https://orcid.org/0009-0003-3001-717X> ;
    schema:name "Toponomastica sardo corso atlantidea relativa a Capoterra" ;
    dcterms:created "2026-04-13"^^xsd:date ;
    schema:license <https://creativecommons.org/licenses/by/4.0/> ;
    schema:description "Testo di Luigi Usai contenente osservazioni toponomastiche, ipotesi geomitologiche e proposte di ricerca relative a Capoterra, Frutti d'Oro, Colonne d'Ercole e al paradigma PSCA." .

#################################################################
# Entità principali e toponimi chiave
#################################################################
psca:Capoterra a psca:Toponym, psca:GeographicalEntity ;
    schema:name "Capoterra"@it ;
    rdfs:label "Capoterra (Cabuderra / Caput Terræ)"@it ;
    psca:hasAncientEquivalent "Caput Terræ; Cabuderra" ;
    psca:isInterpretedBy psca:ParadigmaSardoCorsoAtlantideo ;
    schema:description "Località in provincia di Cagliari interpretata come 'capo della terra' e limite occidentale conosciuto per i navigatori antichi." .

psca:FruttiDoro_Capoterra a psca:Toponym, psca:GeographicalEntity ;
    schema:name "Frutti d'Oro (frazione di Capoterra)"@it ;
    rdfs:label "Frutti d'Oro"@it ;
    schema:description "Frazione di Capoterra il cui toponimo richiama il mito delle Esperidi; elemento chiave per la proposta di localizzazione del Giardino delle Esperidi." ;
    psca:isPartOf psca:Capoterra .

psca:Carloforte_FaraglioneAnticheColonne a psca:GeographicalEntity ;
    schema:name "Faraglione Antiche Colonne (Carloforte)"@it ;
    rdfs:label "Faraglione Antiche Colonne"@it ;
    schema:description "Formazione rocciosa interpretata come possibile 'Colonne d'Ercole' nella ricostruzione proposta." ;
    psca:isInterpretedBy psca:ParadigmaSardoCorsoAtlantideo .

psca:SantAntioco a psca:GeographicalEntity ;
    schema:name "Sant'Antioco"@it ;
    rdfs:label "Sant'Antioco"@it ;
    schema:description "Isola/area collegata a Carloforte; parte della ricostruzione delle Colonne d'Ercole e della rotta antica." .

psca:PerdeSali a psca:Toponym, psca:GeographicalEntity ;
    schema:name "Perd'e Sali"@it ;
    rdfs:label "Perd'e Sali"@it ;
    schema:description "Toponimo locale interpretato come 'Pietra di Sale', messo in relazione con i 'monti di sale' menzionati da Erodoto." .

psca:LaguneCagliari a psca:GeographicalEntity ;
    schema:name "Lagune di Cagliari (Santa Gilla, Molentargius, Stagno di Capoterra)"@it ;
    rdfs:label "Lagune di Cagliari"@it ;
    schema:description "Serie di bacini lagunari interpretati come residui del Lago Tritonide menzionato nelle fonti antiche." .

psca:SulcisMassiccio a psca:GeologicalBlock, psca:GeographicalEntity ;
    schema:name "Massiccio del Sulcis"@it ;
    rdfs:label "Sulcis (Monti di Atlante)"@it ;
    schema:description "Area interpretata come i 'Monti di Atlante' nelle fonti antiche rilette secondo il PSCA." .

#################################################################
# Ipotesi e affermazioni (claim) estratte dal testo
#################################################################
psca:Claim_CapoterraAsHeadland a psca:Hypothesis ;
    schema:name "Capoterra come limite occidentale conosciuto e sede del Giardino delle Esperidi"@it ;
    schema:description "Ipotesi che identifica Capoterra (Cabuderra / Caput Terræ) e la frazione Frutti d'Oro con il Giardino delle Esperidi." ;
    psca:confidenceLevel "0.35"^^xsd:decimal ;
    psca:supportedBy psca:FruttiDoro_Capoterra, psca:Capoterra .

psca:Claim_ColumnsAtCarloforte a psca:Hypothesis ;
    schema:name "Colonne d'Ercole localizzate tra Carloforte e Sant'Antioco"@it ;
    schema:description "Interpretazione dei faraglioni denominati 'Antiche Colonne' come le Colonne d'Ercole della tradizione antica." ;
    psca:confidenceLevel "0.30"^^xsd:decimal ;
    psca:supportedBy psca:Carloforte_FaraglioneAnticheColonne, psca:SantAntioco .

psca:Claim_LibyaAsCagliariProvince a psca:Hypothesis ;
    schema:name "Ricalibrazione della 'Libia' erodotea sulla Sardegna meridionale"@it ;
    schema:description "Ipotesi che i 'Libi' di Erodoto corrispondano a popolazioni del Campidano/Sulcis piuttosto che all'attuale Nord Africa." ;
    psca:confidenceLevel "0.20"^^xsd:decimal ;
    psca:supportedBy psca:PerdeSali, psca:LaguneCagliari, psca:SulcisMassiccio .

psca:Claim_TritonideAsCagliariLagoons a psca:Hypothesis ;
    schema:name "Lago Tritonide corrisponde alle lagune di Cagliari"@it ;
    schema:description "Ipotesi che il Lago Tritonide menzionato nelle fonti antiche sia l'insieme delle lagune attuali di Cagliari." ;
    psca:confidenceLevel "0.40"^^xsd:decimal ;
    psca:supportedBy psca:LaguneCagliari .

#################################################################
# Evidenze, osservazioni e dati raccolti
#################################################################
psca:Observation_FruttiDoroPresence a schema:Observation ;
    schema:description "Presenza del toponimo 'Frutti d'Oro' nella frazione di Capoterra, considerata come indizio toponomastico per il mito delle Esperidi." ;
    dcterms:source <https://www.luigiusai.it/doc/toponomastica-capoterra-psca> .

psca:Observation_FaraglioneAnticheColonne a schema:Observation ;
    schema:description "Esistenza dei faraglioni denominati 'Faraglione Antiche Colonne' a Carloforte; osservazione visiva e toponomastica." ;
    dcterms:source <https://www.luigiusai.it/doc/toponomastica-capoterra-psca> .

psca:Observation_TempioPuntaDelMorto a schema:Observation ;
    schema:description "Segnalazione di resti di un tempio di età fenicio-punica a Punta del Morto, citata come prova archeologica locale." ;
    dcterms:source <https://www.sardegnaforeste.it/monumento-naturale/le-colonne-carloforte> .

psca:Observation_FuntToponymsCount a schema:Observation ;
    schema:description "Rilevamento di 3207 toponimi sardi che iniziano con 'Funt' (funti, funtana) dal portale SardegnaGeoPortale; interpretati come indice della ricchezza idrica del territorio." ;
    schema:value "3207"^^xsd:integer ;
    dcterms:source <https://www.sardegnageoportale.it/webgis/ricercatoponimi/search> .

