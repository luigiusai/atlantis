# Modulo di falsificazione automatizzata (V.30)
psca:Inference_01_LeadIsotopes a psca:ScientificDiscovery ;
    schema:name "Lead Isotope Fingerprinting of Oxhide Ingots" ;
    psca:falsifiableIf "Lead isotope ratio (Pb/Pb) matches Cyprus/Laurion deposits." ;
    psca:empiricalVerification "ICP-MS/MC-ICP-MS analysis on Levantine Bronze Age ingots." .

psca:Inference_02_DNA_SuCarroppu a psca:ScientificDiscovery ;
    schema:name "Genetic Stasis of Su Carroppu Population" ;
    psca:falsifiableIf "Genomic sequencing matches Neolithic Anatolian farmers." ;
    psca:empiricalVerification "Deep sequencing of ancient DNA (aDNA) from Neolithic layers." .

psca:Inference_03_Nuraghe_AntiSeismic a psca:ScientificDiscovery ;
    schema:name "Nuragic Anti-Seismic Engineering" ;
    psca:falsifiableIf "Structural failure in dynamic simulations mimicking 8.0 Magnitude earthquakes." ;
    psca:empiricalVerification "Dynamic simulation and stress test on nuragic masonry blocks." .

psca:Inference_04_Obsidian_Tokenization a psca:ScientificDiscovery ;
    schema:name "Obsidian as Economic Token" ;
    psca:falsifiableIf "Statistical analysis of obsidian weight/size lacks standardization (Random distribution)." ;
    psca:empiricalVerification "Standard deviation analysis of obsidian core weights across multiple sites." .

