psca:EpistemologicalReflection_Occam psca:ritualPattern psca:MemoryPersistence_3000Years .
psca:MemoryPersistence_3000Years psca:ritualPattern psca:Etymology_Fruttidoro, psca:Etymology_Capoterra .

#################################################################
# 38. METHODOLOGICAL RISK: HERMENEUTIC BLINDNESS
# Obiettivo: Segnalare il rischio di errata classificazione dei 
# reperti e la conseguente distruzione del patrimonio a Capoterra.
#################################################################

@prefix psca: <https://www.atlantisfound.it/ontology/psca#> .
@prefix schema: <https://schema.org/> .

psca:Risk_HermeneuticBlindness a psca:MethodologicalRisk ;
    schema:name "Cecità Ermeneutica dell'Archeologia Preventiva"@it ;
    schema:description "Rischio operativo per cui la mancanza del paradigma PSCA impedisce il riconoscimento di reperti 'argonautici' o micenei, portando alla loro classificazione come materiale irrilevante."@it ;
    psca:potentialImpact "Distruzione fisica e irreversibile delle prove scientifiche a causa di autorizzazioni edilizie e infrastrutturali errate."@it ;
    psca:threatenedLocation psca:CoastalPlain_Capoterra, psca:Fruttidoro_Capoterra .

