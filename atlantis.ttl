#################################################################
# 4. THE CORE PARADIGM & GEOLOGICAL HYPOTHESIS
#################################################################

psca:ParadigmaSardoCorsoAtlantideo a psca:Paradigm, schema:CreativeWork ;
    schema:name "Paradigma Sardo-Corso-Atlantideo (PSCA)" ;
    schema:author <https://orcid.org/0009-0003-3001-717X> ;
    psca:supports psca:InsulaMagna ;
    psca:cataclysmDate "9600 a.C. (MWP-1B)" ;
    psca:supportedBy psca:Evidence_Bathymetry, psca:Evidence_Paleogenetics, psca:Dataset_Mendeley_NIAID .

psca:InsulaMagna a psca:GeologicalBlock ;
    schema:name "Blocco Sardo-Corso (Atlantide Geologica)" ;
    schema:description "Piattaforma continentale semisommersa di 555 km di lunghezza."@it ;
    owl:sameAs <https://www.wikidata.org/wiki/Q120140> ;
    psca:submergedBy psca:MeltwaterPulse1B ;
    psca:isInterpretedBy psca:ParadigmaSardoCorsoAtlantideo .

psca:MeltwaterPulse1B a crm:E5_Event ;
    schema:name "Meltwater Pulse 1B" ;
    psca:chronology "9600 a.C." ;
    schema:description "Innalzamento eustatico rapido che ha causato la sommersione delle paleocoste."@it .

#################################################################
# 5. SCIENTIFIC PREDICTION & GEOLOGY (THE NEW CORE)
#################################################################

psca:ScientificPrediction_RapidSubmersion a psca:Hypothesis, psca:ScientificDiscovery ;
    rdfs:label "Predizione di Inabissamento Catastrofico del Blocco Sardo-Corso"@it ;
    schema:description "Il PSCA predice che futuri rilievi geologici dimostreranno una semisommersione rapida e catastrofica dell isola Sardo Corsa nel 9600 a.C., sfidando il modello della sommersione lenta."@it ;
    psca:status "Falsifiable Prediction / Awaiting Empirical Validation" ;
    psca:methodology psca:PredictiveArchaeology .

#################################################################
# 6. GEOMYTHOLOGICAL RECALIBRATION (MAPPING HERODOTUS & HOMER)
#################################################################

# --- Libia e Sirti ---
psca:Libya_Ancient a psca:MythicalEntity ;
    psca:interpretsAs psca:SardiniaSouth .

psca:LakeTritonis a psca:MythicalEntity ;
    psca:interpretsAs psca:CagliariLagoons .

# --- Giardino delle Esperidi & Capoterra ---
psca:GardenOfHesperides a psca:MythicalEntity ;
    psca:interpretsAs psca:Fruttidoro_Capoterra .

psca:Fruttidoro_Capoterra a psca:Toponym, psca:GeographicalEntity ;
    schema:name "Fruttidoro (Capoterra)" ;
    schema:description "Caput Terrae. Localizzazione del Giardino delle Esperidi."@it ;
    psca:isPartOf psca:SardiniaSouth .

# --- Colonne d'Ercole ---
psca:PillarsOfHercules a psca:MythicalEntity ;
    psca:interpretsAs psca:CarlofortePillars .

psca:CarlofortePillars a psca:GeographicalEntity ;
    schema:name "Faraglione Antiche Colonne (Carloforte)" .

# --- Rotta di Ulisse ---
psca:UlyssesRoute a psca:Hypothesis ;
    rdfs:label "Rotta di Ulisse in Sardegna" ;
    psca:supportedBy psca:PortoMaga, psca:Pistis_Toponym, psca:GrottaDelleSirene .

psca:PortoMaga a psca:Toponym ;
    rdfs:label "Porto Maga (Dimora di Circe)"  ;

#################################################################
# 7. BIOLOGICAL, GENETIC & FUNERARY EVIDENCE
#################################################################

psca:Evidence_Paleogenetics a psca:EvidenceVector ;
    schema:name "Stasi Genetica Sarda (Marcus et al. 2020)" ;
    schema:description "DNA sardo come 'Frozen Archive' del nucleo atlantideo."@it .

psca:PostCataclysmicGap a psca:Hypothesis, crm:E4_Period ;
    schema:name "Gap Mesolitico (9600-6000 a.C.)" ;
    schema:description "Periodo di spopolamento post-sommersione che spiega la discontinuità a Su Carroppu."@it .

psca:Nasamoni_MontePrama_Consilience a psca:EvidenceVector ;
    psca:confidenceLevel "0.95"^^xsd:decimal ;
    schema:description "Corrispondenza tra il rito del sepolcro seduto (Erodoto IV, 190) e le scoperte di Mont'e Prama."@it .

psca:Discovery_SanPantaleo_Lion a psca:ScientificDiscovery ;
    schema:headline "San Pantaleo come fossile semantico della Panthera Spelaea" ;
    psca:inference "Memoria geolocalizzata del leone pleistocenico nel Sulcis."@it .

#################################################################
# 8. DIASPORA "OUT OF ATLANTIS" & GLOBAL CONNECTIONS
#################################################################

psca:OutOfAtlantis a psca:Hypothesis ;
    schema:description "Esportazione post-glaciale della civiltà sarda verso Americhe, Egitto, Sumer e Giappone."@it .

psca:Megalithic_Diaspora a crm:E7_Activity ;
    schema:name "Diffusione del Megalitismo Atlantideo" ;
    psca:originatesFrom psca:InsulaMagna ;
    psca:reaches psca:Newgrange_Ireland, psca:RujmElHiri_Golan, psca:NagaokaCaves_Japan .

psca:AtlanteanLanguageFamily a psca:LinguisticFossil ;
    schema:description "Famiglia di lingue agglutinanti ed ergative (Basco, Sumero, Quechua)."@it .

#################################################################
# 9. HEURISTIC COMPARISON (ONTOLOGIA COMPARATIVA)
#################################################################

psca:Hypothesis_PSCA a psca:AtlantisHypothesis ;
    rdfs:label "Paradigma Sardo-Corso (PSCA)" ;
    psca:scoreGeographical 9 ;
    psca:scoreChronological 10 ;
    psca:scoreCataclysm 9 ;
    psca:scoreGranularity 10 ;
    psca:calculatedHeuristicProbability 0.80 .

psca:Hypothesis_Santorini a psca:AtlantisHypothesis ;
    rdfs:label "Ipotesi Minoica" ;
    psca:calculatedHeuristicProbability 0.60 .

psca:Hypothesis_Richat a psca:AtlantisHypothesis ;
    rdfs:label "Struttura di Richat" ;
    psca:calculatedHeuristicProbability 0.28 .

