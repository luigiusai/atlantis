#################################################################
# 18. ESPANSIONE V. 24.0 - IL MARCATORE FUNERARIO DEI NASAMONI
#################################################################

# --- 1. IL RITO DEL SEPOLCRO SEDUTO (MARCATORE ETNOGRAFICO) ---

psca:SittingBurialRite a psca:CulturalPhenomenon ;
    rdfs:label "Rito della Sepoltura Seduta"@it , "Sitting Burial Rite"@en ;
    schema:description "Pratica funeraria altamente specifica ed estremamente rara nel bacino del Mediterraneo, caratterizzata dalla deposizione del defunto in posizione seduta o costretta verticalmente."@it ;
    psca:isUniqueMarker "true"^^xsd:boolean ;
    psca:literarySource <https://archive.org/details/erodoto-le-storie-vol-i-libri-i-iv#book4_ch190> .

# --- 2. L'IDENTITÀ NASAMONI-NURAGICI ---

psca:Nasamones a psca:AncientPopulation ;
    rdfs:label "Nasamoni (Libia Erodotea)"@it ;
    schema:description "Popolazione descritta da Erodoto nella Libia occidentale. Nel PSCA, identificata come una specifica élite o tribù nuragica stanziata nel Sinis."@it ;
    psca:interpretsAs psca:MontePramaElite ;
    psca:hasFuneraryCustom psca:SittingBurialRite .

psca:MontePramaElite a psca:AncientPopulation ;
    rdfs:label "Elite Nuragica di Mont'e Prama"@it ;
    schema:description "Casta guerriera nuragica che si autorappresenta attraverso la statuaria colossale e pratica la sepoltura in tombe a pozzetto con assetto verticale/seduto."@it ;
    psca:locatedIn psca:MontePramaSite .

# --- 3. IL SITO ARCHEOLOGICO DI RIFERIMENTO ---

psca:MontePramaSite a psca:ArchaeologicalSite ;
    rdfs:label "Sito Archeologico di Mont'e Prama (Cabras)"@it ;
    geo:hasGeometry "POINT(8.4450 39.9558)" ;
    schema:description "Necropoli monumentale del Sinis caratterizzata da tombe a pozzetto con individui maschi giovani deposti seduti."@it ;
    psca:hasArtifact "Giganti di Mont'e Prama", "Tombe a pozzetto verticali" ;
    psca:providesEvidenceFor psca:Nasamoni_MontePrama_Consilience .

# --- 4. VETTORE DI CONSILIENZA (LA PROVA REGINA) ---

psca:Nasamoni_MontePrama_Consilience a psca:EvidenceVector ;
    rdfs:label "Consilienza Nasamoni-Mont'e Prama"@it ;
    psca:confidenceLevel "0.95"^^xsd:decimal ;
    schema:description "Il combinato disposto tra il passo erodoteo (IV, 190) e l'anomalia archeologica di Mont'e Prama valida la rilocazione della Libia antica in Sardegna. La specificità del rito (non morire supini) agisce come firma culturale univoca."@it ;
    psca:supports psca:Libya_Rethink ;
    psca:inference "I Nasamoni di Erodoto sono la casta guerriera nuragica del Sinis."@it .

# --- 5. RIFERIMENTO TESTUALE SPECIFICO ---

<https://archive.org/details/erodoto-le-storie-vol-i-libri-i-iv#book4_ch190> a schema:Chapter ;
    schema:name "Erodoto, Storie, Libro IV, Capitolo 190" ;
    schema:text "I Nasamoni seppelliscono i loro morti seduti, avendo cura, quando uno sta per spirare, di metterlo a sedere affinché non muoia supino." ;
    psca:ingestionDate "2026-04-12"^^xsd:date .

# --- 6. PUBBLICAZIONI CORRELATE ---

