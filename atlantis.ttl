psca:basedOnEvidenceCount a owl:DatatypeProperty ;
    rdfs:domain psca:Hypothesis ;
    rdfs:range xsd:integer ;
    rdfs:label "number of supporting evidences"@en  ;

psca:usesIndependentSources a owl:DatatypeProperty ;
    rdfs:domain psca:Hypothesis ;
    rdfs:range xsd:boolean ;
    rdfs:label "uses independent sources"@en  ;

