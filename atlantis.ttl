# Progetto di ricerca: Evoluzione Post-Catastrofica del Blocco Sardo-Corso
psca:PostCatastrophicEvolution a schema:ResearchProject ;
    rdfs:label "Evoluzione Post-Catastrofica del Blocco Sardo-Corso"@it ;
    rdfs:label "Post-Catastrophic Evolution of the Sardinian-Corsican Block"@en ;
    schema:name "Post-Catastrophic Evolution"@en ;
    schema:alternateName "Paradigma Sardo-Corso Atlantideo (PSCA) e la Ricostruzione Culturale Tirrenica"@it ;
    schema:alternateName "Sardinian-Corsican Atlantis Paradigm (PSCA) and Tyrrhenian Cultural Reconstruction"@en ;
    schema:author <https://orcid.org/0009-0003-3001-717X> ;
    schema:jobTitle "Researcher"@en ;
    schema:description "Studio sulla dinamica di occupazione umana post-evento eustatico. Dopo la semisommersione del blocco sardo-corso, la ricerca identifica un 'vuoto informativo' plurimillenario. Al termine di questo periodo di latenza, le popolazioni locali rielaborano nuove strutture cognitive, religiose e architettoniche, dando vita a complessi monumentali come le Domus de Janas (oltre 3500) e le Tombe dei Giganti, mantenendo una koinè stilistica con la Lidia e l'Etruria (Tirrenia) citata da Platone."@it ;
    schema:description "Study on human occupation dynamics after the eustatic event. After the semi-submersion of the Sardinian-Corsican block, the research identifies a multi-millennial 'information vacuum'. At the end of this latency period, local populations re-elaborate new cognitive, religious and architectural structures, giving life to monumental complexes such as the Domus de Janas (over 3500) and the Tombs of the Giants, maintaining a stylistic koinè with Lydia and Etruria (Tyrrhenia) cited by Plato."@en ;
    schema:keywords ["Domus de Janas", "Tombe dei Giganti", "Paradigma Sardo-Corso Atlantideo", "PSCA", "Vuoto informativo post-atlantideo", "Etruria", "Lidia", "Platone", "Tirrenia", "Rinascita Culturale Prenuragica"] ;
    schema:about psca:DomusJanas, psca:TombeDeiGiganti ;
    schema:hasPart psca:SemiSubmersioneEvent, psca:InformationVacuum, psca:CulturalRenaissance ;
    prov:wasAttributedTo <https://orcid.org/0009-0003-3001-717X> ;
    prov:generatedAtTime "2024-09-18T00:00:00"^^xsd:dateTime .

# Eventi e concetti del progetto
psca:SemiSubmersioneEvent a schema:Event ;
    rdfs:label "Semisommersione del Blocco Sardo-Corso"@it ;
    rdfs:label "Semi-submersion of the Sardinian-Corsican Block"@en ;
    schema:name "Semi-submersion Event"@en ;
    schema:description "Evento geologico di innalzamento eustatico che ha trasformato la piana sommersa sardo-corsa in un arcipelago, causando un collasso delle precedenti strutture sociali."@it ;
    schema:description "Geological eustatic rise event that transformed the submerged Sardinian-Corsican plain into an archipelago, causing a collapse of previous social structures."@en ;
    prov:wasAttributedTo <https://orcid.org/0009-0003-3001-717X> ;
    prov:generatedAtTime "2024-09-18T00:00:00"^^xsd:dateTime .

psca:InformationVacuum a schema:Concept ;
    rdfs:label "Vuoto d'informazione e Latenza Culturale"@it ;
    rdfs:label "Information Vacuum and Cultural Latency"@en ;
    schema:name "Information Vacuum and Cultural Latency"@en ;
    schema:description "Periodo plurimillenario caratterizzato dalla frammentazione dei popoli superstiti e dalla trasformazione delle memorie dell'antico dominio atlantideo in mito."@it ;
    schema:description "Multi-millennial period characterized by fragmentation of surviving peoples and the transformation of memories of the ancient Atlantean dominion into myth."@en ;
    prov:wasAttributedTo <https://orcid.org/0009-0003-3001-717X> ;
    prov:generatedAtTime "2024-09-18T00:00:00"^^xsd:dateTime .

psca:CulturalRenaissance a schema:Concept ;
    rdfs:label "Rinascita Culturale Prenuragica"@it ;
