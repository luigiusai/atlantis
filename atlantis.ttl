@prefix schema: <http://schema.org/> .
@prefix ex: <http://example.org/atlantis/> .

# --- Definizione delle Classi ---
ex:GeologicalBlock a rdfs:Class ;
    rdfs:label "Blocco Geologico"@it  ;

ex:MythologicalPlace a rdfs:Class ;
    rdfs:label "Luogo Mitologico"@it  ;

ex:AncientPeople a rdfs:Class ;
    rdfs:label "Popolo Antico"@it  ;

ex:ArchaeologicalSite a rdfs:Class ;
    rdfs:label "Sito Archeologico"@it  ;

ex:NaturalResource a rdfs:Class ;
    rdfs:label "Risorsa Naturale"@it  ;

# --- Definizione delle Proprietà ---
ex:isIdentifiedAs a rdf:Property ;
rdfs:domain ex:GeologicalBlock ;
rdfs:range ex:MythologicalPlace ;
    rdfs:label "è identificato come"@it  ;

ex:hasCapital a rdf:Property ;
rdfs:domain ex:GeologicalBlock ;
rdfs:range ex:ArchaeologicalSite ;
    rdfs:label "ha come capitale"@it  ;

ex:hasFeature a rdf:Property ;
rdfs:domain ex:GeologicalBlock ;
    rdfs:label "ha caratteristica"@it  ;

ex:wasSubmergedBy a rdf:Property ;
rdfs:domain ex:GeologicalBlock ;
    rdfs:label "fu sommerso da"@it  ;

ex:originOf a rdf:Property ;
rdfs:domain ex:GeologicalBlock ;
rdfs:range ex:AncientPeople ;
    rdfs:label "origine di"@it  ;

ex:hasResource a rdf:Property ;
rdfs:domain ex:GeologicalBlock ;
rdfs:range ex:NaturalResource ;
    rdfs:label "ha risorsa"@it  ;

ex:hasDiscoverer a rdf:Property ;
    rdfs:label "ha come scopritore"@it  ;

# --- Istanze e Relazioni ---

# Blocco Sardo-Corso (Atlantide)
ex:SardoCorsicanBlock a ex:GeologicalBlock ;
rdfs:label "Blocco Geologico Sardo-Corso"@it ;
schema:description "Frammento di litosfera continentale che include la Sardegna, la Corsica e le loro piattaforme continentali, attualmente semi-sommerso nel Mediterraneo Occidentale."@it ;
ex:isIdentifiedAs ex:Atlantis, ex:HaouNebout, ex:Meropide, ex:CyrneIchnusa ;
ex:hasCapital ex:Sulcis ;
ex:wasSubmergedBy "Innalzamento eustatico (escursione 120-140 metri)"@it ;
ex:originOf ex:Sumerians, ex:Basques, ex:Jews, ex:Aztecs, ex:Minoans, ex:Guanches, ex:SeaPeoples ;
ex:hasFeature "Alta densità archeologica"@it, "Oltre 7000 torri (Nuraghi)"@it, "Fango causato da erosione costiera"@it ;
schema:size "Lunghezza della pianura: circa 555 km (3000 stadi)"@it ;
ex:hasResource ex:Obsidian, ex:RedRocks, ex:WhiteRocks, ex:SulcisMines .

# Luoghi Mitologici
ex:Atlantis a ex:MythologicalPlace ;
    rdfs:label "Atlantide"@it  ;

ex:HaouNebout a ex:MythologicalPlace ;
    rdfs:label "Haou-Nebout"@it  ;

ex:Meropide a ex:MythologicalPlace ;
    rdfs:label "Meropide"@it  ;

ex:CyrneIchnusa a ex:MythologicalPlace ;
    rdfs:label "CyrneIchnusa"@it  ;

# Siti Geografici/Archeologici
ex:Sulcis a ex:ArchaeologicalSite ;
    rdfs:label "Sulcis"@it  ;

ex:Sardinia a schema:Place ;
rdfs:label "Sardegna"@it ;
schema:description "Altopiano emerso del blocco geologico sardo-corso."@it .

ex:Corsica a schema:Place ;
rdfs:label "Corsica"@it ;
schema:description "Parte montuosa a nord del blocco geologico sardo-corso."@it .

ex:PillarsOfHercules a ex:MythologicalPlace ;
rdfs:label "Colonne d'Ercole"@it ;
schema:sameAs ex:FaraglioneAnticheColonne .

ex:FaraglioneAnticheColonne a schema:LandmarksOrHistoricalBuildings ;
rdfs:label "Faraglione Antiche Colonne"@it ;
schema:addressLocality "Carloforte, Isola di San Pietro, Sardegna"@it ;
ex:hasDiscoverer ex:GiorgioSaba .

ex:Fetovaia a ex:ArchaeologicalSite ;
rdfs:label "Fetovaia"@it ;
schema:description "Porto neolitico dei sardi nel 3720 a.C."@it .

ex:TerresLongues a ex:ArchaeologicalSite ;
rdfs:label "Terres Longues"@it ;
schema:addressLocality "Trets, Provenza, Francia"@it ;
schema:description "Sito neolitico (circa 3720 a.C.) con deposito di 4548 frammenti di ossidiana del Monte Arci."@it .

# Popoli
ex:SeaPeoples a ex:AncientPeople ;
rdfs:label "Popoli del Mare"@it ;
schema:description "Popoli migrati da Atlantide sardo-corsa verso il resto del mondo."@it .

ex:Sumerians a ex:AncientPeople ;
    rdfs:label "Sumeri"@it  ;

ex:Basques a ex:AncientPeople ;
    rdfs:label "Baschi"@it  ;

ex:Jews a ex:AncientPeople ;
    rdfs:label "Ebrei"@it  ;

ex:Aztecs a ex:AncientPeople ;
rdfs:label "Atzechi"@it ;
schema:description "Migrazione atlantidea dal blocco geologico sardo corso."@it .

ex:Minoans a ex:AncientPeople ;
    rdfs:label "Minoici"@it  ;

ex:Guanches a ex:AncientPeople ;
    rdfs:label "Guanci"@it  ;

ex:NuragicPeople a ex:AncientPeople ;
rdfs:label "Popolo Nuragico"@it ;
schema:description "Sinonimo di popolo Atlantideo, termine inventato da Giovanni Lilliu."@it .

# Risorse e Caratteristiche
ex:Obsidian a ex:NaturalResource ;
rdfs:label "Ossidiana"@it ;
schema:description "Pietra nera vulcanica del Monte Arci, commercializzata in Europa (es. sito di Terres Longues)."@it ;
schema:color "Nero"@it .

ex:RedRocks a ex:NaturalResource ;
rdfs:label "Rocce Rosse"@it ;
schema:description "Presenti ad Arbatax e Carloforte (Sardegna)."@it ;
schema:color "Rosso"@it .

ex:WhiteRocks a ex:NaturalResource ;
rdfs:label "Rocce Bianche"@it ;
schema:description "Presenti ovunque in Sardegna."@it ;
schema:color "Bianco"@it .

ex:SulcisMines a ex:NaturalResource ;
rdfs:label "Miniere del Sulcis"@it ;
schema:description "Le miniere più antiche d'Europa."@it .

ex:MammuthusLamarmorai a schema:Taxon ;
rdfs:label "Mammuthus Lamarmorai"@it ;
schema:description "Specie di elefante presente nel blocco sardo-corso."@it .

# Persone
ex:LuigiUsai a schema:Person ;
rdfs:label "Luigi Usai"@it ;
schema:description "Propositore della teoria che identifica Atlantide col blocco sardo-corso."@it .

ex:GiorgioSaba a schema:Person ;
rdfs:label "Giorgio Saba"@it ;
schema:description "Scopritore delle Colonne d'Ercole a Carloforte."@it .

ex:AngeloMazzei a schema:Person ;
rdfs:label "Angelo Mazzei"@it ;
schema:description "Autore di uno studio su Fetovaia come porto neolitico sardo."@it .

ex:RobertHTykot a schema:Person ;
rdfs:label "Robert H. Tykot"@it ;
schema:description "Autore di studi sulla diffusione dell'ossidiana sarda nel Mediterraneo."@it .

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <http://schema.org/> .
@prefix psca: <https://www.atlantisfound.it/ontology/psca#> .

# --- Definizione delle Classi ---
psca:GeologicalBlock a rdfs:Class ; rdfs:label "Blocco Geologico"@it .
psca:ArchaeologicalSite a rdfs:Class ; rdfs:label "Sito Archeologico"@it .
psca:MythologicalPlace a rdfs:Class ; rdfs:label "Luogo Mitologico"@it .
psca:MythologicalFigure a rdfs:Class ; rdfs:label "Figura Mitologica"@it .
psca:CulturalPhenomenon a rdfs:Class ; rdfs:label "Fenomeno Culturale"@it .
psca:Toponym a rdfs:Class ; rdfs:label "Toponimo"@it .
psca:AncientPeople a rdfs:Class ; rdfs:label "Popolo Antico"@it .
psca:GeologicalEvent a rdfs:Class ; rdfs:label "Evento Geologico"@it .

# --- Definizione delle Proprietà ---
psca:identifiedAs a rdf:Property ; rdfs:label "identificato come"@it .
psca:hasEvidence a rdf:Property ; rdfs:label "ha come prova"@it .
psca:submergedBy a rdf:Property ; rdfs:label "sommerso da"@it .
psca:originOf a rdf:Property ; rdfs:label "origine di"@it .
psca:etymology a rdf:Property ; rdfs:label "etimologia"@it .

# --- 1. Il Paradigma Centrale e l'Evento Geologico ---

psca:SardoCorsicanBlock a psca:GeologicalBlock ;
rdfs:label "Blocco Sardo-Corso-Atlantideo"@it ;
schema:description "Blocco geologico semi-sommerso, antica terra di Atlantide, abitata fin da 300.000 anni fa."@it ;
psca:identifiedAs psca:Atlantis ;
psca:submergedBy psca:MeltwaterPulses, psca:SlabRollBack ;
schema:size "Circa 555 km di lunghezza (3000 stadi platonici)"@it .

psca:MeltwaterPulses a psca:GeologicalEvent ;
rdfs:label "Meltwater Pulses"@it ;
schema:temporalCoverage "Prima del 9600 a.C."@it .

psca:SlabRollBack a psca:GeologicalEvent ;
rdfs:label "Slab Roll-Back / Faglia Tettonica"@it ;
schema:description "Faglia tettonica passante sotto il Sulcis, verso Gibilterra e Pompei/Ercolano."@it .

# --- 2. Il Culto del Toro (Fenomeno Culturale) ---

psca:BullCult a psca:CulturalPhenomenon ;
rdfs:label "Culto del Toro in Sardegna"@it ;
schema:description "Venerazione del toro legato alla fertilità maschile (agraria) e della luna (Mater Terra), incarnato dal Dio Toro-Luna."@it ;
psca:hasEvidence psca:IsolaDelToro, psca:IsolaDellaVacca, psca:TempioDiMatzanni, psca:SaLondra, psca:BingiaEccia, psca:MonteMajore, psca:SaUccaESuTintirriolu, psca:AngheluRuju, psca:TombeDeiGiganti .

psca:TempioDiMatzanni a psca:ArchaeologicalSite ; rdfs:label "Tempio di Matzanni"@it .
psca:SaLondra a psca:ArchaeologicalSite ; rdfs:label "Ipogeo di Sa Londra (Alghero)"@it .
psca:BingiaEccia a psca:ArchaeologicalSite ; rdfs:label "Bingia Eccia (Dolianova)"@it .
psca:MonteMajore a psca:ArchaeologicalSite ; rdfs:label "Grotta di Monte Majore"@it .
psca:SaUccaESuTintirriolu a psca:ArchaeologicalSite ; rdfs:label "Sa Ucca 'e su Tintirriolu"@it .
psca:AngheluRuju a psca:ArchaeologicalSite ; rdfs:label "Necropoli di Anghelu Ruju"@it .
psca:TombeDeiGiganti a psca:ArchaeologicalSite ;
rdfs:label "Tombe dei Giganti"@it ;
schema:description "I due bracci semicircolari riprodurrebbero la forma delle corna del toro."@it .

# --- 3. Dati Genetici e Archeologici ---

psca:SuCarroppu a psca:ArchaeologicalSite ;
rdfs:label "Rifugio sottoroccia Su Carroppu (Sirri)"@it ;
schema:description "Sito in cui è stato analizzato il DNA di individui predatori di risorse marine, ipotizzati come Atlantidei, geneticamente distinti dalle popolazioni sarde successive."@it .

psca:GrottaDiLanaittu a psca:ArchaeologicalSite ;
rdfs:label "Grotta di Lanaittu"@it ;
schema:description "Sito con resti risalenti a circa 20.000 anni fa, coerente con l'antichità di Atlantide."@it .

# --- 4. Ricalibrazione Geografica delle Fonti Classiche ---

psca:Libya_Herodotus a psca:MythologicalPlace ;
rdfs:label "Libia (secondo Erodoto)"@it ;
psca:identifiedAs "Provincia di Cagliari (Sardegna meridionale)"@it .

psca:Asia_Herodotus a psca:MythologicalPlace ;
rdfs:label "Asia (secondo Erodoto)"@it ;
psca:identifiedAs "Corsica"@it .

psca:AtlasMountains a psca:MythologicalPlace ;
rdfs:label "Monti di Atlante"@it ;
psca:identifiedAs "Monti del Sulcis"@it .

psca:LakeTritonis a psca:MythologicalPlace ;
rdfs:label "Lago Tritonide"@it ;
schema:description "Somma dei laghi, lagune e stagni di Cagliari, Assemini, Elmas, Capoterra, Quartu, Molentargius, ecc."@it .

psca:PillarsOfHercules a psca:MythologicalPlace ;
rdfs:label "Colonne d'Ercole"@it ;
psca:identifiedAs psca:FaraglioneAnticheColonne .

psca:FaraglioneAnticheColonne a schema:LandmarksOrHistoricalBuildings ;
rdfs:label "Faraglione Antiche Colonne di Carloforte"@it ;
schema:discoverer psca:GiorgioSaba .

# --- 5. Figure Mitologiche (Visione Evemeristica) ---

psca:Poseidon a psca:MythologicalFigure ;
rdfs:label "Poseidone"@it ;
schema:description "Antichissimo sovrano dell'isola sardo-corsa deificato."@it .

psca:Athena a psca:MythologicalFigure ;
rdfs:label "Atena"@it ;
schema:description "Figlia di Poseidone e del Lago Tritonide, associata alle Amazzoni."@it .

# --- 6. Analisi Toponomastica Sarda (Il Sulcis e Atlantide) ---

psca:Acquacadda a psca:Toponym ; rdfs:label "Acquacadda (Acqua calda)"@it .
psca:Acquafredda a psca:Toponym ; rdfs:label "Acquafredda / Castello di Acquafredda"@it .
psca:AcquaCallentiSusu a psca:Toponym ; rdfs:label "S'Acqua Callenti de Susu"@it .
psca:AcquaCallentiBasciu a psca:Toponym ; rdfs:label "S'Acqua Callenti de Basciu"@it .
psca:Furriadroxiu a psca:Toponym ; rdfs:label "Furriadroxiu (Luogo capovolto)"@it .
psca:Spistiddatroxiu a psca:Toponym ; rdfs:label "Spistiddatroxiu (Luogo dove ci si fa male)"@it .
psca:Piscinas a psca:Toponym ; rdfs:label "Piscinas"@it .

psca:Terresoli a psca:Toponym ;
rdfs:label "Terresoli"@it ;
psca:etymology "Terra del Sole (corrispettivo di Heliopolis)"@it .

psca:Sais a psca:Toponym ;
rdfs:label "Is Sais (Superiore e Inferiore)"@it ;
schema:description "Località presso Narcao (Sulcis), legata al nome del sacerdote egizio Sonchis di Sais."@it .

# --- 7. Analisi Toponomastica di Origine Greca in Sardegna ---

psca:Tharros a psca:Toponym ;
rdfs:label "Tharros"@it ;
psca:etymology "Dal greco Thàrras (coraggio). Città fondata dai sopravvissuti alla sommersione."@it .

psca:Olbia a psca:Toponym ;
rdfs:label "Olbia"@it ;
psca:etymology "Dal greco: fortunata, felice."@it .

psca:Nora a psca:Toponym ;
rdfs:label "Nora"@it ;
schema:description "Città con legami greci, puniche e prenuragiche."@it .

psca:Pistis a psca:Toponym ;
rdfs:label "Pistis"@it ;
psca:etymology "Dal greco: fede, fiducia."@it .

psca:Musei a psca:Toponym ;
rdfs:label "Musei"@it ;
psca:etymology "Possibile richiamo alle Muse greche."@it .

psca:Neapolis a psca:Toponym ;
rdfs:label "Neapolis"@it ;
psca:etymology "Dal greco: Città nuova."@it .

psca:Ampurias a psca:Toponym ;
rdfs:label "Diocesi di Tempio Ampurias / Castelsardo"@it ;
schema:description "Possibile legame storico/toponomastico con Empúries (Spagna), fondata dai focesi."@it .

# --- 8. Persone e Studiosi citati ---

psca:GiorgioSaba a schema:Person ;
rdfs:label "Giorgio Saba"@it ;
schema:description "Autore del testo 'Scusi, dov’è l’Ade?' e scopritore ufficiale delle Colonne d'Ercole a Carloforte."@it .

psca:PierluigiMontalbano a schema:Person ;
    rdfs:label "Pierluigi Montalbano"@it  ;

psca:GiovanniLilliu a schema:Person ;
