# Proprietà aggiuntive per la matrice
psca:criterionNumber a rdf:Property ;
    rdfs:subPropertyOf schema:identifier ;
    rdfs:range xsd:integer ;
    schema:domainIncludes psca:MilosCriterion ;
    rdfs:label "numero criterio"@it ;
    rdfs:comment "Numero progressivo del criterio"@it .

psca:weight a rdf:Property ;
    rdfs:subPropertyOf schema:property ;
    rdfs:range xsd:decimal ;
    schema:domainIncludes psca:MilosCriterion ;
    rdfs:label "peso"@it ;
    rdfs:comment "Peso del criterio nel calcolo finale"@it .

psca:category a rdf:Property ;
    rdfs:subPropertyOf schema:category ;
    rdfs:range xsd:string ;
    schema:domainIncludes psca:MilosCriterion ;
    rdfs:label "categoria"@it ;
    rdfs:comment "Categoria del criterio"@it .

psca:theoryEvaluated a rdf:Property ;
    rdfs:subPropertyOf schema:about ;
    rdfs:range rdfs:Resource ;
    schema:domainIncludes prov:Entity ;
    rdfs:label "teoria valutata"@it ;
    rdfs:comment "Teoria valutata"@it .

psca:totalScore a rdf:Property ;
    rdfs:subPropertyOf schema:value ;
    rdfs:range xsd:decimal ;
    schema:domainIncludes prov:Entity ;
    rdfs:label "punteggio totale"@it ;
    rdfs:comment "Punteggio totale della teoria"@it .

psca:ranking a rdf:Property ;
    rdfs:subPropertyOf schema:position ;
    rdfs:range xsd:integer ;
    schema:domainIncludes prov:Entity ;
    rdfs:label "classifica"@it ;
    rdfs:comment "Posizione in classifica"@it .

psca:evaluationStatus a rdf:Property ;
    rdfs:subPropertyOf schema:status ;
    rdfs:range xsd:string ;
    schema:domainIncludes prov:Entity ;
    rdfs:label "stato valutazione"@it ;
    rdfs:comment "Stato della valutazione"@it .

psca:scoresByCriterion a rdf:Property ;
    rdfs:subPropertyOf schema:property ;
    rdfs:range rdfs:Resource ;
    schema:domainIncludes prov:Entity ;
    rdfs:label "punteggi per criterio"@it ;
    rdfs:comment "Punteggi dettagliati per ogni criterio"@it .

psca:criterion a rdf:Property ;
    rdfs:subPropertyOf schema:about ;
    rdfs:range rdfs:Resource ;
    schema:domainIncludes psca:MilosScore ;
    rdfs:label "criterio"@it ;
    rdfs:comment "Criterio di riferimento"@it .

psca:score a rdf:Property ;
    rdfs:subPropertyOf schema:value ;
    rdfs:range xsd:decimal ;
    schema:domainIncludes psca:MilosScore ;
    rdfs:label "punteggio"@it ;
    rdfs:comment "Punteggio assegnato"@it .

psca:justification a rdf:Property ;
    rdfs:subPropertyOf schema:description ;
    rdfs:range xsd:string ;
    schema:domainIncludes psca:MilosScore ;
    rdfs:label "giustificazione"@it ;
    rdfs:comment "Giustificazione del punteggio"@it .

psca:totalCriteria a rdf:Property ;
    rdfs:subPropertyOf schema:quantity ;
    rdfs:range xsd:integer ;
    schema:domainIncludes prov:Collection ;
    rdfs:label "totale criteri"@it ;
