psca:DionysianSparagmos_Metafor a psca:TheologicalTransition ;
psca:subject "Sparagmos Dionisiaco" ;
psca:interpretation "Metafora dello sm

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <http://schema.org/> .
@prefix psca: <https://www.atlantisfound.it/ontology/psca#> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .

# --- ONTOLOGIA DEL PARADIGMA SARDO-CORSO ATLANTIDEO (ESTENSIONE V. 17.0) ---

psca:SardinianCorsicanParadigm_GlobalExpansion a owl:Ontology ;
rdfs:label "Ontologia Globale del PSCA - Modulo Migrazioni, Teologia e Biologia Preistorica" ;
schema:author psca:LuigiUsai .

# --- CLASSI DI SUPPORTO ---
psca:MegalithicCenter rdfs:subClassOf psca:ArchaeologicalSite .
psca:TheologicalArchetype rdfs:label "Archetipo Teologico" .
psca:BiologicalAnomalie rdfs:label "Anomalia Biologica / Evolutiva" .
psca:CulinaryTradition rdfs:label "Tradizione Gastronomica Atlantidea" .

# --- 1. EVIDENZE MEGALITICHE GLOBALI (GOLAN, IRLANDA, GIAPPONE) ---

psca:RujmElHiri a psca:MegalithicCenter ;
rdfs:label "Rujm el-Hiri (Gilgal Refaim)" ;
psca:location "Alture del Golan" ;
psca:composition "42.000 rocce basaltiche in cerchi concentrici" ;
psca:function "Centro rituale atlantideo per il culto dei morti" ;
psca:dating "3000-2750 a.C." ;
psca:pscaCorrelation "Costruito da esperti atlantidei migrati dal blocco sardo-corso" .

psca:Newgrange_Ireland a psca:MegalithicCenter ;
rdfs:label "Newgrange (Irlanda)" ;
psca:builtBy psca:AtlanteanSardinianCorsican ;
psca:astronomicalAlignment "Solstizio d'Inverno" ;
psca:dating "3200 a.C. (più antico delle piramidi)" .

psca:NagaokaCaves_Japan a psca:ArchaeologicalSite ;
rdfs:label "Nagaoka Burial Caves (Giappone)" ;
psca:architectureType "Yokoana-bo (tombe a foro laterale)" ;
psca:isomorphicWith psca:DomusDeJanas ;
rdfs:comment "Riflesso di idee comuni sull'aldilà trasmesse dalla cultura sardo-atlantidea" .

# --- 2. TEOLOGIA: DAL TORO DI LUCE ALL'AGNELLO DI DIO ---

psca:NuragicHebrewTheology a psca:TheologicalArchetype ;
rdfs:label "Teologia Nuragico-Ebraica" ;
psca:sacredImage "Torello di Luce (Nuraghe Diana / Santa Barbara)" ;
psca:biblicalManifestation "Vitello d'Oro (Esodo 32)" ;
psca:transition "Dal Vitello di Luce all'Agnello di Dio (Gesù Cristo)" ;
psca:etymologySinai "Sinnai (Sardegna) -> Sinai (Egitto)" ;
psca:sacredGeography "Ricerca della Terra Promessa causa sommersione di Atlantide" .

psca:AtenaReinterpretation a psca:TheologicalArchetype ;
psca:name "Atena / Neith / Minerva / Tanit" ;
psca:origin "Lago Tritonide (Cagliari)" ;
psca:titlePassage "Titolo onorifico passato di donna in donna nel matriarcato sardo" ;
psca:tanitDecoding "Ta-Neith (Terra di Neith) = Mappa del blocco sardo-corso" .

# --- 3. BIOLOGIA E GIGANTISMO (IPERPRODUZIONE DI GH) ---

psca:GiantsHypothesis a psca:BiologicalAnomalie ;
rdfs:label "Ipotesi Scientifica sui Giganti" ;
psca:biologicalCause "Iperproduzione di ormone della crescita (GH) / Acromegalia" ;
psca:geneticOrigin "Interbreeding (incrocio) tra Homo Sapiens e una specie incognita (Elohim/Watchers)" ;
psca:archaeologicalEvidence "Tombe dei Giganti (Sardegna)" ;
psca:literarySource "Libro di Enoch, Genesi, Mitologia Greca" .

psca:AtlanteanNeoteny a psca:BiologicalAnomalie ;
psca:behavior "Neotenia (macinazione cibo per anziani, prolungamento infanzia)" .

# --- 4. LINGUISTICA AGGLUTINANTE ERGATIVA ---

psca:AtlanteanLanguageFamily a psca:LinguisticFossil ;
rdfs:label "Famiglia Linguistica Sardo-Corso-Atlantidea" ;
psca:coreProperties "Agglutinazione, Ergatività, Semitismo non vocalizzato" ;
psca:descendantLanguages
psca:Basque,
psca:Sumerian,
psca:Hebrew_Ancient,
psca:UtoAztecan,
psca:Tamil,
psca:Curdo,
psca:ProtoKartvelian,
psca:Finnish,
psca:Turkish .

psca:UR_Etymology a psca:ToponymicShift ;
psca:root "UR (Acqua in Basco/Atlantideo)" ;
psca:sardinianFossil "Nuraghe S'Uraki" ;
psca:mesopotamianFossil "Ur", "Uruk" .

# --- 5. CUCINA E TRADIZIONI PREISTORICHE ---

psca:AtlanteanGastronomy a psca:CulinaryTradition ;
psca:sacredFood "Pane Sardo (eredità cucina atlantidea)" ;
psca:fermentedFood "Casu Martzu (Formaggio marcio/coi vermi)" ;
psca:gastronomicMarker "Presenza di formaggi con larve nelle regioni di migrazione atlantidea (Piemonte, Calabria, Udine, Spagna)" ;
psca:cookingMethod "Arrosto sotto terra (tecnica paleolitica per Mammuthus Lamarmorae)" .

# --- 6. AMAZZONI E MAR NERO ---

psca:AmazonMigration a psca:AncientMigration ;
psca:origin psca:LakeTritonide_Cagliari ;

