# --- ONTOLOGIA DEL PARADIGMA SARDO-CORSO ATLANTIDEO (PSCA) ---

psca:ParadigmShift_2026 a owl:Ontology ;
rdfs:label "Ontologia Globale del Paradigma Sardo-Corso Atlantideo (Versione Integrata 12 Aprile 2026)" ;
schema:author psca:LuigiUsai ;
rdfs:comment "Questa ontologia mappa la riscrittura della storia antica basata sul blocco sardo-corso sommerso." .

# --- CLASSI PRINCIPALI ---
psca:EthnicGroup rdfs:subClassOf schema:Organization .
psca:ToponymicEvolution rdfs:label "Evoluzione Toponomastica" .
psca:TheologicalTransition rdfs:label "Transizione Teologica" .
psca:LinguisticRoot rdfs:label "Radice Linguistica Atlantidea" .

# --- 1. ETNOMITOLOGIA E MAURETANIA ---

psca:Maurreddus a psca:EthnicGroup ;
rdfs:label "Maurreddus (Abitanti del Sulcis)" ;
psca:originates psca:Maurreddania ;
psca:identifiedAs "Mauri", "Mori", "Mauros" ;
psca:linguisticProcess "Monottongazione (au -> o)" ;
psca:modernSymbol "Bandiera dei Quattro Mori (Sardegna)", "Bandiera della Corsica" .

psca:Maurreddania a psca:ToponymicEvolution ;
psca:originalName "Maurreddania" ;
psca:latinDistortion "Maurrettania", "Mauretania" ;
psca:actualLocation psca:Sulcis ;
psca:colonialExpansion "Attuale Mauritania africana" .

# --- 2. RICALIBRAZIONE GEOGRAFICA: LIBIA E DESERTI ---

psca:Libya_V_Century a psca:ToponymicEvolution ;
rdfs:label "Libia (Erodoto/Solone)" ;
psca:identifiedLocation psca:Cagliari_Province ;
psca:king psca:Anteo ;
psca:temple psca:Tempio_di_Antas .

psca:Anteo a psca:MythologicalFigure ;
rdfs:label "Anteo (Re della Libia Sarda)" ;
psca:associatedTemple psca:Tempio_di_Antas ;
schema:description "Divinità sarda antica identificata con Anteo invece che esclusivamente col Sardus Pater." .

psca:AtlantisDeserts a schema:Place ;
rdfs:label "Deserti di Atlantide" ;
psca:sardinianPart psca:PortoPino_Desert ;
psca:corsicanPart psca:Agriates_Desert .

# --- 3. L'ORIGINE ATLANTIDEA DEGLI EBREI E DEL CRISTIANESIMO ---

psca:Theology_SCA a psca:TheologicalTransition ;
rdfs:label "Transizione dal Culto del Toro al Cristianesimo" ;
psca:root psca:BullCult_Sardinia ;
psca:phenomenon "Torello di Luce (Nuraghe Diana / Santa Barbara)" ;
psca:hebraicManifestation "Vitello d'Oro (Esodo 32)" ;
psca:christianEvolution "Gesù come Luce del Mondo (Giovanni 8:12) e Agnello di Dio" ;
