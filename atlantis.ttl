psca:SardiniaMapping a prov:Entity ;
    rdfs:label "Mappatura Sardegna-Wikidata"@it ;
    rdfs:label "Sardinia-Wikidata Mapping"@en ;
    psca:pscaEntity usai:Sardegna ;
    psca:wikidataEntity wd:Q1462 ;
    psca:mappingType "Direct equivalence" ;
    psca:confidence 0.98 ;
    psca:lastVerified "2026-04-15"^^xsd:date ;
    psca:mappingQuery """
        SELECT ?item ?itemLabel ?itemDescription ?coordinates ?population ?area
        WHERE {
            SERVICE <https://query.wikidata.org/sparql> {
                wd:Q1462 rdfs:label ?itemLabel .
                wd:Q1462 schema:description ?itemDescription .
                wd:Q1462 wdt:P625 ?coordinates .
                wd:Q1462 wdt:P1082 ?population .
                wd:Q1462 wdt:P2046 ?area .
                FILTER(LANG(?itemLabel) = "it")
                FILTER(LANG(?itemDescription) = "it")
            }
        }
    """ ;
    prov:wasGeneratedBy psca:WikidataFederationSystem .

