#################################################################
# MIGLIORAMENTO 14: MATERIALIZED VIEWS PER PERFORMANCE
#################################################################

# Sistema di materialized views per ottimizzazione query
psca:MaterializedViewSystem a prov:Activity ;
    rdfs:label "Sistema Materialized Views PSCA"@it ;
    rdfs:label "PSCA Materialized View System"@en ;
    prov:startedAtTime "2026-04-19T00:00:00"^^xsd:dateTime ;
    prov:wasAssociatedWith <https://orcid.org/0009-0003-3001-717X> ;
    psca:databaseSystem "Apache Jena Fuseki + Virtuoso" ;
    psca:viewRefreshStrategy "Incremental + Scheduled" ;
    psca:refreshInterval "Every 6 hours" ;
    psca:storageEngine "Columnar storage + Index compression" ;
    psca:queryOptimization "Query plan caching + Result caching" ;
    prov:generated psca:MaterializedViews .

# Materialized view per evidenze PSCA
psca:PSCAEvidenceView a prov:Entity ;
    rdfs:label "View Evidenze PSCA"@it ;
    rdfs:label "PSCA Evidence View"@en ;
    psca:viewType "Aggregated evidence summary" ;
    psca:baseQuery """
        SELECT ?evidence ?type ?strength ?date ?location ?reliability
        WHERE {
            ?evidence a psca:Evidence .
            ?evidence a ?type .
            ?evidence psca:evidenceStrength ?strength .
            ?evidence psca:evidenceDate ?date .
            ?evidence psca:hasLocation ?location .
            ?evidence psca:reliabilityScore ?reliability .
            FILTER(?type IN (psca:StrongEvidence, psca:ModerateEvidence, psca:WeakEvidence))
        }
    """ ;
    psca:refreshFrequency "Every 2 hours" ;
    psca:indexColumns ["type", "strength", "date", "location"] ;
    psca:estimatedRows 5000 ;
    psca:storageSize "15 MB" ;
    psca:queryPerformanceImprovement "85%" ;
    psca:lastRefresh "2026-04-19T12:00:00"^^xsd:dateTime ;
    prov:wasGeneratedBy psca:MaterializedViewSystem .

# Materialized view per correlazioni evidenze
psca:EvidenceCorrelationView a prov:Entity ;
    rdfs:label "View Correlazioni Evidenze"@it ;
    rdfs:label "Evidence Correlation View"@en ;
    psca:viewType "Pre-computed correlation matrix" ;
    psca:baseQuery """
        SELECT ?evidence1 ?evidence2 ?correlationStrength ?correlationType
        WHERE {
            ?correlation a psca:EvidenceCorrelation .
            ?correlation psca:correlatesEvidence1 ?evidence1 .
            ?correlation psca:correlatesEvidence2 ?evidence2 .
            ?correlation psca:correlationStrength ?correlationStrength .
            ?correlation psca:correlationType ?correlationType .
        }
    """ ;
    psca:refreshFrequency "Every 4 hours" ;
    psca:indexColumns ["evidence1", "evidence2", "correlationStrength"] ;
    psca:estimatedRows 25000 ;
    psca:storageSize "45 MB" ;
    psca:queryPerformanceImprovement "92%" ;
    psca:lastRefresh "2026-04-19T10:00:00"^^xsd:dateTime ;
    prov:wasGeneratedBy psca:MaterializedViewSystem .

# Materialized view per analisi temporale
psca:TemporalAnalysisView a prov:Entity ;
    rdfs:label "View Analisi Temporale"@it ;
    rdfs:label "Temporal Analysis View"@en ;
    psca:viewType "Time-series aggregation" ;
    psca:baseQuery """
        SELECT ?event ?startDate ?endDate ?duration ?type ?location
        WHERE {
            ?event a time:Interval .
            ?event time:hasBeginning ?start .
            ?event time:hasEnd ?end .
            ?start time:inXSDDateTime ?startDate .
            ?end time:inXSDDateTime ?endDate .
            ?event a ?type .
            ?event psca:hasLocation ?location .
            BIND(?endDate - ?startDate AS ?duration)
        }
    """ ;
    psca:refreshFrequency "Every 8 hours" ;
    psca:indexColumns ["startDate", "endDate", "type", "location"] ;
    psca:estimatedRows 3000 ;
    psca:storageSize "12 MB" ;
    psca:queryPerformanceImprovement "78%" ;
    psca:lastRefresh "2026-04-19T08:00:00"^^xsd:dateTime ;
    prov:wasGeneratedBy psca:MaterializedViewSystem .

# Materialized view per risultati Bayesian
psca:BayesianResultsView a prov:Entity ;
    rdfs:label "View Risultati Bayesian"@it ;
    rdfs:label "Bayesian Results View"@en ;
    psca:viewType "Statistical summary view" ;
    psca:baseQuery """
        SELECT ?theory ?prior ?likelihood ?posterior ?confidenceInterval
        WHERE {
            ?evaluation a psca:BayesianEvaluation .
            ?evaluation psca:evaluatesTheory ?theory .
            ?evaluation psca:priorProbability ?prior .
            ?evaluation psca:likelihood ?likelihood .
            ?evaluation psca:posteriorProbability ?posterior .
            ?evaluation psca:confidenceInterval ?confidenceInterval .
        }
    """ ;
    psca:refreshFrequency "Every 12 hours" ;
    psca:indexColumns ["theory", "posterior", "likelihood"] ;
    psca:estimatedRows 50 ;
    psca:storageSize "2 MB" ;
    psca:queryPerformanceImprovement "95%" ;
    psca:lastRefresh "2026-04-19T06:00:00"^^xsd:dateTime ;
    prov:wasGeneratedBy psca:MaterializedViewSystem .

# Materialized view per metriche performance
psca:PerformanceMetricsView a prov:Entity ;
    rdfs:label "View Metriche Performance"@it ;
    rdfs:label "Performance Metrics View"@en ;
    psca:viewType "Performance aggregation view" ;
    psca:baseQuery """
        SELECT ?entity ?metricType ?metricValue ?timestamp
        WHERE {
            ?entity psca:hasPerformanceMetric ?metric .
            ?metric a ?metricType .
            ?metric psca:metricValue ?metricValue .
            ?metric prov:generatedAtTime ?timestamp .
        }
    """ ;
    psca:refreshFrequency "Every 1 hour" ;
    psca:indexColumns ["entity", "metricType", "timestamp"] ;
    psca:estimatedRows 10000 ;
    psca:storageSize "25 MB" ;
    psca:queryPerformanceImprovement "88%" ;
    psca:lastRefresh "2026-04-19T13:00:00"^^xsd:dateTime ;
