# LAYER 3: IL PARADIGMA PSCA (ASSIOMI E MECCANICA)

# Paradigma PSCA completo
psca:PSCA_Complete a usai:StructuredParadigm ;
    rdfs:label "Paradigma Sardo-Corso-Atlantideo (PSCA)"@it ;
    rdfs:label "Sardinian-Corsican Atlantis Paradigm (PSCA)"@en ;
    schema:name "Sardinian-Corsican Atlantis Paradigm"@en ;
    schema:description "Modello archeologico predittivo ed eustatico che identifica l'Atlantide platonica nel blocco geologico Sardo-Corso"@it ;
    schema:description "Predictive and eustatic archaeological model identifying Platonic Atlantis in the Sardinian-Corsican geological block"@en ;
    usai:coreAxioms psca:Axiom_IdentitaGeologica, psca:Axiom_SincroniaEustatica, psca:Axiom_DerivaSemantica ;
    psca:depthMarkers psca:DepthMarkers_PSCA ;
    prov:wasAttributedTo <https://orcid.org/0009-0003-3001-717X> ;
    prov:generatedAtTime "2024-09-18T00:00:00"^^xsd:dateTime .

# Assiomi fondamentali del Paradigma PSCA
psca:Axiom_IdentitaGeologica a usai:Axiom ;
    rdfs:label "Identità Geologica"@it ;
    rdfs:label "Geological Identity"@en ;
    schema:name "Geological Identity Axiom"@en ;
    schema:description "Atlantide = Blocco Sardo-Corso (Piana rettangolare sommersa)."@it ;
    schema:description "Atlantis = Sardinian-Corsican Block (submerged rectangular plain)."@en ;
    prov:wasAttributedTo <https://orcid.org/0009-0003-3001-717X> ;
    prov:generatedAtTime "2024-09-18T00:00:00"^^xsd:dateTime .

psca:Axiom_SincroniaEustatica a usai:Axiom ;
    rdfs:label "Sincronia Eustatica"@it ;
    rdfs:label "Eustatic Chronology"@en ;
    schema:name "Eustatic Chronology Axiom"@en ;
    schema:description "Sommersione via Meltwater Pulse 1B (9600 a.C. / 11.600 BP)."@it ;
    schema:description "Submersione via Meltwater Pulse 1B (9600 BC / 11,600 BP)."@en ;
    prov:wasAttributedTo <https://orcid.org/0009-0003-3001-717X> ;
    prov:generatedAtTime "2024-09-18T00:00:00"^^xsd:dateTime .

psca:Axiom_DerivaSemantica a usai:Axiom ;
    rdfs:label "Deriva Semantica/Odologica"@it ;
    rdfs:label "Semantic/Toponymic Derivation"@en ;
    schema:name "Semantic/Toponymic Derivation Axiom"@en ;
    schema:description "Riassegnazione geografica: Libia = Sardegna Sud, Asia = Corsica."@it ;
    schema:description "Geographical reassignment: Libya = Southern Sardinia, Asia = Corsica."@en ;
    prov:wasAttributedTo <https://orcid.org/0009-0003-3001-717X> ;
    prov:generatedAtTime "2024-09-18T00:00:00"^^xsd:dateTime .

