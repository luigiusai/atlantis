# Elenco selezionato di corrispondenze onomastiche (esempi)
#################################################################
psca:Toponym_Nora a psca:Toponym ;
    schema:name "Nora"@it ;
    rdfs:label "Nora (SU)"@it  ;

psca:OnomasticCorr_Sais a schema:Thing ;
