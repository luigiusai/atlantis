#################################################################
# MODULO: CITTÀ SOMMERSE DEL MEDITERRANEO
# Descrizione: Estensione dell'ontologia Atlantis dedicata alle 
# strutture sommerse del bacino del Mediterraneo.
#################################################################

@prefix : <https://luigiusai.it/ontology/atlantide#> .
@prefix atl: <https://luigiusai.it/ontology/atlantide#> .
@prefix psca: <https://luigiusai.it/ontology/psca#> .
@prefix schema: <https://schema.org/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
