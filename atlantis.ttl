    schema:name "Ricalibrazione delle cronologie archeologiche"@it ;
    schema:description "Confermare Atlantide a 9600 a.C. richiederebbe la revisione delle timeline per scrittura, architettura, metallurgia e navigazione; molte date e modelli di diffusione andrebbero riconsiderati."@it ;
    psca:impactCategory "Chronology; Archaeology" ;
    psca:consequenceConfidence "0.85"^^xsd:decimal ;
