# Framework avanzato per rilevamento bias
psca:AdvancedBiasDetectionFramework a prov:Activity ;
    rdfs:label "Framework Avanzato Rilevamento Bias"@it ;
    rdfs:label "Advanced Bias Detection Framework"@en ;
    prov:startedAtTime "2026-04-19T00:00:00"^^xsd:dateTime ;
    prov:wasAssociatedWith <https://orcid.org/0009-0003-3001-717X> ;
    psca:detectionMethodology "Multi-layered bias analysis + Statistical testing + Expert validation" ;
    psca:biasCategories ["Confirmation bias", "Selection bias", "Publication bias", "Cultural bias", "Temporal bias", "Geographic bias"] ;
    psca:detectionTools ["R statistical packages", "Python bias detection libraries", "Expert review protocols"] ;
    psca:confidenceThreshold 0.05 ;
    psca:correctionMethods ["Statistical adjustment", "Blind review", "Cross-cultural validation"] ;
    prov:generated psca:BiasAnalysisResults .

