#################################################################
# MIGLIORAMENTO 12: PROMPT ENGINEERING AVANZATO PER LLM
#################################################################

# Framework di prompt engineering per analisi PSCA
psca:LLMPromptFramework a prov:Activity ;
    rdfs:label "Framework Prompt Engineering LLM PSCA"@it ;
    rdfs:label "PSCA LLM Prompt Engineering Framework"@en ;
    prov:startedAtTime "2026-04-19T00:00:00"^^xsd:dateTime ;
    prov:wasAssociatedWith <https://orcid.org/0009-0003-3001-717X> ;
    psca:llmModels ["GPT-4", "Claude-3", "LLaMA-3", "Gemini Pro"] ;
    psca:promptStrategy "Chain-of-thought + Few-shot learning + Self-consistency" ;
    psca:temperature 0.7 ;
    psca:maxTokens 4000 ;
    psca:topP 0.9 ;
    psca:frequencyPenalty 0.1 ;
    psca:presencePenalty 0.1 ;
    prov:generated psca:LLMPrompts .

# Template di prompt per analisi linguistica
psca:LinguisticAnalysisPrompt a prov:Entity, schema:CreativeWork ;
    rdfs:label "Prompt Analisi Linguistica"@it ;
    rdfs:label "Linguistic Analysis Prompt"@en ;
    schema:text """You are an expert linguist specializing in ancient Mediterranean languages and comparative linguistics. 

TASK: Analyze the provided text for evidence of Proto-Sardinian linguistic elements that could support the PSCA (Paradigma Sardo-Corso-Atlantideo).

CONTEXT: The PSCA proposes that a sophisticated civilization existed on the Sardinian-Corsican continental shelf around 9600 BC, which was submerged during the Meltwater Pulse 1B event.

ANALYSIS REQUIREMENTS:
1. Identify lexical items that could be of Proto-Sardinian origin
2. Look for phonological patterns consistent with Sardinian language family
3. Check for semantic fields related to maritime culture, cataclysms, or advanced civilization
4. Compare with known Sardinian, Basque, and Berber cognates
5. Assess temporal plausibility of linguistic diffusion

INPUT TEXT: {input_text}

OUTPUT FORMAT:
- Proto-Sardinian candidates: [list]
- Phonetic analysis: [analysis]
- Semantic field: [classification]
- Comparative cognates: [list]
- Confidence score: [0-1]
- PSCA relevance: [High/Medium/Low]

Chain-of-thought reasoning: [detailed analysis]""" ;
    psca:promptType "Linguistic analysis" ;
    psca:targetLanguage "Proto-Sardinian reconstruction" ;
    psca:expertiseLevel "Advanced" ;
    psca:expectedOutput "Structured linguistic analysis" ;
    psca:validationCriteria "Cross-linguistic consistency" ;
    prov:wasGeneratedBy psca:LLMPromptFramework .

# Template di prompt per interpretazione testi antichi
psca:AncientTextInterpretationPrompt a prov:Entity, schema:CreativeWork ;
    rdfs:label "Prompt Interpretazione Testi Antichi"@it ;
    rdfs:label "Ancient Text Interpretation Prompt"@en ;
    schema:text """You are an expert in ancient Mediterranean history, archaeology, and textual criticism with deep knowledge of Plato's dialogues and other classical sources mentioning Atlantis.

TASK: Interpret the provided ancient text for evidence that could support or contradict the PSCA theory.

CONTEXT: The PSCA identifies the Sardinian-Corsican continental shelf as the location of Plato's Atlantis, submerged around 9600 BC during Meltwater Pulse 1B.

INTERPRETATION FRAMEWORK:
1. Historical context analysis
2. Geographical identification clues
3. Chronological alignment with 9600 BC
4. Cataclysm description matching MWP-1B
5. Cultural/technological descriptions
6. Comparison with PSCA predictions

INPUT TEXT: {input_text}
SOURCE: {source_author}, {date_approx}

ANALYSIS DIMENSIONS:
- Geographical clues: [extract and analyze]
- Temporal references: [extract and analyze]
- Cataclysm descriptions: [compare with MWP-1B]
- Technological/cultural level: [assess]
- PSCA alignment score: [0-1]
- Alternative interpretations: [list]

Chain-of-thought reasoning: [detailed step-by-step analysis]

Final conclusion: [Supports/Contradicts/Neutral for PSCA]""" ;
    psca:promptType "Ancient text interpretation" ;
    psca:targetSources ["Plato's dialogues", "Classical historians", "Mythological texts"] ;
    psca:expertiseLevel "Expert" ;
    psca:expectedOutput "Multi-dimensional textual analysis" ;
    psca:validationCriteria "Historical accuracy and logical coherence" ;
    prov:wasGeneratedBy psca:LLMPromptFramework .

# Template di prompt per analisi correlazioni
psca:CorrelationAnalysisPrompt a prov:Entity, schema:CreativeWork ;
    rdfs:label "Prompt Analisi Correlazioni"@it ;
    rdfs:label "Correlation Analysis Prompt"@en ;
    schema:text """You are an expert interdisciplinary scientist specializing in evidence synthesis and correlation analysis across archaeology, geology, genetics, and oceanography.

TASK: Analyze the provided evidence items for potential correlations that could strengthen the PSCA theory.

CONTEXT: The PSCA proposes that multiple independent lines of evidence converge on the Sardinian-Corsican shelf as Atlantis.

EVIDENCE ITEMS:
{evidence_items}

CORRELATION ANALYSIS FRAMEWORK:
1. Temporal proximity analysis
2. Geographical coincidence assessment
3. Disciplinary cross-validation
4. Causal mechanism identification
5. Strength quantification

ANALYSIS DIMENSIONS:
- Temporal correlation: [0-1 score + reasoning]
- Spatial correlation: [0-1 score + reasoning]
- Disciplinary synergy: [0-1 score + reasoning]
- Causal plausibility: [0-1 score + reasoning]
- Overall correlation strength: [0-1 score]

Identified correlations:
1. [Correlation 1]: [detailed analysis]
2. [Correlation 2]: [detailed analysis]
...

Network effects: [analysis of how correlations reinforce each other]

Confidence assessment: [overall confidence in correlation network]

Recommendations: [suggested further investigations]""" ;
    psca:promptType "Evidence correlation analysis" ;
    psca:targetDisciplines ["Archaeology", "Geology", "Genetics", "Oceanography"] ;
    psca:expertiseLevel "Expert" ;
    psca:expectedOutput "Network correlation analysis" ;
    psca:validationCriteria "Interdisciplinary consistency" ;
    prov:wasGeneratedBy psca:LLMPromptFramework .

# Template di prompt per validazione predittiva
psca:PredictiveValidationPrompt a prov:Entity, schema:CreativeWork ;
    rdfs:label "Prompt Validazione Predittiva"@it ;
    rdfs:label "Predictive Validation Prompt"@en ;
    schema:text """You are an expert in scientific methodology and hypothesis testing with deep knowledge of the PSCA theory and its predictions.

TASK: Evaluate the provided prediction test results to assess how well they support the PSCA theory.

CONTEXT: The PSCA makes specific, testable predictions about submerged structures, genetic bottlenecks, and linguistic continuity.

PREDICTION UNDER EVALUATION:
{prediction_details}

ACTUAL RESULTS:
{actual_results}

VALIDATION CRITERIA:
1. Prediction specificity: [How specific was the prediction?]
2. Methodological rigor: [How robust was the test?]
3. Result alignment: [How well do results match prediction?]
4. Statistical significance: [Are results statistically significant?]
5. Alternative explanations: [Are there plausible alternatives?]

SCORING FRAMEWORK:
- Prediction accuracy: [0-1 score]
- Methodological quality: [0-1 score]
- Statistical support: [0-1 score]
- Overall validation strength: [0-1 score]

Chain-of-thought evaluation: [detailed assessment]

Conclusion: [Strongly supports/Moderately supports/Weakly supports/Contradicts PSCA]

Recommendations: [for improving prediction testing]""" ;
    psca:promptType "Predictive validation assessment" ;
    psca:targetPredictions ["Submerged structures", "Genetic bottlenecks", "Linguistic continuity"] ;
    psca:expertiseLevel "Expert" ;
    psca:expectedOutput "Structured validation assessment" ;
    psca:validationCriteria "Scientific rigor and statistical validity" ;
    prov:wasGeneratedBy psca:LLMPromptFramework .

# Collezione di tutti i prompt
psca:LLMPrompts a prov:Collection ;
    rdfs:label "Collezione Prompt LLM PSCA"@it ;
    rdfs:label "PSCA LLM Prompt Collection"@en ;
    prov:hadMember psca:LinguisticAnalysisPrompt, psca:AncientTextInterpretationPrompt, psca:CorrelationAnalysisPrompt, psca:PredictiveValidationPrompt ;
    psca:totalPrompts 4 ;
    psca:coverageAreas ["Linguistic analysis", "Text interpretation", "Evidence correlation", "Predictive validation"] ;
    psca:qualityMetrics ["Coherence", "Specificity", "Actionability", "Reproducibility"] ;
    psca:version "1.0" ;
    psca:lastUpdated "2026-04-19"^^xsd:date ;
    prov:wasGeneratedBy psca:LLMPromptFramework .

