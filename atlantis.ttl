#################################################################
# 1. ONTOLOGY HEADER (CENTRALIZED)
#################################################################

<https://www.atlantisfound.it/ontology/psca> a owl:Ontology ;
    rdfs:label "Ontologia Universale del Paradigma Sardo-Corso-Atlantideo (PSCA)"@it ,
               "Universal Sardinian-Corsican-Atlantean Paradigm Ontology"@en ;
    dcterms:creator <https://orcid.org/0009-0003-3001-717X> ;
    owl:versionInfo "v26.0_Universal_Master_Consilience" ;
    schema:version "5.0" ;
    schema:identifier "10.5281/zenodo.19551255" ;
    dcterms:created "2026-04-13"^^xsd:date ;
    rdfs:comment "Sintesi perfetta di geologia, linguistica, archeogenetica e mitografia ricalibrata. Include modelli di consilienza IA e geologia predittiva."@it ;
    schema:license <https://creativecommons.org/licenses/by/4.0/> .

#################################################################
# 2. TBOX: CORE CLASSES & PROPERTIES
#################################################################

psca:Paradigm a owl:Class .
psca:Hypothesis a owl:Class ; rdfs:subClassOf schema:CreativeWork .
psca:EvidenceVector a owl:Class .
psca:Methodology a owl:Class .
psca:GeologicalBlock a owl:Class ; rdfs:subClassOf geo:Feature .
psca:MythicalEntity a owl:Class .
psca:Toponym a owl:Class ; rdfs:subClassOf schema:Place .
psca:AncientPopulation a owl:Class ; rdfs:subClassOf schema:Organization .
psca:ScientificDiscovery a owl:Class .

psca:interpretsAs a owl:ObjectProperty .
psca:supportedBy a owl:ObjectProperty .
psca:pioneeredMethod a owl:ObjectProperty ; rdfs:domain schema:Person ; rdfs:range psca:Methodology .
psca:confidenceLevel a owl:DatatypeProperty ; rdfs:range xsd:decimal .
psca:heuristicScore a owl:DatatypeProperty ; rdfs:range xsd:integer .

#################################################################
# 3. THE AGENT: LUIGI USAI (ORCID: 0009-0003-3001-717X)
#################################################################

<https://orcid.org/0009-0003-3001-717X> a schema:Person, prov:Agent, foaf:Person ;
    schema:name "Luigi Usai" ;
