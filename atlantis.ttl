    rdfs:label "Koinè Culturale Atlantidea"@it ;
    rdfs:label "Atlantean Cultural Koinè"@en ;
    schema:name "Atlantean Cultural Koinè"@en ;
    schema:description "La koinè culturale condivisa tra Sardegna, Lidia e Etruria come prova del dominio atlantideo sulla Tirrenia citato da Platone"@it ;
    schema:description "The shared cultural koinè between Sardinia, Lydia and Etruria as proof of Atlantean dominion over Tyrrhenia cited by Plato"@en ;
    prov:wasAttributedTo <https://orcid.org/0009-0003-3001-717X> ;
    prov:generatedAtTime "2024-09-18T00:00:00"^^xsd:dateTime .

