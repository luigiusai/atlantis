schema:description "Archeologo, descrisse il culto del toro in Sardegna come partner della Dea Madre."@it .

psca:LuigiUsai a schema:Person ;
rdfs:label "Luigi Usai"@it ;
schema:description "Autore della teoria del blocco sardo-corso come Atlantide e scopritore di nuove formazioni sommerse."@it .

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <http://schema.org/> .
@prefix psca: <https://www.atlantisfound.it/ontology/psca#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .

# --- Definizione delle Classi ---
psca:Toponym a rdfs:Class ; rdfs:label "Toponimo"@it .
psca:ArchaeologicalSite a rdfs:Class ; rdfs:label "Sito Archeologico"@it .
psca:SubmergedSite a rdfs:Class ; rdfs:subClassOf psca:ArchaeologicalSite ; rdfs:label "Sito Sommerso"@it .
psca:CaveSystem a rdfs:Class ; rdfs:label "Sistema di Grotte"@it .
psca:ScientificTheory a rdfs:Class ; rdfs:label "Teoria Scientifica"@it .
psca:MythologicalFigure a rdfs:Class ; rdfs:label "Figura Mitologica"@it .

# --- Definizione delle Proprietà ---
psca:etymology a rdf:Property ; rdfs:label "etimologia"@it .
psca:hasCulturalInfluence a rdf:Property ; rdfs:label "ha influenza culturale"@it .
psca:locatedIn a rdf:Property ; rdfs:label "situato in"@it .
psca:associatedWith a rdf:Property ; rdfs:label "associato a"@it .

# --- 1. Toponomastica Sarda di possibile origine Greca ---

psca:Kalaris a psca:Toponym ;
rdfs:label "Kalaris (Cagliari)"@it ;
psca:etymology "Possibile derivazione dal greco 'kályx' (coppa o calice), in riferimento alla forma del porto naturale."@it .

psca:Tiana a psca:Toponym ;
rdfs:label "Tiana"@it ;
psca:etymology "Possibile derivazione dal greco 'tíanos' (allungato o esteso)."@it .

psca:Pirri a psca:Toponym ;
rdfs:label "Pirri"@it ;
psca:etymology "Possibile derivazione dal greco 'pyrrós' (rosso o color fuoco)."@it .

psca:MonteAstili a psca:Toponym ;
rdfs:label "Monte Astili"@it ;
psca:etymology "Possibile derivazione dal greco 'ástylos' (senza colonne o disadorno)."@it .

psca:Tiscali a psca:Toponym ;
rdfs:label "Tiscali"@it ;
psca:etymology "Possibile derivazione dal greco 'skális' (scala o scalinata)."@it .

psca:Zinnias a psca:Toponym ;
rdfs:label "Zinnias (Zinnigas)"@it ;
psca:etymology "Possibile derivazione dal greco 'skínos' (giunco o canna)."@it .

# --- 2. Siti Archeologici Sommersi e Costieri (Supporto alla Teoria della Riva Würmiana) ---

psca:WurmianShoreTheory a psca:ScientificTheory ;
rdfs:label "Teoria della Riva Würmiana"@it ;
schema:author psca:LuigiUsai ;
schema:description "Teoria che afferma che buona parte delle paleocoste sommerse dopo la glaciazione Würm erano abitate."@it .

psca:Nora a psca:SubmergedSite ;
rdfs:label "Città sommersa di Nora"@it ;
psca:locatedIn "Sulcis (Sardegna meridionale, vicino a Pula)"@it ;
schema:description "Antica città fenicio-punica e romana parzialmente sommersa. Prova archeologica di innalzamento eustatico nel Sulcis."@it ;
psca:etymology "Possibile somiglianza fonetica con 'Norax', gigante fondatore di Nora e figlio di Ercole nella mitologia greca."@it .

psca:PortoMelqart a psca:SubmergedSite ;
rdfs:label "Porto sommerso di Melqart (Portus Erculi)"@it ;
psca:locatedIn "Capo Malfatano (Teulada, Sulcis)"@it ;
schema:description "Antico porto fenicio/cartaginese/romano, capace di ospitare 400 navi, le cui rovine si trovano a 2 metri di profondità."@it ;
psca:associatedWith psca:Hercules .

psca:PortoFlavia a psca:ArchaeologicalSite ;
rdfs:label "Porto Flavia"@it ;
psca:locatedIn "Masua (Sulcis-Iglesiente)"@it ;
schema:description "Antico porto minerario scavato nella roccia, con gallerie che si estendono al di sotto del livello del mare."@it .

psca:PortoConte a psca:SubmergedSite ;
rdfs:label "Porto Conte"@it ;
psca:locatedIn "Alghero"@it ;
schema:description "Resti archeologici e strutture portuali sommerse fenicio-puniche."@it .

# --- 3. Sistemi di Grotte (Possibile connessione con il mito e l'archeologia) ---

psca:IsZuddas a psca:CaveSystem ;
rdfs:label "Grotte di Is Zuddas"@it ;
psca:locatedIn "Sulcis-Iglesiente"@it ;
schema:description "Sistema carsico. Ipotesi PSCA: potrebbe aver giocato un ruolo nell'immaginario locale (es. ingresso all'Ade nel mito di Orfeo ed Euridice)."@it .

psca:GrottaCormorani a psca:SubmergedSite ;
rdfs:label "Grotta dei Cormorani"@it ;
psca:locatedIn "Cala Gonone"@it .

psca:GrotteNettuno a psca:CaveSystem ;
rdfs:label "Grotte di Nettuno"@it ;
psca:locatedIn "Alghero"@it .

psca:GrottaBueMarino a psca:CaveSystem ;
rdfs:label "Grotta del Bue Marino"@it ;
psca:locatedIn "Cala Gonone"@it .

# --- 4. Figure Mitologiche e Studi ---

psca:Hercules a psca:MythologicalFigure ;
rdfs:label "Ercole"@it ;
schema:description "Figura mitologica legata al Sulcis attraverso toponimi come Portus Erculi (Malfatano) e il mito del Giardino delle Esperidi."@it .

psca:Norax a psca:MythologicalFigure ;
rdfs:label "Norax"@it ;
schema:description "Gigante fondatore di Nora, figlio di Ercole."@it .

psca:GiandomenicoSerra a schema:Person ;
rdfs:label "Giandomenico Serra"@it ;
schema:description "Autore del lavoro 'Appunti su l’elemento punico e libico nell’onomastica sarda'."@it .

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <http://schema.org/> .
@prefix ex: <http://example.org/atlantis/> .

# --- Definizioni delle Classi ---
ex:ArchaeologicalSite a rdfs:Class ; rdfs:label "Sito Archeologico" .
ex:SubmergedSite a rdfs:Class ; rdfs:subClassOf ex:ArchaeologicalSite ; rdfs:label "Sito Sommerso" .
ex:AncientCity a rdfs:Class ; rdfs:label "Città Antica" .
ex:StructureType a rdfs:Class ; rdfs:label "Tipologia di Struttura" .
ex:AncientPeople a rdfs:Class ; rdfs:label "Popolo Antico" .
ex:HistoricalText a rdfs:Class ; rdfs:label "Testo Storico" .
ex:MythologicalEntity a rdfs:Class ; rdfs:label "Entità Mitologica" .
ex:GeographicalFeature a rdfs:Class ; rdfs:label "Caratteristica Geografica" .
ex:Toponym a rdfs:Class ; rdfs:label "Toponimo" .
ex:Event a rdfs:Class ; rdfs:label "Evento" .

# --- Definizioni delle Proprietà ---
ex:locatedIn a rdf:Property ; rdfs:label "situato in" .
ex:hasStructureType a rdf:Property ; rdfs:label "ha tipo di struttura" .
ex:mentionedIn a rdf:Property ; rdfs:label "menzionato in" .
ex:originOf a rdf:Property ; rdfs:label "origine di" .
ex:associatedWith a rdf:Property ; rdfs:label "associato a" .
ex:identifiedAs a rdf:Property ; rdfs:label "identificato come" .
ex:etymology a rdf:Property ; rdfs:label "etimologia" .

# --- Istanze: Tipologie di Strutture Sarde ---
ex:Nuraghe a ex:StructureType ; rdfs:label "Nuraghe" ; schema:description "Antichi edifici megalitici (1900-730 a.C.), quasi 7000 presenti in Sardegna." .
ex:SacredWell a ex:StructureType ; rdfs:label "Pozzo Sacro" .
ex:GiantsTomb a ex:StructureType ; rdfs:label "Tomba dei Giganti" .
ex:Dolmen a ex:StructureType ; rdfs:label "Dolmen" .
ex:Menhir a ex:StructureType ; rdfs:label "Menhir" .
ex:DomusDeJanas a ex:StructureType ; rdfs:label "Domus de Janas" .

# --- Istanze: Siti Archeologici e Città in Sardegna ---
ex:SuNuraxi a ex:ArchaeologicalSite ; rdfs:label "Su Nuraxi di Barumini" ; ex:hasStructureType ex:Nuraghe .
ex:NuragheSantuAntine a ex:ArchaeologicalSite ; rdfs:label "Nuraghe Santu Antine" ; ex:hasStructureType ex:Nuraghe .
ex:Tharros a ex:AncientCity ; rdfs:label "Tharros" ; ex:locatedIn "Costa occidentale della Sardegna" .
ex:Nora a ex:AncientCity ; rdfs:label "Nora" ; ex:locatedIn "Costa meridionale della Sardegna" .
ex:MontePrama a ex:ArchaeologicalSite ; rdfs:label "Statue di Mont'e Prama" .
ex:VillaggioTiscali a ex:ArchaeologicalSite ; rdfs:label "Villaggio Nuragico di Tiscali" .
ex:Tuvixeddu a ex:ArchaeologicalSite ; rdfs:label "Necropoli di Tuvixeddu" ; ex:locatedIn "Cagliari" .

ex:SuCarroppu a ex:ArchaeologicalSite ; rdfs:label "Rifugio sottoroccia Su Carroppu di Sirri" ; schema:description "Sito dove è stato rinvenuto DNA antico di probabili individui atlantidei." .
ex:GrottaLanaittu a ex:ArchaeologicalSite ; rdfs:label "Grotta di Lanaittu" ; schema:description "Resti risalenti a circa 20.000 anni fa." .
ex:NuragheAntigori a ex:ArchaeologicalSite ; rdfs:label "Nuraghe Antigori (Sarroch)" ; schema:description "Sito con ceramiche nuragiche e micenee (XIV-XII sec. a.C.)." .

# --- Istanze: Città e Siti Sommersi ---
ex:Pavlopetri a ex:SubmergedSite ; rdfs:label "Pavlopetri" ; ex:locatedIn "Grecia" .
ex:Baia a ex:SubmergedSite ; rdfs:label "Baia" ; ex:locatedIn "Italia" .
ex:Olous a ex:SubmergedSite ; rdfs:label "Olous" ; ex:locatedIn "Grecia" .
ex:Dolchiste a ex:SubmergedSite ; rdfs:label "Dolchiste" ; ex:locatedIn "Turchia" .
ex:AtlitYam a ex:SubmergedSite ; rdfs:label "Atlit Yam" ; ex:locatedIn "Israele" .
ex:Heracleion a ex:SubmergedSite ; rdfs:label "Heracleion" ; ex:locatedIn "Egitto" .

ex:PortoMelqart a ex:SubmergedSite ; rdfs:label "Porto sommerso di Melqart (Portus Erculi)" ; ex:locatedIn "Capo Malfatano, Teulada" .

# --- Istanze: Popoli ---
ex:Shardana a ex:AncientPeople ; rdfs:label "Shardana (Popoli del Mare)" ; schema:description "Popolo menzionato in testi egiziani (es. Ramses II), identificato da molti con i Sardi." .
ex:AtlanteanPeople a ex:AncientPeople ; rdfs:label "Popolo degli Atlanti" ; ex:locatedIn "Sulcis (Sardegna)" ; ex:mentionedIn ex:HistoriesHerodotus .
ex:Amazons a ex:AncientPeople ; rdfs:label "Amazzoni di Mirina" ; ex:locatedIn "Provincia di Cagliari (Lago Tritonide)" .

# --- Istanze: Testi Storici ---
ex:HistoriesHerodotus a ex:HistoricalText ; rdfs:label "Storie di Erodoto" ; schema:description "Testo che conferma la presenza del popolo degli Atlanti e descrive Libia e Sirti (identificate con la Sardegna meridionale)." .
ex:TimaeusAndCritias a ex:HistoricalText ; rdfs:label "Timeo e Crizia di Platone" .
ex:Argonautica a ex:HistoricalText ; rdfs:label "Argonautiche di Apollonio Rodio" .

# --- Istanze: Geografia Mitologica e Ricalibrazione ---
ex:Libya_Ancient a ex:GeographicalFeature ; rdfs:label "Libia (antica)" ; ex:identifiedAs "Provincia di Cagliari (Sardegna)" .
ex:Asia_Ancient a ex:GeographicalFeature ; rdfs:label "Asia (antica)" ; ex:identifiedAs "Corsica" .
ex:Syrtis a ex:GeographicalFeature ; rdfs:label "Sirti (Grande e Piccola)" ; ex:identifiedAs "Golfi di Cagliari e Sant'Antioco" .
ex:LakeTritonis a ex:GeographicalFeature ; rdfs:label "Lago Tritonide" ; ex:identifiedAs "Lagune di Cagliari" .
ex:AtlasMountains a ex:GeographicalFeature ; rdfs:label "Monti di Atlante" ; ex:identifiedAs "Monti del Sulcis" .
ex:GardenOfHesperides a ex:MythologicalEntity ; rdfs:label "Giardino delle Esperidi" ; ex:identifiedAs ex:Fruttidoro .
ex:HesperidumInsulae a ex:MythologicalEntity ; rdfs:label "Isole Esperidi (Isole delle Signore dell'Ovest)" ; ex:identifiedAs "Sardegna, Corsica e isole minori (es. Sant'Antioco)" .
ex:AtlanticOcean_Paleolithic a ex:GeographicalFeature ; rdfs:label "Oceano Atlantico (Paleolitico)" ; ex:identifiedAs "Mediterraneo Occidentale (Mar di Sardegna e Corsica)" .

# --- Istanze: Toponimi e Località ---
ex:Fruttidoro a ex:Toponym ; rdfs:label "Fruttidoro" ; ex:locatedIn "Capoterra, Sardegna" ; ex:identifiedAs ex:GardenOfHesperides .
ex:Capoterra a ex:Toponym ; rdfs:label "Capoterra" ; ex:etymology "Caput Terrae (Capo della Terra)" .
ex:Sulcis a ex:GeographicalFeature ; rdfs:label "Sulcis" ; schema:description "Capitale di Atlantide, sede del popolo degli Atlanti e dei Monti di Atlante." .
ex:Carloforte a ex:Toponym ; rdfs:label "Carloforte (Faraglione Antiche Colonne)" ; ex:identifiedAs "Colonne d'Ercole" .
ex:Ampurias_Sardinia a ex:Toponym ; rdfs:label "Diocesi di Tempio-Ampurias (Sardegna)" ; ex:associatedWith ex:Ampurias_Spain .
ex:Ampurias_Spain a ex:Toponym ; rdfs:label "Ampurias / Empúries (Spagna)" .

# --- Istanze: Eventi e Cause ---
ex:AtlantisSubmersion a ex:Event ;
rdfs:label "Affondamento di Atlantide (Blocco Sardo-Corso)" ;
schema:temporalCoverage "Prima del 9600 a.C." ;
ex:associatedWith "Meltwater Pulses (Pulse 1b)", "Slab Roll-Back", "Faglia Tettonica sotto il Sulcis" .

ex:EdittoDelleChiudende a ex:Event ;
rdfs:label "Editto delle Chiudende (XIX sec.)" ;
schema:description "Decreto che causò la distruzione e il saccheggio di molti nuraghi e reperti archeologici in Sardegna." .

# --- Relazioni internazionali (Colonie/Contatti) ---
ex:ElAhwat a ex:ArchaeologicalSite ; rdfs:label "El-Ahwat" ; ex:locatedIn "Israele (Vicino a Nahal Iron)" ; schema:description "Città fortificata dell'Età del Ferro I, associata da Adam Zertal agli Shardana." .
ex:NahalMearot a ex:ArchaeologicalSite ; rdfs:label "Grotte di Nahal Me’arot / Monte Carmelo" ; ex:locatedIn "Israele" ; schema:description "Ipotetiche colonie sardo-corso-atlantidee." .
ex:Trets a ex:ArchaeologicalSite ; rdfs:label "Sito di Terres Longues (Trets)" ; ex:locatedIn "Provenza, Francia" ; schema:description "Sito neolitico con 4548 frammenti di ossidiana sarda del Monte Arci." .

# --- Istanze: Religione e Mitologia ---
ex:BullCult a ex:MythologicalEntity ; rdfs:label "Culto del Toro" ; schema:description "Culto diffuso in Sardegna (cultura di Ozieri) e in Egitto (toro Apis), legato alla fertilità maschile e lunare/solare." .
ex:Poseidon a ex:MythologicalEntity ; rdfs:label "Poseidone" ; schema:description "Antichissimo sovrano dell'isola sardo-corsa, poi deificato." .
ex:Hercules a ex:MythologicalEntity ; rdfs:label "Ercole" ; ex:associatedWith ex:GardenOfHesperides, ex:PortoMelqart .
ex:Athena a ex:MythologicalEntity ; rdfs:label "Atena" ; ex:associatedWith ex:LakeTritonis .
ex:MadonnaDiBonaria a ex:MythologicalEntity ; rdfs:label "Madonna di Bonaria" ; schema:description "Leggenda della cassa incagliata nel Golfo di Cagliari (1370 d.C.), possibile parallelismo con le antiche navi greche incagliate nel Lago Tritonide." .

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <http://schema.org/> .
@prefix psca: <https://www.atlantisfound.it/ontology/psca#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .

# --- Definizione dell'Ontologia ---
psca:SardinianCorsicanParadigm a owl:Ontology ;
rdfs:label "Ontologia del Paradigma Sardo-Corso Atlantideo (Version 2026)" ;
schema:author psca:LuigiUsai .

# --- Classi ---
psca:GeologicalBlock rdfs:subClassOf schema:Place ; rdfs:label "Blocco Geologico" .
psca:AncientMigration rdfs:subClassOf schema:Event ; rdfs:label "Migrazione Atlantidea" .
psca:ToponymicShift rdfs:subClassOf schema:PropertyValue ; rdfs:label "Slittamento Toponomastico" .
psca:MythologicalReinterpretation rdfs:subClassOf schema:CreativeWork ; rdfs:label "Reinterpretazione Mitologica" .
psca:LinguisticFossil rdfs:label "Fossile Linguistico" .

# --- Entità Principale: Atlantide Sardo-Corsa ---
psca:AtlantisSardoCorsa a psca:GeologicalBlock ;
psca:identifiedAs "Blocco Geologico Sardo-Corso semi-sommerso" ;
psca:ancientName "Haou-Nebout", "Meropide", "CyrneIchnusa", "Nesos Espera" ;
psca:capital psca:Sulcis ;
psca:geographicalOrientation "Nord-Sud" ;
psca:submergedBy "Meltwater Pulse 1b", "Slab Roll-Back", "Faglia Wadati-Benioff sotto il Sulcis" ;
psca:geologicalEvidence "Piattaforma continentale sardo-corsa (-120/-140 metri)" ;
psca:survivingPlateaus psca:Sardinia, psca:Corsica .

# --- Etimologie e Slittamenti Toponomastici ---
psca:MauretaniaShift a psca:ToponymicShift ;
psca:originalRoot "Maurreddus" ;
psca:originalRegion "Sulcis" ;
psca:evolution "Maurreddania -> Maurrettania (latino) -> Mauretania" ;
psca:meaning "Terra di conquista dei Sulcitani" .

psca:LibyaShift a psca:ToponymicShift ;
psca:ancientReference "Libia (Erodoto, V sec. a.C.)" ;
psca:actualLocation psca:Cagliari_Province ;
psca:king psca:Anteo ;
psca:associatedDesert psca:PortoPino_Desert .

psca:GizaShift a psca:ToponymicShift ;
psca:subject "Piramidi di Giza" ;
psca:hypothesizedOrigin "Popolo dei Gizanti (Sardegna meridionale)" .

# --- Migrazioni Atlantidee (Out of Atlantis) ---
psca:Migration_Basques a psca:AncientMigration ;
psca:people "Popolo Basco" ;
psca:culturalFossil "Zanpantzar / Joaldun (mutazione dei Mamuthones/Boes sardi)" ;
psca:linguisticLink "Lingua ergativo-assolutiva, agglutinante (simili al Sardo e Sumero)" ;
psca:toponymicLink "Ittiri/Ituren", "Aritzo/Aritzu" .

psca:Migration_Sumerians a psca:AncientMigration ;
psca:people "Sumeri (teste nere)" ;
psca:languageLink "Lingua Atlantidea Sumerica (agglutinante)" ;
psca:etymologyLink "SMR (Sumer) -> SMR (Samaria)" .

psca:Migration_Hebrews a psca:AncientMigration ;
psca:people "Tribù perdute d'Israele / Ebrei" ;
psca:shardanaConnection "Identità Shardana-Tribù di Dan" ;
psca:toponymicLink "Sinnai -> Sinai" ;
psca:archaeologicalSite psca:ElAhwat .

psca:Migration_Aztecs a psca:AncientMigration ;
psca:people "Atzechi" ;
psca:originPlace "Aztlan (Isola nell'Atlantico/Mediterraneo)" ;
psca:toponymicFossil "Falesia di Montezuma (Sardegna)" .

psca:Migration_Patagoni a psca:AncientMigration ;
psca:people "Giganti Patagoni" ;
psca:literaryMatch "Meropi (Teopompo di Chio) = Pathagoni (Antonio Pigafetta)" .

# --- Reinterpretazioni Mitologiche ---
psca:MinotaurReinterpretation a psca:MythologicalReinterpretation ;
psca:sardinianRoot "Su Boe Erchitu", "Su Boe Muliache" ;
psca:minoanConnection "Minoici come migrazione sardo-atlantidea a Creta" .

psca:AthenaReinterpretation a psca:MythologicalReinterpretation ;
psca:birthPlace psca:LakeTritonide ;
psca:egyptianIdentity "Neith (Sais)" ;
psca:latinIdentity "Minerva" ;
psca:sardinianLink "Dea Tanit (Ta-Neith: Terra di Neith)" ;
psca:foundingDateSais "8590 a.C." ;
psca:foundingDateAthens "9590 a.C." .

psca:HesperidesReinterpretation a psca:MythologicalReinterpretation ;
psca:location psca:Fruttidoro_Capoterra ;
psca:toponymEtymology "Caput Terrae (Capo della Terra)" ;
psca:goldenFruits "Arance o Limoni (scoperti dai Greci/Ercole)" .

# --- Siti Archeologici Chiave ---
psca:ElAhwat a psca:ArchaeologicalSite ;
rdfs:label "El-Ahwat (Israele)" ;
psca:excavator "Adam Zertal" ;
psca:nuragicSimilarity "Torri a corridoio simili ai Nuraghi" .

psca:BeitShearim a psca:ArchaeologicalSite ;
rdfs:label "Necropoli di Beit Shearim" ;
psca:features "Culto del Toro", "Simbologia di Nekhbet" ;
psca:architecture "Evoluzione delle Domus de Janas" .

psca:RujmElHiri a psca:ArchaeologicalSite ;
rdfs:label "Rujm el-Hiri (Alture del Golan)" ;
psca:structure "Cerchi concentrici megalitici atlantidei" .

psca:Antas a psca:ArchaeologicalSite ;
rdfs:label "Tempio di Antas" ;
psca:dedication "Anteo (Re della Libia/Campidano) deificato" .

# --- Fossili Linguistici ---
psca:ContinentExpression a psca:LinguisticFossil ;
psca:idiom "Deppu andai in Continenti" ;
psca:meaning "Andare fuori dall'isola (ex-continente Atlantideo)" ;
psca:semioticProof "Conferma la descrizione di Platone del blocco come 'continente'" .

# --- Fauna e Risorse ---
psca:MammuthusLamarmorae a schema:Taxon ;
rdfs:label "Elefante nano sardo" ;
psca:platonicMatch "Specie degli elefanti presente ad Atlantide" .

psca:Obsidian rdfs:label "Ossidiana del Monte Arci" ;
psca:platonicMatch "Pietre nere di Atlantide" .

# --- Supporto Tecnico ---
psca:EmodnetMapViewer a schema:SoftwareApplication ;
rdfs:label "EMODnet Map Viewer" ;
psca:usedFor "Analisi batimetrica ad alta precisione del blocco sardo-corso" .

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <http://schema.org/> .
@prefix psca: <https://www.atlantisfound.it/ontology/psca#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .

# --- Definizione dell'Ontologia ---
psca:SardinianCorsicanParadigm_Expansion_2026 a owl:Ontology ;
rdfs:label "Espansione Ontologica del Paradigma Sardo-Corso Atlantideo (Modulo Israele-Americhe-Giappone)" ;
schema:author psca:LuigiUsai .

# --- Classi Aggiuntive ---
psca:MegalithicMonument rdfs:subClassOf schema:Place ; rdfs:label "Monumento Megalitico" .
psca:LinguisticFamily rdfs:label "Famiglia Linguistica Atlantidea" .
psca:ReligiousPhenomenon rdfs:label "Fenomeno Religioso / Rituale" .
psca:ScientificDiscovery rdfs:label "Scoperta Scientifica Correlata" .

# --- 1. Evidenze in Israele e Medio Oriente ---

psca:RujmElHiri a psca:MegalithicMonument ;
rdfs:label "Rujm el-Hiri (Gilgal Refaim)" ;
geo:hasGeometry "Alture del Golan" ;
psca:structure "42.000 rocce basaltiche in cerchi concentrici" ;
psca:dating "3000-2750 a.C. (Antica Età del Bronzo)" ;
psca:interpretedAs "Centro rituale atlantideo per il culto dei morti" ;
psca:pscaCorrelation "Tecnica costruttiva del popolo di Atlantide (blocco sardo-corso)" .

psca:HebrewReligionOrigin a psca:ReligiousPhenomenon ;
rdfs:label "Origine della Religione Ebraica" ;
psca:symbol "Vitello d'Oro" ;
psca:originalSource psca:NuragheDiana_HeadOfLight ;
psca:theologicalRoot "Ricerca della Terra Promessa dopo l'affondamento di Atlantide" .

psca:NuragheDiana_Macomer a psca:ArchaeologicalSite ;
rdfs:label "Nuraghe Diana (Macomer)" ;
psca:miracleOfLight "Formazione di una testa di vitello solare (Dio Toro) tramite feritoia" .

# --- 2. Larache (Marocco) e il Pleistocene ---

psca:LaracheFootprints a psca:ScientificDiscovery ;
rdfs:label "Impronte umane di Larache" ;
psca:location "Marocco" ;
psca:dating "90.000 anni fa (Tardo Pleistocene)" ;
psca:researcher psca:MoncefEssedrati ;
psca:pscaCorrelation "Prova della presenza di Homo Sapiens evoluti in aree connesse al paradigma sardo-corso" .

# --- 3. Sinonimi e Identità di Atlantide ---

psca:AtlantisIdentities a owl:Class ;
    rdfs:label "Nomi Diversificati di Atlantide Sardo-Corsa"  ;

psca:SardoCorsicanBlock psca:synonym
"Meropide" ,
"Nibiru (secondo rilettura del termine)" ,
"Tirrenide" ,
"Aztlán" .

psca:NibiruMiners a psca:AncientPeople ;
rdfs:label "Minatori di Nibiru" ;
psca:actualIdentity "Minatori del Sulcis (Sardegna)" ;
psca:activity "Estrazione di oro in Africa per scopi religiosi atlantidei" ;
psca:michaelTellingerLink "Miniere d'oro antichissime in Sud Africa" .

# --- 4. Connessioni Globali (Irlanda, Giappone, Spagna) ---

psca:Newgrange_Ireland a psca:MegalithicMonument ;
rdfs:label "Newgrange (Irlanda)" ;
psca:pscaInfluence "Abilità ingegneristica e astronomica sardo-corso atlantidea" ;
psca:dating "3200 a.C." .

psca:NagaokaCaves_Japan a psca:ArchaeologicalSite ;
rdfs:label "Nagaoka Burial Caves (Giappone)" ;
psca:typology "Yokoana-bo (tombe a foro laterale)" ;
psca:analogWith psca:DomusDeJanas ;
rdfs:comment "Adattamento di simili condizioni geologiche e concezioni dell'aldilà" .

psca:CanchoRoano_Spain a psca:ArchaeologicalSite ;
rdfs:label "Cancho Roano" ;
psca:pscaCorrelation "Costruzione post-sommersione; quadrati concentrici per 'nascondersi' da Poseidone; presenza del simbolo della metallurgia del Sulcis" .

# --- 5. Epistemologia e Filosofia ---

psca:DionysianSparagmos a psca:MythologicalReinterpretation ;
rdfs:label "Sparagmos Dionisiaco" ;
psca:metaphorFor "Smembramento e dispersione del popolo di Atlantide dopo il cataclisma" .

psca:UsaiInsightTheorem a schema:CreativeWork ;
rdfs:label "Teorema dell'Insight di Usai" ;
schema:description "Necessità della cognizione umana abduttiva per superare i limiti probabilistici dell'IA e del consenso accademico (Kuhnian Paradigm Shift)" .

# --- 6. Linguistica Agglutinante ed Ergativa ---

psca:AtlanteanLinguisticFamily a psca:LinguisticFamily ;
rdfs:label "Lingue Agglutinanti Ergative" ;
psca:includes
"Basco" ,
"Sumero" ,
"Ebraico (sostrato)" ,
"Uto-Azteca (Nahuatl)" ,
"Tamil (Dravidiche)" ,
"Uraliche (Finlandese, Ungherese)" ;
psca:commonOrigin "Piattaforma continentale sardo-corsa (Paleo-Indo-Europeo reale)" .

psca:ToponymicCoincidence_Uta a psca:ToponymicShift ;
psca:sardinianTerm "Uta (Sulcis)" ;
psca:amerindianTerm "Utah / Tribù Ute" ;
psca:interpretedAs "Migrazione dei Popoli del Mare verso le Americhe" .

# --- 7. Mitologia Egizia e Sarda ---

psca:TaNeith a psca:MythologicalReinterpretation ;
psca:symbol "Tanit" ;
psca:geroglyphicMeaning "Ta Neith (Terra di Neith/Atena)" ;
psca:geographicInterpretation "Mappa stilizzata del blocco sardo-corso (Testa=Corsica, Braccia=Bocche di Bonifacio, Triangolo=Sardegna)" .

psca:Hathor_Atzori a psca:ToponymicShift ;
psca:egyptianDeity "Hathor (Dea Vacca)" ;
psca:sardinianSurname "Atzori / Atzeni" ;
psca:phoneticRoot "Atz (suono tipico sardo e azteco/Aztlan)" .

# --- 8. Reperti e Oggetti Sacri ---

psca:SardinianCassapanca a schema:Thing ;
rdfs:label "Cassapanca sarda con 4 ruote (Bronzetto)" ;
psca:hypothesizedIdentity "Vera Arca dell'Alleanza" ;
psca:orientalLink "Vaso Fang Ding (Cina, Dinastia XIX)" .

# --- 9. Geologia e Strutture ---

psca:CampidanoGeology a psca:GeologicalEvent ;
psca:structure "Graben-Horst" ;
psca:vulnerability "Rischio di sommersione rapida e collasso carsico (Doline del Sulcis)" .

