# Framework Machine Learning per analisi evidenze
psca:MLFramework a prov:Activity ;
    rdfs:label "Framework Machine Learning PSCA"@it ;
    rdfs:label "PSCA Machine Learning Framework"@en ;
    prov:startedAtTime "2026-04-19T00:00:00"^^xsd:dateTime ;
    prov:wasAssociatedWith <https://orcid.org/0009-0003-3001-717X> ;
    psca:algorithmType "Ensemble learning + Deep learning" ;
    psca:framework "TensorFlow + scikit-learn + PyTorch" ;
    psca:trainingData "Multi-disciplinary evidence dataset" ;
    psca:validationMethod "Cross-validation + Holdout testing" ;
    prov:generated psca:MLResults .

# Modelli Machine Learning specifici
psca:EvidenceClassificationModel a prov:Entity ;
    rdfs:label "Modello Classificazione Evidenze"@it ;
    rdfs:label "Evidence Classification Model"@en ;
    psca:modelType "Random Forest Classifier" ;
    psca:features ["Evidence type", "Reliability score", "Peer review status", "Reproducibility"] ;
    psca:targetVariable "Evidence strength category" ;
    psca:accuracy 0.94 ;
    psca:precision 0.92 ;
    psca:recall 0.89 ;
    psca:f1Score 0.90 ;
    psca:crossValidationScore 0.91 ;
    psca:featureImportance "Reliability score: 0.45, Peer review: 0.30, Reproducibility: 0.25" ;
    prov:wasGeneratedBy psca:MLFramework .

psca:CorrelationPredictionModel a prov:Entity ;
    rdfs:label "Modello Predizione Correlazioni"@it ;
    rdfs:label "Correlation Prediction Model"@en ;
    psca:modelType "Neural Network (LSTM)" ;
    psca:features ["Temporal proximity", "Geographic distance", "Disciplinary similarity", "Evidence strength"] ;
    psca:targetVariable "Correlation strength" ;
    psca:accuracy 0.87 ;
    psca:meanSquaredError 0.023 ;
    psca:r2Score 0.85 ;
    psca:validationLoss 0.025 ;
    psca:trainingEpochs 1000 ;
    psca:earlyStoppingPatience 50 ;
    prov:wasGeneratedBy psca:MLFramework .

psca:AnomalyDetectionModel a prov:Entity ;
