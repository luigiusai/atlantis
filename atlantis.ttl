#################################################################
# 13. ESPANSIONE V. 19.0 - GEOLOCALIZZAZIONE DELLA ROTTA DI ULISSE
#################################################################

# --- 1. IPOTESI E TEORIE (ROTTA DI ULISSE) ---

psca:UlyssesRouteHypothesis a psca:Hypothesis ;
    rdfs:label "Geolocalizzazione della Rotta di Ulisse nel Mediterraneo Occidentale"@it ;
    schema:description "Rilocazione odologica che posiziona il viaggio di Ulisse (Nostos) lungo le coste della Sardegna (rotta da Nord a Sud-Ovest), integrando la geografia omerica nel Paradigma Sardo-Corso-Atlantideo."@it ;
    psca:supportedBy psca:Evidence_Telepylos, psca:Evidence_PortoMaga, psca:Evidence_Pistis, psca:Evidence_SirensCave, psca:Evidence_ScyllaCharybdis, psca:Evidence_HeliosCows ;
    schema:author <https://orcid.org/0009-0003-3001-717X> .

# --- 2. FIGURE E POPOLAZIONI MITOLOGICHE (OMERO) ---

psca:Ulysses a psca:MythicalEntity ;
    rdfs:label "Ulisse / Odisseo"@it ;
    schema:description "Navigatore acheo la cui rotta esplorativa e commerciale si è snodata lungo l'Insula Magna."@it ;
    psca:isInterpretedBy psca:ParadigmaSardoCorsoAtlantideo .

psca:Circe a psca:MythicalEntity ;
    rdfs:label "Maga Circe (Pharmakis)"@it ;
    schema:description "Figura femminile egemone/sacerdotessa sarda incontrata da Ulisse."@it ;
    psca:interpretsAs psca:PortoMaga .

psca:Sirens a psca:MythicalEntity ;
    rdfs:label "Sirene"@it ;
    schema:description "Riflesso mitopoietico della tradizione polifonica femminile sarda, amplificata da casse di risonanza litiche naturali verso il mare aperto."@it ;
    psca:interpretsAs psca:GrottaDelleSirene .

psca:Laistrygones a psca:AncientPopulation, psca:MythicalEntity ;
    rdfs:label "Lestrigoni"@it ;
    schema:description "Tribù costiere sarde del Nord (probabilmente Corsi o Balari), fiere e difensive, poste a guardia delle Bocche di Bonifacio."@it ;
    psca:interpretsAs psca:GalluraCoast .

# --- 3. TOPONIMI E GEOGRAFIA REALE SULLA ROTTA ---

psca:IslandOfAeaea a psca:MythicalEntity ;
    rdfs:label "Isola di Eea (Dimora di Circe)"@it ;
    psca:interpretsAs psca:PortoMaga .

psca:GalluraCoast a psca:GeographicalEntity ;
    rdfs:label "Costa della Gallura / Palau / Bocche di Bonifacio"@it ;
    schema:description "Identificata con Telepilo, la terra dei Lestrigoni. Descritta da Omero come un fiordo stretto, circondato da rupi eccelse con acque interne mai gonfie."@it .

psca:PortoMaga a psca:Toponym, psca:GeographicalEntity ;
    rdfs:label "Porto Maga (Costa Verde, Arbus)"@it ;
    schema:description "Toponimo fossile indicante la dimora della Maga Circe (Pharmakis)."@it ;
    psca:hasAncientEquivalent psca:IslandOfAeaea .

psca:Pistis_Toponym a psca:Toponym ;
    rdfs:label "Pistis (Costa Verde, Sardegna)"@it ;
    schema:description "Toponimo adiacente a Porto Maga. Relitto filologico del termine greco pístis (fiducia/giuramento), a ricordo del patto di ripartenza stretto tra l'eroe e la maga."@it ;
    psca:sourceText "Dal greco πίστις (fiducia, persuasione, patto)."@it .

psca:GrottaDelleSirene a psca:Toponym, psca:GeographicalEntity ;
    rdfs:label "Grotta delle Sirene (Sant'Antioco)"@it ;
    schema:description "Antro utilizzato come cassa di risonanza naturale (megafono litico). Si configurava come trappola idrografica e acustica per i navigatori egei che si avvicinavano agli scogli."@it .

psca:IsolaDellaVacca a psca:Toponym, psca:GeographicalEntity ;
    rdfs:label "Isola della Vacca / Isola Rossa (Eriteia)"@it ;
    schema:description "Area del Sulcis meridionale sacra al culto zootecnico. Corrisponde ai pascoli del bestiame sacro al Dio Sole (Helios), il cui furto scatenò l'ira divina contro l'equipaggio di Ulisse."@it .

psca:ScillaAndCharybdis_Sulcis a psca:GeographicalEntity ;
    rdfs:label "Scilla e Cariddi (Stretto Sulcitano / Capo Teulada)"@it ;
    schema:description "Passaggio critico tra le isole sulcitane e Capo Teulada, caratterizzato da correnti incrociate avverse e scogliere taglienti, trasfigurato nel mito del mostro e del vortice."@it .

# --- 4. EVIDENZE DI CONSILIENZA (Vettori Epistemologici) ---

psca:Evidence_Telepylos a psca:EvidenceVector ;
    rdfs:label "Morfologia di Telepilo"@it ;
    schema:description "Sovrapponibilità morfologica esatta tra i fiordi della costa gallurese e la descrizione omerica di un porto senza onde racchiuso tra rupi continue."@it .

psca:Evidence_Pistis a psca:EvidenceVector ;
    rdfs:label "Fossile Filologico 'Pistis'"@it ;
    schema:description "Eccezionale conservazione della radice greca di 'patto/fiducia' in strettissima adiacenza al locus di Porto Maga."@it .

psca:Evidence_SirensCave a psca:EvidenceVector ;
    rdfs:label "Ipotesi Eco-Acustica della Grotta"@it ;
    schema:description "La musica vocale ostrumentale amplificata dalla roccia costiera venne interpretata dai navigatori ignari come un richiamo sovrannaturale alieno."@it .

psca:Evidence_HeliosCows a psca:EvidenceVector ;
    rdfs:label "Distretto del Toro Sacro"@it ;
    schema:description "Densità anomala di riferimenti zootecnici (Isola della Vacca, Isola del Vitello, Isola del Toro) in prossimità del percorso nautico."@it .

# --- 5. PUBBLICAZIONI E FONTI (Dati Bibliografici) ---

