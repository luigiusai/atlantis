@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

### 1. DEFINIZIONE DEL POPOLO ATLANTIDEO (MODELLO ACTOR)
psca:PopoloAtlantideo rdf:type owl:Class ;
    rdfs:subClassOf crm:E74_Group ; # Gruppo sociale secondo CIDOC-CRM
    rdfs:label "Popolazione dell'Isola Sardo-Corsa (Atlantide)"@it ;
    rdfs:comment "Gruppo umano residente nel blocco Sardo-Corso prima della sommersione post-glaciale."@it .

### 2. LOGICA TEMPORALE (LIMITE 9600 a.C.)
# Definiamo l'evento di sommersione come spartiacque
psca:EventoSommersioneAtlantide rdf:type crm:E52_Time-Span ;
    time:inXSDDateTime "BC09600-01-01T00:00:00Z"^^xsd:dateTime .

### 3. ASSIOMA DI INFERENZA (RESTRIZIONE LOGICA)
# Questo blocco dice al Reasoner: 
# "Se un sito   nel blocco Sardo-Corso E la sua datazione   antecedente al 9600 BC,
# allora gli abitanti sono automaticamente PopoloAtlantideo".

psca:AbitanteAtlantideo rdf:type owl:Class ;
    owl:equivalentClass [
        rdf:type owl:Restriction ;
        owl:onProperty crm:P14i_performed ; # Ha compiuto azioni in...
        owl:someValuesFrom [
            rdf:type owl:Class ;
            owl:intersectionOf (
                crm:E7_Activity
                [ rdf:type owl:Restriction ;
                  owl:onProperty crm:P7_took_place_at ;
                  owl:hasValue psca:BloccoSardoCorso ]
                [ rdf:type owl:Restriction ;
                  owl:onProperty crm:P4_has_time-span ;
                  owl:someValuesFrom psca:PeriodoPreCataclismatico ]
            )
        ]
    ] .

### 4. DEFINIZIONE DELLE COSTANTI (IL BLOCCO SARDO-CORSO)
psca:BloccoSardoCorso rdf:type crm:E53_Place ;
    rdfs:label "Isola Sardo-Corsa (Piana del Campidano estesa)"@it ;
    geo:hasGeometry [ 
        rdf:type geo:Geometry ;
        geo:asWKT "POLYGON((...))"^^geo:wktLiteral # Qui andrebbero le coordinate della paleocosta -120m
    ] .

psca:PeriodoPreCataclismatico rdf:type crm:E52_Time-Span ;
    rdfs:label "Era Pre-Sommersione"@it ;
    psca:datazioneBP_Min 11600 . # 9600 BC + 2000 anni (BP)

#################################################################
# PROPRIET  DI INFERENZA AUTOMATICA (PROPERTY CHAINS)
#################################################################

# Se un reperto   trovato in un sito pre-9600 BC nel blocco Sardo-Corso,
#   automaticamente classificato come "Manufatto Atlantideo".

psca:manufattoAtlantideo rdf:type owl:ObjectProperty ;
    owl:propertyChainAxiom (
        crm:P108i_was_produced_by
        crm:P7_took_place_at
        psca:mostraContinuitaCon
    ) ;
    rdfs:label "manufatto di origine atlantidea"@it  ;

#################################################################
# ESEMPIO DI COSA SUCCEDE (DATO DI INPUT)
#################################################################

# Se tu scrivi questo nel tuo file:
# psca:Strumento_Ossidiana_X rdf:type crm:E22_Manmade_Object ;
#    crm:P7_took_place_at psca:BloccoSardoCorso ;
#    psca:datazioneBP_Min 12000 .
#
# IL REASONER AGGIUNGER  DA SOLO:
# -> psca:Strumento_Ossidiana_X rdf:type psca:AbitanteAtlantideo (o relativo output)

@prefix :        <https://www.atlantisfound.it/ontology/psca#> .
@prefix psca:    <https://www.atlantisfound.it/ontology/psca#> .
@prefix usai:    <https://www.atlantisfound.it/resource/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix schema:  <https://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix geo:     <http://www.opengis.net/ont/geosparql#> .
@prefix crm:     <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix wd:      <http://www.wikidata.org/entity/> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix dcat:    <http://www.w3.org/ns/dcat#> .
