    psca:driftDetectionMethod "Population Stability Index + KL divergence" ;
    psca:performanceThreshold 0.85 ;
    psca:retrainingTrigger "Performance drop > 10% or drift detected" ;
    psca:monitoringFrequency "Daily automated checks" .

