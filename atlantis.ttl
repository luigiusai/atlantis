psca:Epistemological_Status_KuhnianShift a schema:Thing ;
    schema:name "Kuhnian Paradigm Shift of the PSCA" ;
    schema:description "Il PSCA sostituisce la storiografia classica in crisi tramite evidenze consilienti (geologia, genetica, batimetria), attuando un cambio di paradigma come descritto da Thomas Kuhn."@it ;
    psca:appliesMethodology "Anarchismo Epistemologico (Paul Feyerabend)" ;
    schema:creator <https://orcid.org/0009-0003-3001-717X> .

