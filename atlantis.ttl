# Query template per arricchimento dati
psca:WikidataEnrichmentQuery a prov:Entity, schema:CreativeWork ;
    rdfs:label "Query Arricchimento Wikidata"@it ;
    rdfs:label "Wikidata Enrichment Query"@en ;
    schema:text """
    PREFIX wd: <http://www.wikidata.org/entity/>
    PREFIX wdt: <http://www.wikidata.org/prop/direct/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX schema: <http://schema.org/>
    
    # Query template per arricchimento entità PSCA
    SELECT ?pscaEntity ?wikidataEntity ?property ?value ?valueLabel
    WHERE {
        # Entità PSCA da arricchire
        VALUES ?pscaEntity { ?psca_entity_placeholder }
        
        # Mapping a Wikidata
        ?mapping psca:pscaEntity ?pscaEntity .
        ?mapping psca:wikidataEntity ?wikidataEntity .
        
        # Proprietà da estrarre da Wikidata
        SERVICE <https://query.wikidata.org/sparql> {
            ?wikidataEntity ?property ?value .
            OPTIONAL {
                ?value rdfs:label ?valueLabel .
                FILTER(LANG(?valueLabel) = "it")
            }
        }
        
        # Filtra proprietà di interesse
        FILTER(?property IN (wdt:P31, wdt:P279, wdt:P361, wdt:P527, wdt:P155, wdt:P156))
    }
    """ ;
    psca:queryType "Enrichment template" ;
    psca:supportedProperties ["Instance of", "Subclass of", "Part of", "Has part", "Follows", "Followed by"] ;
    psca:outputFormat "JSON + RDF" ;
    psca:processingPipeline "Validation + Normalization + Integration" ;
    prov:wasGeneratedBy psca:WikidataFederationSystem .

