    schema:description "Un nucleo atlantideo con 'stasi genetica' implicherebbe nuove interpretazioni sui flussi post-glaciali e possibili connessioni transoceaniche o intercontinentali."@it ;
    psca:impactCategory "Paleogenetics; PopulationGenomics" ;
    psca:consequenceConfidence "0.60"^^xsd:decimal ;
