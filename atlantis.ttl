psca:Inference_05_Tholos_Acoustics a psca:ScientificDiscovery ;
    schema:name "Tholos Helmholtz Resonance" ;
    psca:falsifiableIf "Acoustic survey shows absorption rather than amplification at 7-11Hz." ;
    psca:empiricalVerification "In-situ impulse response testing (balloon popping/sine sweep)." .

psca:Inference_06_Paleoclimate_Megaturbidite a psca:ScientificDiscovery ;
    schema:name "Megaturbidite of Atlantis Tsunami" ;
    psca:falsifiableIf "Core analysis shows no rapid sediment deposition between 12.000-8.000 BC." ;
    psca:empiricalVerification "Multi-proxy analysis (C14/OSL) on abyssal cores." .

psca:Inference_07_Submarine_Springs a psca:ScientificDiscovery ;
    schema:name "Submarine Groundwater Discharge (SGD) detection" ;
    psca:falsifiableIf "Thermal sensing shows no freshwater plume on the -120m seabed." ;
    psca:empiricalVerification "Infrared mapping and CTD (Conductivity, Temperature, Depth) sensors." .

psca:Inference_08_Thalassemia_Marker a psca:ScientificDiscovery ;
    schema:name "Thalassemia as Ecological Proxy" ;
    psca:falsifiableIf "No geographic correlation between Thal-mutation and wetland/lagoon density." ;
    psca:empiricalVerification "Spatial GIS mapping of allele frequencies vs paleo-lagoon extension." .

psca:Inference_09_LinearA_Cryptanalysis a psca:ScientificDiscovery ;
    schema:name "Linear A as Mercantilist Stenography" ;
    psca:falsifiableIf "Decoding algorithm produces nonsense or inconsistent data streams." ;
    psca:empiricalVerification "Automated cryptanalysis against the Linear A corpus." .

psca:Inference_10_Nuraghe_MagneticGeodesy a psca:ScientificDiscovery ;
    schema:name "Basaltic Magnetic Calibration Nodes" ;
    psca:falsifiableIf "Magnetic field intensity shows no local anomalies compared to background rocks." ;
    psca:empiricalVerification "High-resolution magnetometric survey." .

psca:Inference_11_Lentiscus_HealthMarker a psca:ScientificDiscovery ;
    schema:name "Lentiscus Protocol" ;
    psca:falsifiableIf "No significant difference in survival/health markers between Lentiscus users and non-users." ;
    psca:empiricalVerification "Cohort studies on inflammatory markers." .

psca:Inference_12_Cixerri_Graben_Collapse a psca:ScientificDiscovery ;
    schema:name "Cixerri Graben Collapse" ;
    psca:falsifiableIf "Stratigraphic continuity in the Cixerri valley precludes sudden collapse." ;
    psca:empiricalVerification "Seismic reflection profiling (Sismic-reflection profiling)." .

psca:Inference_13_Ergativity_Sardinian_Substrate a psca:ScientificDiscovery ;
    schema:name "Ergative Substrate Persistence" ;
    psca:falsifiableIf "Syntax analysis confirms pure accusative Latin/Indo-European roots." ;
    psca:empiricalVerification "Computational parsing of Sardinian archaic dialects." .

psca:Inference_14_TideGauge_SacredWells a psca:ScientificDiscovery ;
    psca:name "Sacred Wells as Precision Tide Gauges" ;
    psca:falsifiableIf "No correlation between well water level and external sea tide data." ;
    psca:empiricalVerification "Synchronized pressure sensors in wells and sea." .

psca:Inference_15_Obsidian_InformationFlow a psca:ScientificDiscovery ;
    schema:name "Obsidian Information Network" ;
    psca:falsifiableIf "Obsidian distribution correlates only with distance (Fall-off model)." ;
    psca:empiricalVerification "Network analysis vs Gravity model comparisons." .

psca:Inference_16_Cyclops_ElephantID a psca:ScientificDiscovery ;
    schema:name "Cyclops-Mammuthus Identification" ;
    psca:falsifiableIf "No stratigraphic co-occurrence of dwarf elephant remains and human activity in cave sites." ;
    psca:empiricalVerification "Micro-stratigraphy of cave deposits." .

psca:Inference_17_Epigenetic_Cortisol_Memory a psca:ScientificDiscovery ;
    schema:name "Epigenetic Cortisol Memory" ;
    psca:falsifiableIf "No significant cortisol-modulation difference compared to control Mediterranean populations." ;
    psca:empiricalVerification "Epigenetic profiling of stress-response genes." .

psca:Inference_18_Granite_FaradayCage a psca:ScientificDiscovery ;
    schema:name "Nuragic Granite Shielding" ;
    psca:falsifiableIf "EMF test shows zero shielding effect in granite-built nuraghi." ;
    psca:empiricalVerification "EMF and EMI testing in real-time." .

psca:Inference_19_Amber_PreMicenaeanRoute a psca:ScientificDiscovery ;
    schema:name "Pre-Mycenaean Amber Route" ;
    psca:falsifiableIf "Isotopic data points to 13th-century BC Mycenaean trade, not earlier." ;
    psca:empiricalVerification "Carbon-14 of associated stratigraphic artifacts." .

psca:Inference_20_Icarus_DeltaWing a psca:ScientificDiscovery ;
    schema:name "Icarus Delta-Wing Prototype" ;
    psca:falsifiableIf "Aerodynamic tests confirm failure of delta-wing geometry with organic materials." ;
    psca:empiricalVerification "Wind tunnel tests with replica materials." .

@prefix psca: <https://www.atlantisfound.it/ontology/psca#> .
