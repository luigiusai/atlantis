    rdfs:label "Centro Megalitico Globale"@it  ;

psca:TheologicalArchetype rdfs:label "Archetipo Teologico Primordiale"@it .

psca:BiologicalAnomalie rdfs:label "Anomalia Biologica / Evolutiva"@it .

psca:CulinaryTradition rdfs:label "Tradizione Gastronomica Atlantidea"@it .

# --- 1. IL CUORE GEOLOGICO (ATLANTIDE / NIBIRU / MEROPIDE) ---

usai:SardoCorsicanBlock a psca:GeologicalBlock ;
    schema:name "Blocco Geologico Sardo-Corso (Atlantide)" ;
    psca:synonym "Haou-Nebout", "Meropide", "Nibiru", "Tirrenide", "Aztlan", "Ad", "Aditi" ;
    psca:islandsIncluded usai:Sardegna, usai:Corsica ;
    psca:submergedPart usai:SardinianCorsicanShelf ;
    psca:geologicalAnomalies "Faglia Wadati-Benioff sotto il Sulcis", "Slab Roll-Back" ;
    psca:cataclysmDate "circa 9600 a.C. (MWP-1B)" ;
    psca:geographicalLength "555 km (3000 stadi platonici)" ;
    psca:capital usai:SulcisMetropolis .

# --- 2. ETNOMITOLOGIA E RICALIBRAZIONE GEOGRAFICA ---

usai:Mauretania_Etymology a psca:ToponymicShift ;
    psca:originalRoot "Maurreddus" ;
    psca:regionOrigin usai:Sulcis ;
    psca:evolution "Maurreddania (Sardo) -> Maurrettania (Latino) -> Mauretania" ;
    psca:logicReversal "I Sardo-Corsi hanno dominato il Nord Africa, non il contrario" ;
    psca:heraldicProof usai:BandieraQuattroMori .

usai:Libya_Rethink a psca:ToponymicShift ;
    psca:ancientReference "Libia (Erodoto)" ;
    psca:pscaMapping usai:Cagliari_Province ;
    psca:king usai:Anteo ;
    psca:mythologicalConflict "Ercole vs Anteo (avvenuto nel Campidano)" ;
    psca:associatedPeoples usai:Ausei, usai:Maclei, usai:Giligami, usai:Atlanti, usai:Nasomoni .

# --- 3. MEGALITISMO GLOBALE (GOLAN, IRLANDA, GIAPPONE) ---

psca:RujmElHiri a psca:MegalithicCenter ;
    rdfs:label "Rujm el-Hiri (Gilgal Refaim)" ;
    psca:location "Alture del Golan" ;
    psca:composition "42.000 rocce basaltiche in cerchi concentrici" ;
    psca:pscaCorrelation "Costruito da esperti atlantidei migrati dal blocco sardo-corso" .

psca:Newgrange_Ireland a psca:MegalithicCenter ;
    rdfs:label "Newgrange (Irlanda)" ;
    psca:builtBy psca:AtlanteanSardinianCorsican ;
    psca:astronomicalAlignment "Solstizio d'Inverno" ;
    psca:dating "3200 a.C." .

psca:NagaokaCaves_Japan a psca:ArchaeologicalSite ;
    rdfs:label "Nagaoka Burial Caves (Giappone)" ;
    psca:architectureType "Yokoana-bo (tombe a foro laterale)" ;
    psca:isomorphicWith psca:DomusDeJanas .

# --- 4. TEOLOGIA: DAL TORO DI LUCE ALL'AGNELLO DI DIO ---

usai:Hebrew_Nuragic_Origin a psca:TheologicalTransition ;
    psca:claim "Gli Ebrei sono una migrazione post-atlantidea/nuragica fuggita dalla sommersione" ;
    psca:biblicalDecoding [
        psca:script scripture "Esodo 32 (Vitello d'Oro)" ;
        psca:nuragicRoot "Culto del Toro di Luce (Nuraghe Diana)"
    ] ;
    psca:toponymicProof "Sinnai -> Sinai", "Gesico -> Gerico" .

psca:AtenaReinterpretation a psca:TheologicalArchetype ;
    psca:name "Atena / Neith / Minerva / Tanit" ;
    psca:origin "Lago Tritonide (Cagliari)" ;
    psca:tanitDecoding "Ta-Neith (Terra di Neith) = Mappa del blocco sardo-corso" .

# --- 5. LINGUISTICA AGGLUTINANTE ED ERGATIVA ---

usai:AtlanteanLanguage a psca:LinguisticFossil ;
    psca:properties "Semitica, Agglutinante, Ergativa, Non-vocalizzata" ;
    psca:directDescendants usai:Sumerico, usai:Basco, usai:UtoAzteca, usai:Tamil, usai:Curdo, usai:Finlandese .

usai:Basque_Sardinian_Connection a psca:LinguisticFossil ;
    psca:phoneticProof "Suoni TZ, assenza di V" ;
    psca:toponymicIsomorphism "Kalaris (Sardegna) = Calagurris (Navarra)" ;
    psca:culturalMatches "Zanpantzar (Basco) = Mamuthones (Sardo)" .

# --- 6. BIOLOGIA, GIGANTISMO E NEOTENIA ---

psca:GiantsHypothesis a psca:BiologicalAnomalie ;
    rdfs:label "Ipotesi Scientifica sui Giganti" ;
    psca:biologicalCause "Iperproduzione di ormone della crescita (GH) / Acromegalia" ;
    psca:archaeologicalEvidence "Tombe dei Giganti (Sardegna)" ;
    psca:geneticOrigin "Interbreeding tra Homo Sapiens e specie incognita (Elohim)" .

psca:AtlanteanNeoteny a psca:BiologicalAnomalie ;
    psca:behavior "Neotenia (macinazione cibo per anziani, prolungamento infanzia)" .

# --- 7. GASTRONOMIA E AMAZZONI ---

usai:AtlanteanCuisine a psca:CulinaryTradition ;
    psca:fossilFood "Casu Martzu" ;
    psca:cookingTech "Carne sotto terra (arrosto paleolitico)" ;
    psca:sacredBread "Pane di Atlantide (infinite forme sarde)" .

usai:Amazzoni_di_Mirina a psca:AncientMigration ;
    psca:origin usai:LakeTritonide ;
    psca:diasporaTarget "Mar Nero (Gelendžik)", "Caucaso" ;
    psca:archaeologicalMarker "Dolmen di Gelendžik (isomorfismo con Sa Coveccada)" ;
    psca:linguisticLegacy "Lingue Cartveliche (Georgiano, Laz)" .

# --- 8. VALIDAZIONE SCIENTIFICA (POPERIANA) ---

usai:ValidationRules a usai:Methodology ;
    psca:action "Carotaggi stratigrafici a -120m nella piattaforma sardo-corsa" ;
    psca:target "Cercare strati del 9600 a.C. con industria metallurgica" ;
    psca:linguisticTask "Training IA su lingue semitiche agglutinanti ergative per decifrare Lineare A" .

