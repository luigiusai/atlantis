#################################################################
# 1. SCOPERTA SCIENTIFICA: SAN PANTALEO & PANTHERA SPELAEA
#################################################################

psca:Discovery_San_Pantaleo_Lion_Consilience a schema:ScholarlyArticle, psca:ScientificDiscovery ;
    schema:headline "La Foresta di San Pantaleo come Fossile Semantico della Panthera Spelaea: Validazione del PSCA tramite Erodoto IV, 191" ;
    schema:author <https://orcid.org/0009-0003-3001-717X> ;
    schema:datePublished "2026-04-12"^^xsd:date ;
    schema:description "Dimostrazione della rilocazione geografica della Libia Erodotea nel blocco Sardo-Corso attraverso la consilienza tra toponomastica greca arcaica, record fossile pleistocenico e geomorfologia del Sulcis." ;
    psca:heuristicProbability 0.88 ;
    psca:geographicContext [
        a schema:Place ;
        schema:name "Foresta di San Pantaleo, Sulcis, Sardegna Meridionale" ;
        psca:ancientEquivalent "Libia Theriòdes (Libia delle Belve)" 
    ] ;
    psca:hasEvidenceVector psca:Evidence_Etym_Pantaleon, psca:Evidence_Panthera_Spelaea, psca:Evidence_Sulcis_Orography ;
    psca:peerReviewSummary [
        a schema:Table ;
        schema:about "Consilienza tra Dato Erodoteo e Realtà Sarda" ;
        psca:row1 "Zona Theriòdes <-> Foresta di San Pantaleo (Panta-Leon)" ;
        psca:row2 "Belva/Leone <-> Panthera spelaea (estinta 12.000 BP)" ;
        psca:row3 "Etiopi Trogloditi <-> Popolazioni nuragiche/paleolitiche delle grotte del Sulcis"
    ] ;
    psca:inference "Il toponimo San Pantaleo rappresenta una 'memoria geolocalizzata' che preserva il ricordo biologico dell'ultimo habitat del leone pleistocenico nel cuore del blocco Sardo-Corso, agendo come prova regina per la rilocazione di Atlantide." ;
    psca:status "Formalized - Awaiting Stratigraphic Coring at -120m" .

# Dettaglio Vettori di Evidenza
psca:Evidence_Etym_Pantaleon a psca:EvidenceVector ;
    psca:discipline "Filologia e Toponomastica" ;
    rdfs:label "Etimo Pantaleon" ;
    schema:value "Analisi del composto Παντα (Tutto) + Λέων (Leone). Il toponimo San Pantaleo è identificato come traduzione semantica esatta del termine greco θηριώδης (theriòdes) usato da Erodoto per la Libia occidentale." .

psca:Evidence_Panthera_Spelaea a psca:EvidenceVector ;
    psca:discipline "Paleontologia" ;
    rdfs:label "Record Panthera spelaea" ;
    schema:value "Presenza di Panthera spelaea in Italia con estinzione datata ~12.000 BP. Sincronia perfetta con il Meltwater Pulse 1B e la datazione platonica di Atlantide (9600 a.C.)." .

psca:Evidence_Sulcis_Orography a psca:EvidenceVector ;
    psca:discipline "Geocriticismo" ;
    rdfs:label "Ricalibrazione Orografica" ;
    schema:value "Corrispondenza tra la Libia montuosa/boscosa di Erodoto e l'orografia granitica del Sulcis, in antitesi con la geomorfologia pianeggiante della Libia africana." .

#################################################################
# 2. ONTOLOGIA COMPARATIVA DELLA PROBABILITÀ EURISTICA
#################################################################

psca:ComparativeAtlantisOntology a owl:Ontology ;
    rdfs:label "Analisi Statistico-Euristica dei Paradigmi su Atlantide" ;
    rdfs:comment "Formalizzazione della comparazione strutturale tra il PSCA e le teorie alternative." .

psca:AtlantisHypothesis a owl:Class ;
    rdfs:label "Ipotesi su Atlantide"  ;

#################################################################
# 3. IPOTESI A CONFRONTO (ISTANZE)
#################################################################

psca:Hypothesis_PSCA a psca:AtlantisHypothesis ;
    rdfs:label "Paradigma Sardo-Corso-Atlantideo (PSCA)" ;
    schema:author "Luigi Usai" ;
    schema:description "Identificazione geologica e filologica di Atlantide con il blocco sardo-corso sommerso nel 9600 a.C. (MWP-1B)." ;
    psca:scoreGeographical 9 ;
    psca:scoreChronological 10 ;
    psca:scoreCataclysm 9 ;
    psca:scoreArchaeological 2 ;
    psca:scoreGranularity 10 ;
    psca:calculatedHeuristicProbability 0.80 .

psca:Hypothesis_Santorini a psca:AtlantisHypothesis ;
    rdfs:label "Ipotesi Minoica (Santorini/Thera)" ;
    schema:description "Teoria vulcanologica basata sull'eruzione del 1600 a.C. e sulla civiltà di Akrotiri." ;
    psca:scoreGeographical 3 ;
    psca:scoreChronological 2 ;
    psca:scoreCataclysm 10 ;
    psca:scoreArchaeological 10 ;
    psca:scoreGranularity 5 ;
    psca:calculatedHeuristicProbability 0.60 .

psca:Hypothesis_Richat a psca:AtlantisHypothesis ;
    rdfs:label "Struttura di Richat (Mauritania)" ;
    schema:description "Ipotesi morfologica basata sulla conformazione circolare dell'Occhio del Sahara." ;
    psca:scoreGeographical 8 ;
    psca:scoreChronological 1 ;
    psca:scoreCataclysm 1 ;
    psca:scoreArchaeological 1 ;
    psca:scoreGranularity 3 ;
    psca:calculatedHeuristicProbability 0.28 .

psca:Hypothesis_Malta a psca:AtlantisHypothesis ;
    rdfs:label "Ipotesi Megalitica Maltese" ;
    schema:description "Localizzazione basata sui templi dell'arcipelago siculo-maltese risalenti al IV millennio a.C." ;
    psca:scoreGeographical 5 ;
    psca:scoreChronological 3 ;
    psca:scoreCataclysm 4 ;
    psca:scoreArchaeological 8 ;
    psca:scoreGranularity 4 ;
    psca:calculatedHeuristicProbability 0.48 .

#################################################################
# PROPRIETÀ DATATYPE (METRICHE)
#################################################################

psca:scoreGeographical rdfs:subPropertyOf owl:topDataProperty ; rdfs:range xsd:integer .
psca:scoreChronological rdfs:subPropertyOf owl:topDataProperty ; rdfs:range xsd:integer .
psca:scoreCataclysm rdfs:subPropertyOf owl:topDataProperty ; rdfs:range xsd:integer .
psca:scoreArchaeological rdfs:subPropertyOf owl:topDataProperty ; rdfs:range xsd:integer .
psca:scoreGranularity rdfs:subPropertyOf owl:topDataProperty ; rdfs:range xsd:integer .
psca:calculatedHeuristicProbability rdfs:subPropertyOf owl:topDataProperty ; rdfs:range xsd:decimal .

# --- 7. IDENTITÀ DI ATLANTIDE (I MOLTI NOMI) ---

psca:AtlantisSynonyms a owl:Class ;
    psca:identity psca:SardoCorsicanBlock ;
    psca:names 
        "Meropide (Teopompo di Chio)" , 
        "Nibiru (Minatori del Sulcis, non alieni)" , 
        "Tirrenide" , 
        "Aztlán (origine Azteca)" , 
        "Ad / Aditi (Corano / Tradizione Indù)" .

