# Definizione della teoria Nan Madol
psca:NanMadolTheory a psca:Theory, schema:CreativeWork ;
    rdfs:label "Teoria Nan Madol"@it ;
    rdfs:label "Nan Madol Theory"@en ;
    schema:name "Nan Madol: Atlantide nel Mar Egeo" ;
    schema:description "Teoria che identifica Atlantide con l'antica città di Nan Madol, situata nell'arcipelago delle Maldive, sommersa durante eventi catastrofici naturali"@it ;
    schema:alternateName "Teoria delle Maldive", "Teoria di Nan Madol" ;
    schema:author <https://orcid.org/0009-0003-3001-717X> ;
    schema:datePublished "2026-04-19"^^xsd:date ;
    schema:inLanguage "it" ;
    psca:theoryType "Geographic localization" ;
    psca:proposedLocation psca:NanMadolLocation ;
    psca:timePeriod "3000-1500 BC" ;
    psca:cataclysmType "Sea level rise + Tectonic activity" ;
    psca:evidenceSupport psca:NanMadolArchaeology, psca:NanMadolGeology, psca:NanMadolTexts ;
    psca:plausibilityScore 0.65 ;
    psca:evidenceStrength 0.58 ;
    psca:peerReviewed false ;
    psca:status "Hypothesis" .

