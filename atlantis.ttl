psca:HebrewMigration a psca:AncientMigration ;
psca:people "Ebrei (Popolo Atlantideo)" ;
psca:reason "Fuga dalle paleocoste sommerse (Diluvio)" ;
psca:target "Terra Promessa (Ricerca di una nuova terra emersa)" ;
psca:etymology_Sinai "Sinnai (Sardegna) -> Sinai" ;
psca:associatedArtifact psca:CassapancaSarda_Arca .

psca:Bithia a psca:ToponymicEvolution ;
psca:biblicalCharacter "Bithia (figlia del Faraone)" ;
psca:sardinianToponym "Bithia (Chia/Domus de Maria)" ;
psca:geographicContext "Vicina alla spiaggia Su Giudeu (Il Giudeo)" .

# --- 4. CONNESSIONI ORIENTALI E CINESI ---

psca:FangDing_China a schema:Thing ;
rdfs:label "Fang Ding (Vasi in Bronzo Cinesi)" ;
psca:hypothesizedOrigin "Migrazione sardo-corso-atlantidea in Cina" ;
psca:iconography "Dio Toro raffigurato sul fronte" ;
