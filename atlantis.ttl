    rdfs:label "External Epistemic Reviewer (LU)"@en ;
    dct:description "External reviewer providing a structured epistemic assessment of the PSCA research programme."@en .

psca:EpistemicAssessment_PSCA_2026_LU
    a prov:Entity , psca:ExternalAssessment ;
