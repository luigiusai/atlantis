    psca:impactCategory "HistoricalLinguistics; ComparativeLinguistics" ;
    psca:consequenceConfidence "0.55"^^xsd:decimal ;
    psca:conditionalIfExists ex:PSCA_Hypothesis ;
    psca:requiresEvidence <doi:placeholder-linguistics-evidence> ;
    prov:wasDerivedFrom ex:PSCA_Hypothesis .

