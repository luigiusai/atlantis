# SCOPERTA SCIENTIFICA DELLA FORESTA DI SAN PANTALEO

# Scoperta principale: Foresta di San Pantaleo come fossile semantico
psca:SanPantaleoDiscovery a prov:Entity ;
    rdfs:label "Scoperta Foresta di San Pantaleo"@it ;
    rdfs:label "San Pantaleo Forest Discovery"@en ;
    schema:name "San Pantaleo Forest as Panthera spelaea Semantic Fossil"@en ;
    schema:description "Scoperta della Foresta di San Pantaleo nel Sulcis come fossile semantico della Panthera spelaea, validando il Paradigma Sardo Corso Atlantideo tramite Erodoto IV, 191."@it ;
    schema:description "Discovery of San Pantaleo Forest in Sulcis as semantic fossil of Panthera spelaea, validating the Sardinian-Corsican Atlantis Paradigm through Herodotus IV, 191."@en ;
    prov:wasAttributedTo <https://orcid.org/0009-0003-3001-717X> ;
    prov:generatedAtTime "2026-04-12T00:00:00"^^xsd:dateTime ;
    schema:author <https://orcid.org/0009-0003-3001-717X> ;
    schema:datePublished "2026-04-12"^^xsd:date ;
    prov:wasDerivedFrom <https://zenodo.org/records/18060204> ;
    schema:headline "La Foresta di San Pantaleo come Fossile Semantico della Panthera Spelaea: Validazione del PSCA tramite Erodoto IV, 191" ;
    schema:identifier "psca:Discovery_San_Pantaleo_Lion_Consilience" ;
    psca:geographicContext a psca:SanPantaleoLocation ;
    psca:probability "0.88"^^xsd:decimal ;
    psca:chronology "2026-04-12"^^xsd:date ;
    psca:status "Formalized - Awaiting Stratigraphic Coring at -120m" ;
    psca:inference "Il toponimo San Pantaleo rappresenta una 'memoria geolocalizzata' che preserva il ricordo biologico dell'ultimo habitat del leone pleistocenico nel cuore del blocco Sardo-Corso, agendo come prova regina per la rilocazione di Atlantide."@it ;
    psca:inference "The toponym San Pantaleo represents a 'geolocalized memory' that preserves the biological memory of the last Pleistocene lion's habitat in the heart of the Sardinian-Corsican block, acting as queen's proof for the relocation of Atlantis."@en .

