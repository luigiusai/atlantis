    dct:description "Critical epistemic assessment of the PSCA as a Lakatosian research programme, distinguishing formalization, inferential computability and empirical validation."@en ;
    prov:wasAttributedTo psca:ExternalReviewer_LU ;
    prov:generatedAtTime "2026-04-15T12:41:00+02:00"^^xsd:dateTime ;
    prov:wasDerivedFrom  psca:PSCA_Ontology_v2026 ;
    psca:assesses        psca:PSCA_ResearchProgramme .

#################################################################
# 5. PLACEHOLDER PER VERSIONAMENTO DELL'ONTOLOGIA
#################################################################

psca:PSCA_Ontology_v2026
