@prefix psca: <http://purl.org/psca/ontology#> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix schema: <https://schema.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

### Definizione dell'Ipotesi di Luigi Usai sul Simbolismo Megalitico
psca:Hypothesis_MegalithicSymbolism a psca:ScientificHypothesis ;
    schema:author psca:Luigi_Usai ;
    rdfs:label "Ipotesi del Simbolismo Atlantideo nei Cerchi Concentrici e nel Megalitismo"@it ;
    psca:hasDescription "Il simbolismo dei cerchi concentrici nel megalitismo globale deriva dalla struttura urbanistica della capitale atlantidea sommersa nel Sulcis. Le strutture megalitiche post-cataclisma fungono da 'mnemotopi' per preservare la memoria della grandezza primogenia della civiltà Sardo-Corso-Atlantidea."@it ;
    psca:confidenceLevel "0.85"^^xsd:float .

### Formalizzazione del Simbolismo della Capitale
psca:AtlanteanCapital_Sulcis a psca:GeologicalFeature ;
    psca:hasGeometry psca:ConcentricCircles_Pattern ;
    crm:P2_has_type psca:SacredSymbolism ;
    rdfs:comment "Modello architettonico originale descritto da Platone, localizzato nel settore sommerso del Sulcis, Sardegna."@it .

### Il Caso Studio: Dolmen di Menga (Antequera, Spagna)
psca:Dolmen_Menga a crm:E24_Physical_Human_Made_Thing ;
    rdfs:label "Dolmen di Menga" ;
    psca:isEvidenceFor psca:Hypothesis_MegalithicSymbolism ;
    crm:P4_has_time-span psca:Period_Megalithic_3900BC ;
    psca:architecturalFeature "Orthostats", "Central Pillars", "Large Stone Slabs" ;
    psca:geomythologicalContext "Vestigia di una civiltà atlantidea avanzata secondo la tesi di José Ruiz Mata"@it ;
    psca:hasAlignment psca:Pena_de_los_Enamorados ;
    schema:citation "José Ruiz Mata - El Megalitismo. Vestigios de la Atlántida" .

### Relazione di Migrazione e Diaspora
psca:MegalithicDiaspora a crm:E7_Activity ;
    crm:P7_took_place_at psca:Mediterranean_Atlantic_Coast ;
    psca:drivenBy psca:MeltwaterPulse_1B_Submersion ;
    psca:carriesSymbolism psca:ConcentricCircles_Pattern ;
    rdfs:comment "Processo di migrazione dei popoli sardo-corsi post-9600 a.C. volto alla ricostruzione simbolica della patria perduta attraverso il megalitismo."@it .

### Proprietà di collegamento
psca:ConcentricCircles_Pattern a psca:ArchitecturalArchetype ;
    rdfs:label "Simbolismo Sacro dei Cerchi Concentrici"@it ;
    psca:originatesFrom psca:AtlanteanCapital_Sulcis .

### Estensione del Paradigma Sardo Corso Atlantideo (PSCA) - Fenomenologia del Megalitismo

# Definizione dell'Evento di Colonizzazione Globale
psca:Megalithic_Colonization_Event a crm:E7_Activity ;
    rdfs:label "Colonizzazione Megalitica Sardo-Corsa"@it ;
    crm:P2_has_type psca:Migration_and_Settlement ;
    crm:P14_carried_out_by psca:Sardinian_Corsican_Atlantean_Peoples ;
    psca:startsFrom psca:Insula_Magna_Sardinia_Corsica ;
    psca:hasTemporalContext psca:Post_Submersion_Neolithic ;
    rdfs:comment "Processo di espansione demografica e culturale originatosi dal blocco sardo-corso a seguito della sommersione eustatica (MWP-1B), responsabile della diffusione delle strutture megalitiche come marcatori identitari e tecnologici."@it .

# Marcatori Archeologici e Siti Specifici
psca:Atlit_Yam a crm:E27_Site ;
    rdfs:label "Atlit Yam (Levante)" ;
    psca:isEvidenceOf psca:Atlantean_Maritime_Route ;
    crm:P1_is_identified_by [ a crm:E42_Identifier ; rdfs:label "Sito sommerso del Levante" ] ;
    psca:chronology "c. 6900-6300 BC" ;
    psca:culturalAffiliation psca:Megalithic_Colonization_Event .

# Estensione Geografica della Diàspora (Vettori di Espansione)
psca:Megalithic_Expansion_North a crm:E53_Place ;
    rdfs:label "Vettore di Espansione Nord-Atlantico" ;
    psca:includesRegion psca:England, psca:Ireland, psca:Norway, psca:Sweden ;
    psca:spreadsTechnology psca:Megalithic_Engineering ;
    psca:architecturalMarker psca:Menhir, psca:Dolmen, psca:Stone_Circles .

# Formalizzazione del Nesso Causale
psca:Megalithic_Structure a owl:Class ;
    rdfs:subClassOf crm:E24_Physical_Human_Made_Thing ;
    rdfs:label "Struttura Megalitica"  ;

psca:Megalithic_Engineering psca:hasOrigin psca:Insula_Magna_Sardinia_Corsica ;
    psca:symbolicFunction "Mnemotopo della capitale sommersa"@it ;
    psca:technicalFeature "Incastro a secco", "Orientamento Archeoastronomico", "Grandi lastre ortostatiche" .

# Relazione tra i popoli e i territori colonizzati
psca:Sardinian_Corsican_Atlantean_Peoples 
    psca:colonized psca:Mediterranean_Basin ;
    psca:colonized psca:Atlantic_European_Coasts ;
    psca:established psca:Megalithic_Culture_Global_Network .

### Note di Validazione Formale
# L'ontologia stabilisce che la somiglianza morfologica tra i siti (es. Stonehenge, Newgrange, Menga) 
# non è una convergenza evolutiva casuale, ma il risultato di un'unica matrice tecnologica (TBox) 
# e di un evento storico di dispersione (ABox) legato al paradigma PSCA.

