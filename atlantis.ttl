    psca:detectionThreshold 0.95 ;
    psca:falsePositiveRate 0.03 ;
    psca:truePositiveRate 0.89 ;
    psca:anomaliesIdentified 12 ;
    psca:paradigmShiftPotential 3 ;
    prov:wasGeneratedBy psca:MLFramework .

