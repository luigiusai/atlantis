# Elementi individuali del vettore evidenze
psca:PantaleonEtymology a psca:EvidenceVector ;
    rdfs:label "Etimo Pantaleon"@it ;
    rdfs:label "Pantaleon Etymology"@en ;
    schema:name "Pantaleon Etymology Analysis"@en ;
    schema:description "Analisi del composto Παντα (Tutto) + Λέων (Leone). Il toponimo San Pantaleo è identificato come traduzione semantica esatta del termine greco θηριώδης (theriòdes) usato da Erodoto per la Libia occidentale."@it ;
    schema:description "Analysis of the compound Παντα (All) + Λέων (Lion). The toponym San Pantaleo is identified as an exact semantic translation of the Greek term θηριώδης (theriòdes) used by Herodotus for western Libya."@en ;
    psca:discipline "Filologia e Toponomastica" ;
    prov:wasDerivedFrom psca:SanPantaleoDiscovery ;
    prov:generatedAtTime "2026-04-12T00:00:00"^^xsd:dateTime .

