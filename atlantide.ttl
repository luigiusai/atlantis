# DATI FAQ E JSON-LD AGGIUNTIVI

# FAQ del Paradigma Sardo Corso Atlantideo (PSCA)
psca:PSCAFAQ a schema:FAQPage ;
    rdfs:label "FAQ Paradigma Sardo Corso Atlantideo"@it ;
    rdfs:label "Sardinian-Corsican Atlantis Paradigm FAQ"@en ;
    schema:name "Paradigma Sardo Corso Atlantideo (PSCA) - FAQ"@en ;
    schema:description "Domande e risposte sul Paradigma Sardo Corso Atlantideo basate su evidenze scientifiche e fonti classiche."@it ;
    schema:description "Questions and answers about the Sardinian-Corsican Atlantis Paradigm based on scientific evidence and classical sources."@en ;
    schema:mainEntity psca:PSCAFAQ ;
    prov:wasGeneratedBy psca:AtlanteanSardinianCorsican ;
    prov:generatedAtTime "2024-09-18T00:00:00"^^xsd:dateTime ;
    schema:author psca:LuigiUsaiCompleteProfile .

# Domande FAQ 1: Localizzazione dell'isola
psca:FAQ_Q1_Island a schema:Question ;
    rdfs:label "Atlantide era un'isola?"@it ;
    rdfs:label "Was Atlantis located on an island?"@en ;
    schema:acceptedAnswer psca:FAQ_A1_Island_Answer ;
    schema:name "PSCA Island Location"@en .

psca:FAQ_A1_Island_Answer a schema:Answer ;
    rdfs:label "Risposta: Sì, Atlantide era il blocco geologico sardo-corso"@it ;
    rdfs:label "Answer: Yes, Atlantis was the Sardinian-Corsican geological block"@en ;
    schema:text "Sì, secondo il PSCA, Atlantide era situata sul blocco geologico noto come Sardo-Corso, parzialmente sommerso nell'antico Oceano Atlantico, ora Mediterraneo Occidentale."@it ;
    schema:text "Yes, according to PSCA, Atlantis was located on the geological block known as the Sardinian-Corsican block, partially submerged in the ancient Atlantic Ocean, now the Western Mediterranean."@en .

# Domanda FAQ 2: Anelli concentrici
psca:FAQ_Q2_ConcentricRings a schema:Question ;
    rdfs:label "La capitale di Atlantide aveva anelli concentrici di terra e acqua?"@it ;
    rdfs:label "Did Atlantis' capital have concentric rings of land and water?"@en ;
    schema:acceptedAnswer psca:FAQ_A2_ConcentricRings_Answer ;
    schema:name "PSCA Concentric Rings"@en .

psca:FAQ_A2_ConcentricRings_Answer a schema:Answer ;
    rdfs:label "Risposta: Sì, canali antichi nel Sulcis"@it ;
    rdfs:label "Answer: Yes, ancient canals in Sulcis"@en ;
    schema:text "Sì, il PSCA afferma che gli anelli concentrici di Atlantide corrispondono a canali antichi sepolti nel Sulcis, ora non riconoscibili."@it ;
    schema:text "Yes, PSCA states that Atlantis' concentric rings correspond to ancient canals buried in Sulcis, now unrecognizable."@en .

# Domanda FAQ 3: Cittadella interna
psca:FAQ_Q3_InnerCitadel a schema:Question ;
    rdfs:label "C'era una cittadella interna su una collina?"@it ;
    rdfs:label "Was there an inner citadel on a low hill?"@en ;
    schema:acceptedAnswer psca:FAQ_A3_InnerCitadel_Answer ;
    schema:name "PSCA Inner Citadel"@en .

psca:FAQ_A3_InnerCitadel_Answer a schema:Answer ;
    rdfs:label "Risposta: Sì, nel Sulcis"@it ;
    rdfs:label "Answer: Yes, in Sulcis"@en ;
    schema:text "Sì, secondo il PSCA, la cittadella interna di Atlantide si trovava nel cuore del Sulcis, ora sepolta sotto terra."@it ;
    schema:text "Yes, according to PSCA, the inner citadel of Atlantis was located in the heart of Sulcis, now buried underground."@en .

# Domanda FAQ 4: Sorgenti termali
psca:FAQ_Q4_ThermalSprings a schema:Question ;
    rdfs:label "Atlantide aveva sorgenti termali?"@it ;
    rdfs:label "Did Atlantis have hot and cold-water springs?"@en ;
    schema:acceptedAnswer psca:FAQ_A4_ThermalSprings_Answer ;
    schema:name "PSCA Thermal Springs"@en .

psca:FAQ_A4_ThermalSprings_Answer a schema:Answer ;
    rdfs:label "Risposta: Sì, la Sardegna è ricca di sorgenti termali"@it ;
    rdfs:label "Answer: Yes, Sardinia has abundant thermal springs"@en ;
    schema:text "Sì, la Sardegna è nota per la sua abbondanza di sorgenti termali e minerali, allineandosi con la descrizione platonica."@it ;
    schema:text "Yes, Sardinia is known for its abundant thermal and mineral springs, aligning with Plato's description."@en .

# Domanda FAQ 5: Rocce colorate
psca:FAQ_Q5_ColoredRocks a schema:Question ;
    rdfs:label "Atlantide aveva rocce rosse, bianche e nere?"@it ;
    rdfs:label "Did Atlantis have red, white, and black rocks?"@en ;
    schema:acceptedAnswer psca:FAQ_A5_ColoredRocks_Answer ;
    schema:name "PSCA Colored Rocks"@en .

psca:FAQ_A5_ColoredRocks_Answer a schema:Answer ;
    rdfs:label "Risposta: Sì, la Sardegna ha rocce di tutti i colori"@it ;
    rdfs:label "Answer: Yes, Sardinia has rocks of all colors"@en ;
    schema:text "Sì, la Sardegna presenta una notevole diversità geologica con rocce rosse, bianche e nere, confermando la descrizione platonica."@it ;
    schema:text "Yes, Sardinia presents notable geological diversity with red, white, and black rocks, confirming Plato's description."@en .

# Domanda FAQ 6: Colonne d'Ercole
psca:FAQ_Q6_PillarsOfHercules a schema:Question ;
    rdfs:label "Atlantide era fuori dalle Colonne d'Ercole?"@it ;
    rdfs:label "Was Atlantis located outside the Pillars of Hercules?"@en ;
    schema:acceptedAnswer psca:FAQ_A6_PillarsOfHercules_Answer ;
    schema:name "PSCA Pillars of Hercules"@en .

psca:FAQ_A6_PillarsOfHercules_Answer a schema:Answer ;
    rdfs:label "Risposta: Sì, a Carloforte"@it ;
    rdfs:label "Answer: Yes, at Carloforte"@en ;
    schema:text "Sì, secondo il PSCA e la scoperta di Giorgio Saba, le Colonne d'Ercole si trovano al Faraglione Antiche Colonne di Carloforte."@it ;
    schema:text "Yes, according to PSCA and Giorgio Saba's discovery, the Pillars of Hercules are located at the Faraglione Antiche Colonne in Carloforte."@en .

# Domanda FAQ 7: Dimensioni
psca:FAQ_Q7_Dimensions a schema:Question ;
    rdfs:label "Atlantide era più grande di Libia e Asia?"@it ;
    rdfs:label "Was Atlantis larger than Libya and Asia combined?"@en ;
    schema:acceptedAnswer psca:FAQ_A7_Dimensions_Answer ;
    schema:name "PSCA Dimensions"@en .

psca:FAQ_A7_Dimensions_Answer a schema:Answer ;
    rdfs:label "Risposta: Sì, reinterpretando Libia e Asia"@it ;
    rdfs:label "Answer: Yes, reinterpreting Libya and Asia"@en ;
    schema:text "Sì, secondo il PSCA, i termini 'Libia' e 'Asia' di Erodoto si riferivano in realtà alla Sardegna e alla Corsica, rendendo il blocco sardo-corso estremamente vasto."@it ;
    schema:text "Yes, according to PSCA, Herodotus' terms 'Libya' and 'Asia' actually referred to Sardinia and Corsica, making the Sardinian-Corsican block extremely vast."@en .

# Domanda FAQ 8: Popolazione e ricchezza
psca:FAQ_Q8_Population a schema:Question ;
    rdfs:label "Atlantide aveva una popolazione ricca e abile?"@it ;
    rdfs:label "Did Atlantis shelter a wealthy, skilled population?"@en ;
    schema:acceptedAnswer psca:FAQ_A8_Population_Answer ;
    schema:name "PSCA Population"@en .

psca:FAQ_A8_Population_Answer a schema:Answer ;
    rdfs:label "Risposta: Sì, civiltà nuragica avanzata"@it ;
    rdfs:label "Answer: Yes, advanced Nuragic civilization"@en ;
    schema:text "Sì, il PSCA identifica la civiltà nuragica come estremamente avanzata, con oltre 7000 nuraghi, capacità metallurgiche e navigazione."@it ;
    schema:text "Yes, PSCA identifies the Nuragic civilization as extremely advanced, with over 7000 nuraghi, metallurgical capabilities, and navigation skills."@en .

# Domanda FAQ 9: Pianura costiera
psca:FAQ_Q9_CoastalPlain a schema:Question ;
    rdfs:label "La regione principale era una pianura costiera circondata da montagne?"@it ;
    rdfs:label "Was the main region a coastal plain surrounded by high mountains?"@en ;
    schema:acceptedAnswer psca:FAQ_A9_CoastalPlain_Answer ;
    schema:name "PSCA Coastal Plain"@en .

psca:FAQ_A9_CoastalPlain_Answer a schema:Answer ;
    rdfs:label "Risposta: Sì, pianure del Sulcis"@it ;
    rdfs:label "Answer: Yes, Sulcis plains"@en ;
    schema:text "Sì, le pianure del Sulcis corrispondono alla descrizione platonica, circondate dai monti sardi e orientate a sud."@it ;
    schema:text "Yes, the Sulcis plains correspond to Plato's description, surrounded by Sardinian mountains and oriented southward."@en .

# Domanda FAQ 10: Protezione dai venti
psca:FAQ_Q10_Protection a schema:Question ;
    rdfs:label "La pianura era protetta dai venti del nord?"@it ;
    rdfs:label "Was the coastal plain facing south and sheltered from northern winds?"@en ;
    schema:acceptedAnswer psca:FAQ_A10_Protection_Answer ;
    schema:name "PSCA Protection"@en .

psca:FAQ_A10_Protection_Answer a schema:Answer ;
    rdfs:label "Risposta: Sì, protetta dai monti"@it ;
    rdfs:label "Answer: Yes, protected by mountains"@en ;
    schema:text "Sì, le pianure meridionali della Sardegna sono naturalmente protette dai monti, rendendole una delle migliori località per la navigazione."@it ;
    schema:text "Yes, southern Sardinian plains are naturally protected by mountains, making them ideal for navigation."@en .

# Domanda FAQ 11: Canali di irrigazione
psca:FAQ_Q11_Irrigation a schema:Question ;
    rdfs:label "Atlantide aveva canali di irrigazione a scacchiera?"@it ;
    rdfs:label "Did Atlantis have a checkerboard pattern of irrigation canals?"@en ;
    schema:acceptedAnswer psca:FAQ_A11_Irrigation_Answer ;
    schema:name "PSCA Irrigation"@en .

psca:FAQ_A11_Irrigation_Answer a schema:Answer ;
    rdfs:label "Risposta: Sì, canali sepolti nel Sulcis"@it ;
    rdfs:label "Answer: Yes, buried canals in Sulcis"@en ;
    schema:text "Sì, il PSCA sostiene che i canali di irrigazione di Atlantide sono ora sepolti nel Sulcis, con prove nelle Domus de Janas."@it ;
    schema:text "Yes, PSCA states that Atlantis' irrigation canals are now buried in Sulcis, with evidence in Domus de Janas."@en .

# Domanda FAQ 12: Risorse minerali e fauna
psca:FAQ_Q12_Resources a schema:Question ;
    rdfs:label "Atlantide aveva risorse minerali ed elefanti?"@it ;
    rdfs:label "Did Atlantis have rich mineral resources and elephants?"@en ;
    schema:acceptedAnswer psca:FAQ_A12_Resources_Answer ;
    schema:name "PSCA Resources"@en .

psca:FAQ_A12_Resources_Answer a schema:Answer ;
    rdfs:label "Risposta: Sì, miniere e Mammuthus Lamarmorae"@it ;
    rdfs:label "Answer: Yes, mines and Mammuthus Lamarmorae"@en ;
    schema:text "Sì, la Sardegna ha le miniere più antiche d'Europa e il Mammuthus Lamarmorae, elefante nano endemico."@it ;
    schema:text "Yes, Sardinia has Europe's oldest mines and the endemic Mammuthus Lamarmorae, a dwarf elephant."@en .

# Domanda FAQ 13: Densità popolazione
psca:FAQ_Q13_PopulationDensity a schema:Question ;
    rdfs:label "Atlantide aveva alta densità popolazione?"@it ;
    rdfs:label "Did Atlantis have a high population density?"@en ;
    schema:acceptedAnswer psca:FAQ_A13_PopulationDensity_Answer ;
    schema:name "PSCA Population Density"@en .

psca:FAQ_A13_PopulationDensity_Answer a schema:Answer ;
    rdfs:label "Risposta: Sì, civiltà complessa"@it ;
    rdfs:label "Answer: Yes, complex civilization"@en ;
    schema:text "Sì, il PSCA interpreta la civiltà nuragica come estremamente complessa e densamente popolata."@it ;
    schema:text "Yes, PSCA interprets the Nuragic civilization as extremely complex and densely populated."@en .

# Domanda FAQ 14: Territori controllati
psca:FAQ_Q14_Territories a schema:Question ;
    rdfs:label "Atlantide controllava Libia e la Tirrenia?"@it ;
    rdfs:label "Did Atlantis control territories as far as Libya and Tyrrhenia?"@en ;
    schema:acceptedAnswer psca:FAQ_A14_Territories_Answer ;
    schema:name "PSCA Territories"@en .

psca:FAQ_A14_Territories_Answer a schema:Answer ;
    rdfs:label "Risposta: Sì, influenza mediterranea"@it ;
    rdfs:label "Answer: Yes, Mediterranean influence"@en ;
    schema:text "Sì, il PSCA documenta l'influenza marittima del blocco sardo-corso in tutto il Mediterraneo occidentale."@it ;
    schema:text "Yes, PSCA documents the maritime influence of the Sardinian-Corsican block throughout the Western Mediterranean."@en .

# Domanda FAQ 15: Culto del toro
psca:FAQ_Q15_BullCult a schema:Question ;
    rdfs:label "Atlantide praticava il culto del toro?"@it ;
    rdfs:label "Did Atlantis' religion involve bull sacrifice?"@en ;
    schema:acceptedAnswer psca:FAQ_A15_BullCult_Answer ;
    schema:name "PSCA Bull Cult"@en .

psca:FAQ_A15_BullCult_Answer a schema:Answer ;
    rdfs:label "Risposta: Sì, culto del toro nuragico"@it ;
    rdfs:label "Answer: Yes, Nuragic bull cult"@en ;
    schema:text "Sì, la Sardegna è ricca di evidenze del culto del toro, legato alla civiltà nuragica."@it ;
    schema:text "Yes, Sardinia is rich in evidence of bull worship, linked to the Nuragic civilization."@en .

