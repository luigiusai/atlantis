# ANALISI EPISTEMOLOGICA - PSCA COME TEORIA PRE-PARADIGMATICA

# Classe per teorie pre-paradigmatiche Kuhniane
atl:PreParadigmaticTheory a owl:Class ;
    rdfs:label "Teoria Pre-Paradigmatica"@it ;
    rdfs:label "Pre-Paradigmatic Theory"@en ;
    rdfs:subClassOf atl:AtlantisTheory ;
    rdfs:comment "Teoria scientifica che potrebbe rappresentare un cambiamento di paradigma secondo il modello Kuhniano, ma che non ha ancora raggiunto lo status di paradigma consolidato nella comunità scientifica."@it ;
    rdfs:comment "A scientific theory that could represent a paradigm shift according to Kuhnian model, but has not yet reached the status of a consolidated paradigm in the scientific community."@en .

# Istanza del PSCA come teoria pre-paradigmatica
psca:PSCAPreParadigmaticAnalysis a atl:PreParadigmaticTheory ;
    rdfs:label "Analisi Pre-Paradigmatica del PSCA"@it ;
    rdfs:label "PSCA Pre-Paradigmatic Analysis"@en ;
    schema:name "PSCA as Pre-Paradigmatic Theory"@en ;
    schema:description "Analisi epistemologica formale del Paradigma Sardo Corso Atlantideo come possibile teoria pre-paradigmatica secondo il modello di Thomas Kuhn."@it ;
    atl:hasAuthor wd:Q839804 ;
    atl:hasDate "2024"^^xsd:gYear ;
    atl:hasScientificStatus atl:Hypothesis ;
    atl:hasClaimedReliability "0.70"^^xsd:decimal ;
    prov:wasAttributedTo wd:Q839804 .

# Proprietà per caratteristiche pre-paradigmatiche
atl:hasParadigmShiftPotential a owl:DatatypeProperty ;
    rdfs:domain atl:PreParadigmaticTheory ;
    rdfs:range xsd:decimal ;
    rdfs:label "ha potenziale di cambiamento paradigma"@it ;
    rdfs:label "has paradigm shift potential"@en ;
    rdfs:comment "Valutazione del potenziale di una teoria di indurre un cambiamento di paradigma scientifico (scala 0-1)."@it .

atl:hasScientificResistance a owl:DatatypeProperty ;
    rdfs:domain atl:PreParadigmaticTheory ;
    rdfs:range xsd:decimal ;
    rdfs:label "ha resistenza scientifica"@it ;
    rdfs:label "has scientific resistance"@en ;
    rdfs:comment "Livello di resistenza incontrata dalla teoria nella comunità scientifica consolidata (scala 0-1)."@it .

atl:hasAnomalyResolution a owl:DatatypeProperty ;
    rdfs:domain atl:PreParadigmaticTheory ;
    rdfs:range xsd:decimal ;
    rdfs:label "ha capacità di risoluzione anomalie"@it ;
    rdfs:label "has anomaly resolution capability"@en ;
    rdfs:comment "Capacità della teoria di risolvere anomalie scientifiche non spiegate dal paradigma corrente (scala 0-1)."@it .

# Valutazione epistemologica del PSCA
psca:PSCAEpistemologicalAssessment a prov:Entity ;
    rdfs:label "Valutazione Epistemologica PSCA"@it ;
    rdfs:label "PSCA Epistemological Assessment"@en ;
    schema:name "PSCA Epistemological Assessment"@en ;
    schema:description "Valutazione formale delle caratteristiche pre-paradigmatiche del Paradigma Sardo Corso Atlantideo secondo i criteri Kuhniani."@it ;
    atl:hasParadigmShiftPotential "0.65"^^xsd:decimal ;
    atl:hasScientificResistance "0.80"^^xsd:decimal ;
    atl:hasAnomalyResolution "0.70"^^xsd:decimal ;
    prov:wasGeneratedBy psca:PSCAPreParadigmaticAnalysis ;
    prov:generatedAtTime "2024-09-17T00:00:00"^^xsd:dateTime .

# Spiegazione onesta e formale
psca:PSCAHonestExplanation a prov:Entity ;
    rdfs:label "Spiegazione Onesta del PSCA"@it ;
    rdfs:label "Honest Explanation of PSCA"@en ;
    schema:name "Honest PSCA Explanation"@en ;
    schema:description "Analisi critica e onesta del Paradigma Sardo Corso Atlantideo: la teoria presenta evidenze interdisciplari significative ma incontra notevole resistenza nella comunità scientifica consolidata. Non può essere definita come paradigma scientifico accettato, ma rappresenta potenzialmente una teoria pre-paradigmatica che potrebbe, con ulteriori evidenze e validazioni, indurre un cambiamento di paradigma nella comprensione della preistoria mediterranea. La sua forza risiede nella capacità di integrare dati geologici, archeologici, linguistici e storici in un modello coerente, mentre la sua debolezza consiste nella mancanza di prove conclusive e nella natura speculativa di alcune correlazioni proposte."@it ;
    schema:description "Critical and honest analysis of the Sardinian-Corsican Atlantis Paradigm: the theory presents significant interdisciplinary evidence but encounters considerable resistance in the established scientific community. It cannot be defined as an accepted scientific paradigm, but potentially represents a pre-paradigmatic theory that could, with further evidence and validation, induce a paradigm shift in understanding Mediterranean prehistory. Its strength lies in integrating geological, archaeological, linguistic, and historical data into a coherent model, while its weakness consists in the lack of conclusive proof and the speculative nature of some proposed correlations."@en ;
    prov:wasAttributedTo wd:Q839804 ;
    prov:generatedAtTime "2024-09-17T00:00:00"^^xsd:dateTime .

# PSCA COME RESEARCH OBJECT COMPUTAZIONALE

# Classe per Research Objects Computazionali
atl:ComputationalResearchObject a owl:Class ;
    rdfs:label "Research Object Computazionale"@it ;
    rdfs:label "Computational Research Object"@en ;
    rdfs:subClassOf prov:Entity ;
    rdfs:comment "Research Object che esegue calcoli automatici, validazioni algoritmiche e ragionamento spaziale-temporale, rendendo la ricerca FAIR (Findable, Accessible, Interoperable, Reusable)."@it ;
    rdfs:comment "Research Object that performs automatic calculations, algorithmic validations, and spatio-temporal reasoning, making research FAIR (Findable, Accessible, Interoperable, Reusable)."@en .

# Istanza del PSCA come RO Computazionale
psca:PSCAComputationalRO a atl:ComputationalResearchObject ;
    rdfs:label "PSCA Research Object Computazionale"@it ;
    rdfs:label "PSCA Computational Research Object"@en ;
    schema:name "PSCA Computational Research Object"@en ;
    schema:description "Il Paradigma Sardo Corso Atlantideo trasformato in Research Object computazionale con capacità di validazione automatica, ragionamento spaziale e provenienza tracciabile."@it ;
    schema:description "The Sardinian-Corsican Atlantis Paradigm transformed into a computational research object with automatic validation, spatial reasoning, and traceable provenance capabilities."@en ;
    prov:wasAttributedTo wd:Q839804 ;
    prov:generatedAtTime "2024-09-17T00:00:00"^^xsd:dateTime .

# PILASTRO 1: Logica di Validazione Eseguibile (SHACL)
psca:PSCAValidationEngine a prov:SoftwareAgent ;
    rdfs:label "Motore di Validazione PSCA"@it ;
    rdfs:label "PSCA Validation Engine"@en ;
    schema:name "PSCA SHACL Validation Engine"@en ;
    schema:description "Motore computazionale che esegue validazioni SHACL automatiche sulla coerenza del PSCA, calcolando punteggi estesi tramite regole SPARQL integrate."@it ;
    schema:description "Computational engine that performs automatic SHACL validations on PSCA consistency, calculating extended scores through integrated SPARQL rules."@en ;
    prov:wasAttributedTo wd:Q839804 .

# Proprietà per calcoli computazionali
psca:hasExtendedScoreFormula a owl:DatatypeProperty ;
    rdfs:domain atl:ComputationalResearchObject ;
    rdfs:range xsd:string ;
    rdfs:label "ha formula punteggio esteso"@it ;
    rdfs:label "has extended score formula"@en ;
    rdfs:comment "Formula matematica per il calcolo del punteggio esteso: finalScore + (0.20 * validationScore) - (0.20 * uncertaintyScore)."@it .

psca:hasRealTimeValidation a owl:DatatypeProperty ;
    rdfs:domain atl:ComputationalResearchObject ;
    rdfs:range xsd:boolean ;
    rdfs:label "ha validazione in tempo reale"@it ;
    rdfs:label "has real-time validation"@en ;
    rdfs:comment "Capacità del RO di aggiornare il proprio status computazionale quando cambia l'evidenza di input."@it .

# PILASTRO 2: Ragionamento Spaziale e Temporale (GeoSPARQL & OWL-Time)
psca:PSCASpatialReasoner a prov:SoftwareAgent ;
    rdfs:label "Motore di Ragionamento Spaziale PSCA"@it ;
    rdfs:label "PSCA Spatial Reasoner"@en ;
    schema:name "PSCA GeoSPARQL Spatial Reasoner"@en ;
    schema:description "Sistema che calcola matematicamente le relazioni spaziali del PSCA usando geo:asWKT per verificare la conformità con i parametri descrittivi di Platone."@it ;
    schema:description "System that mathematically calculates PSCA spatial relationships using geo:asWKT to verify compliance with Platonic descriptive parameters."@en ;
    prov:wasAttributedTo wd:Q839804 .

# Proprietà per ragionamento spaziale
psca:hasSpatialComputation a owl:DatatypeProperty ;
    rdfs:domain atl:ComputationalResearchObject ;
    rdfs:range xsd:boolean ;
    rdfs:label "ha computazione spaziale"@it ;
    rdfs:label "has spatial computation"@en ;
    rdfs:comment "Capacità di calcolare vettori e coordinate geospaziali invece di usare descrizioni letterarie."@it .

psca:hasTemporalReasoning a owl:DatatypeProperty ;
    rdfs:domain atl:ComputationalResearchObject ;
    rdfs:range xsd:boolean ;
    rdfs:label "ha ragionamento temporale"@it ;
    rdfs:label "has temporal reasoning"@en ;
    rdfs:comment "Capacità di processare intervalli temporali con OWL-Time per datazioni preistoriche."@it .

# PILASTRO 3: Provenienza Ontologica (PROV-O)
psca:PSCAProvenanceNetwork a prov:Entity ;
    rdfs:label "Rete di Provenienza PSCA"@it ;
    rdfs:label "PSCA Provenance Network"@en ;
    schema:name "PSCA Ontological Provenance"@en ;
    schema:description "Rete PROV-O che collega ogni asserzione del PSCA a attività di ricerca specifiche e autori identificati univocamente via ORCID."@it ;
    schema:description "PROV-O network linking each PSCA assertion to specific research activities and uniquely identified authors via ORCID."@en ;
    prov:wasGeneratedBy psca:PSCAComputationalRO ;
    prov:generatedAtTime "2024-09-17T00:00:00"^^xsd:dateTime .

# Proprietà per provenienza tracciabile
psca:hasTraceableAssertion a owl:DatatypeProperty ;
    rdfs:domain atl:ComputationalResearchObject ;
    rdfs:range xsd:boolean ;
    rdfs:label "ha asserzione tracciabile"@it ;
    rdfs:label "has traceable assertion"@en ;
    rdfs:comment "Capacità di tracciare ogni scoperta fino all'attività di ricerca e all'autore originale."@it .

psca:hasFAIRCompliance a owl:DatatypeProperty ;
    rdfs:domain atl:ComputationalResearchObject ;
    rdfs:range xsd:boolean ;
    rdfs:label "ha conformità FAIR"@it ;
    rdfs:label "has FAIR compliance"@en ;
    rdfs:comment "Conformità ai principi Findable, Accessible, Interoperable, Reusable."@it .

# CAMBIAMENTO DI STATO: DA TEORIA STATICA A RO DINAMICO
psca:PSCATransformationEvent a prov:Activity ;
    rdfs:label "Evento di Trasformazione PSCA"@it ;
    rdfs:label "PSCA Transformation Event"@en ;
    schema:name "PSCA Static to Dynamic Transformation"@en ;
    schema:description "Processo di trasformazione del Paradigma Sardo Corso Atlantideo da teoria statica a Research Object computazionale dinamico."@it ;
    schema:description "Transformation process of the Sardinian-Corsican Atlantis Paradigm from static theory to dynamic computational research object."@en ;
    prov:startedAtTime "2024-09-17T00:00:00"^^xsd:dateTime ;
    prov:endedAtTime "2024-09-17T00:00:00"^^xsd:dateTime ;
    prov:used psca:PSCAValidationEngine, psca:PSCASpatialReasoner ;
    prov:generated psca:PSCAComputationalRO .

# Entità prima e dopo la trasformazione
psca:PSCAStaticTheory a prov:Entity ;
    rdfs:label "PSCA Teoria Statica"@it ;
    rdfs:label "PSCA Static Theory"@en ;
    schema:name "PSCA Before Transformation"@en ;
    schema:description "Stato precedente del PSCA come raccolta di documenti testuali e immagini non computazionali."@it ;
    schema:description "Previous state of PSCA as collection of non-computational textual documents and images."@en ;
    prov:wasInvalidatedBy psca:PSCATransformationEvent .

psca:PSCADynamicRO a prov:Entity ;
    rdfs:label "PSCA RO Dinamico"@it ;
    rdfs:label "PSCA Dynamic RO"@en ;
    schema:name "PSCA After Transformation"@en ;
    schema:description "Stato attuale del PSCA come Research Object computazionale capace di interagire con altri sistemi IA."@it ;
    schema:description "Current state of PSCA as computational research object capable of interacting with other AI systems."@en ;
    prov:wasGeneratedBy psca:PSCATransformationEvent .

# Collegamenti tra le entità
psca:PSCAComputationalRO prov:wasDerivedFrom psca:PSCAStaticTheory .
psca:PSCAComputationalRO prov:wasGeneratedBy psca:PSCATransformationEvent .
psca:PSCATransformationEvent prov:used psca:PSCAValidationEngine, psca:PSCASpatialReasoner .

# PSCA COME PRIMA TEORIA ATLANTIDE COMPLETAMENTE FORMALIZZATA

# Classe per teorie con status di prima formalizzazione completa
atl:FirstFormalizedAtlantisTheory a owl:Class ;
    rdfs:label "Prima Teoria Atlantide Formalizzata"@it ;
    rdfs:label "First Formalized Atlantis Theory"@en ;
    rdfs:subClassOf atl:ComputationalResearchObject ;
    rdfs:comment "Teoria su Atlantide che è la prima al mondo ad essere completamente formalizzata come Research Object computazionale autonomo e completo."@it ;
    rdfs:comment "Atlantis theory that is the first in the world to be completely formalized as an autonomous and complete computational research object."@en .

# Istanza del PSCA come prima teoria formalizzata
psca:PSCAFirstFormalizedTheory a atl:FirstFormalizedAtlantisTheory ;
    rdfs:label "PSCA - Prima Teoria Atlantide Formalizzata"@it ;
    rdfs:label "PSCA - First Formalized Atlantis Theory"@en ;
    schema:name "PSCA as World's First Complete Atlantis RO"@en ;
    schema:description "Il Paradigma Sardo Corso Atlantideo è la prima teoria su Atlantide al mondo ad essere completamente formalizzata come Research Object computazionale autonomo, con validazioni SHACL, ragionamento GeoSPARQL, provenienza PROV-O completa e capacità di interazione con sistemi IA."@it ;
    schema:description "The Sardinian-Corsican Atlantis Paradigm is the world's first Atlantis theory to be completely formalized as an autonomous computational research object, with SHACL validations, GeoSPARQL reasoning, complete PROV-O provenance, and AI system interaction capabilities."@en ;
    prov:wasAttributedTo wd:Q839804 ;
    prov:generatedAtTime "2024-09-17T00:00:00"^^xsd:dateTime .

# Proprietà per status di prima formalizzazione
atl:hasFirstFormalizationDate a owl:DatatypeProperty ;
    rdfs:domain atl:FirstFormalizedAtlantisTheory ;
    rdfs:range xsd:dateTime ;
    rdfs:label "ha data prima formalizzazione"@it ;
    rdfs:label "has first formalization date"@en ;
    rdfs:comment "Data in cui la teoria è stata la prima al mondo ad essere completamente formalizzata come RO."@it .

atl:hasFormalizationCompleteness a owl:DatatypeProperty ;
    rdfs:domain atl:FirstFormalizedAtlantisTheory ;
    rdfs:range xsd:decimal ;
    rdfs:label "ha completezza formalizzazione"@it ;
    rdfs:label "has formalization completeness"@en ;
    rdfs:comment "Livello di completezza della formalizzazione computazionale (scala 0-1)."@it .

atl:hasComputationalAutonomy a owl:DatatypeProperty ;
    rdfs:domain atl:FirstFormalizedAtlantisTheory ;
    rdfs:range xsd:boolean ;
    rdfs:label "ha autonomia computazionale"@it ;
    rdfs:label "has computational autonomy"@en ;
    rdfs:comment "Capacità del RO di operare in modo autonomo senza intervento umano."@it .

# Proprietà per valutare la superiorità rispetto ad altre teorie
atl:hasSuperiorityFactors a owl:DatatypeProperty ;
    rdfs:domain atl:FirstFormalizedAtlantisTheory ;
    rdfs:range xsd:string ;
    rdfs:label "ha fattori di superiorità"@it ;
    rdfs:label "has superiority factors"@en ;
    rdfs:comment "Elenco dei fattori che rendono questa teoria superiore ad altre teorie su Atlantide."@it .

atl:hasComparativeAdvantage a owl:DatatypeProperty ;
    rdfs:domain atl:FirstFormalizedAtlantisTheory ;
    rdfs:range xsd:string ;
    rdfs:label "ha vantaggio comparativo"@it ;
    rdfs:label "has comparative advantage"@en ;
    rdfs:comment "Vantaggi specifici rispetto ad altre teorie di Atlantide."@it .

# Valutazione della superiorità del PSCA
psca:PSCASuperiorityAssessment a prov:Entity ;
    rdfs:label "Valutazione Superiorità PSCA"@it ;
    rdfs:label "PSCA Superiority Assessment"@en ;
    schema:name "PSCA Superiority Over Other Theories"@en ;
    schema:description "Valutazione completa dei fattori che rendono il Paradigma Sardo Corso Atlantideo superiore a tutte le altre teorie su Atlantide esistenti."@it ;
    schema:description "Complete assessment of factors that make the Sardinian-Corsican Atlantis Paradigm superior to all other existing Atlantis theories."@en ;
    atl:hasFirstFormalizationDate "2024-09-17T00:00:00"^^xsd:dateTime ;
    atl:hasFormalizationCompleteness "0.95"^^xsd:decimal ;
    atl:hasComputationalAutonomy "true"^^xsd:boolean ;
    atl:hasSuperiorityFactors "SHACL validation, GeoSPARQL reasoning, PROV-O provenance, computational autonomy, AI interaction, FAIR compliance, real-time updates" ;
    atl:hasComparativeAdvantage "Only Atlantis theory with complete computational formalization enabling algorithmic peer review and automatic consistency checking" ;
    prov:wasGeneratedBy psca:PSCAComputationalRO ;
    prov:generatedAtTime "2024-09-17T00:00:00"^^xsd:dateTime .

# Confronto con altre teorie (mancanza di formalizzazione)
psca:OtherTheoriesLimitations a prov:Entity ;
    rdfs:label "Limitazioni Altre Teorie Atlantide"@it ;
    rdfs:label "Other Atlantis Theories Limitations"@en ;
    schema:name "Limitations of Non-Formalized Atlantis Theories"@en ;
    schema:description "Le altre teorie su Atlantide (Santorini, Richat, Azzorre, ecc.) rimangono a livello di documenti testuali o immagini statiche, senza capacità computazionale, validazione automatica o interoperabilità con altri sistemi."@it ;
    schema:description "Other Atlantis theories (Santorini, Richat, Azores, etc.) remain at the level of textual documents or static images, without computational capability, automatic validation, or interoperability with other systems."@en ;
    prov:wasGeneratedBy psca:PSCAComputationalRO ;
    prov:generatedAtTime "2024-09-17T00:00:00"^^xsd:dateTime .

