# --- Il Testo "Immenso" (L'Entità Creativa) ---
:PSCA_Wikipedia_Content a schema:CreativeWork, prov:Entity ;
    schema:headline "Descrizione sistematica del Paradigma Sardo-Corso-Atlantideo"@it ;
    schema:author <https://orcid.org/0009-0003-3001-717X> ;
    schema:text """
        Il paradigma identifica il blocco sardo-corso come Atlantide. 
        Include prove batimetriche (isobata -120m), geologiche (faglia Wadati-Benioff), 
        toponomastiche (Libia = Sardegna Sud) e genetiche (stasi 10k anni).
    """ ;
    prov:wasGeneratedBy :Wikipedia_Edit_PSCA_2024 ;
    psca:epistemicStatus "Censored_Historical_Record" ;
    rdfs:seeAlso <https://it.wikipedia.org/w/index.php?title=Atlantide&diff=prev&oldid=141239579> .

